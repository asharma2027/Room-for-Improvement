<%- include('partials/head', { title: 'Home | Room for Improvement' }) %>

  <body>
    <%- include('partials/nav') %>
      <main>
        <div class="landing-hero">
          <h1>Room for Improvement</h1>
          <% if (user) { %>
            <p>Welcome back, <strong>
                <%= user.email %>
              </strong>.</p>
            <div class="landing-buttons">
              <a href="/map" class="btn-secondary"
                style="padding: 0.875rem 1.75rem; text-decoration: none; border-radius: var(--radius-full); font-weight: 600;">Campus
                Map</a>
              <a href="/logout" class="btn-secondary"
                style="padding: 0.875rem 1.75rem; text-decoration: none; border-radius: var(--radius-full); font-weight: 600; background: rgba(0,0,0,0.1); border-color: transparent;">Logout</a>
            </div>
            <% } else { %>
              <p>
                The ultimate guide to UChicago housing.<br>
                Only <strong>@uchicago.edu</strong> emails can register.
              </p>
              <div class="landing-buttons">
                <a href="/register" class="btn-secondary"
                  style="padding: 0.875rem 1.75rem; text-decoration: none; border-radius: var(--radius-full); font-weight: 600;">Register</a>
                <a href="/login" class="btn-secondary"
                  style="padding: 0.875rem 1.75rem; text-decoration: none; border-radius: var(--radius-full); font-weight: 600; background: white; color: var(--primary-color);">Login</a>
              </div>
              <% } %>
        </div>

        <% if (user) { %>
        <div class="features-grid">
          <!-- Dorm Rankings panel -->
          <a href="/dorm-rankings" class="feature-item" style="text-decoration: none; color: inherit; cursor: pointer;">
            <span class="feature-icon">🏆</span>
            <h3>Dorm Rankings</h3>
            <p>Compare all dorms at a glance and see which ones rank highest across categories.</p>
          </a>
          <!-- Campus Map panel -->
          <a href="/map" class="feature-item" style="text-decoration: none; color: inherit; cursor: pointer;">
            <span class="feature-icon">🗺️</span>
            <h3>Campus Map</h3>
            <p>Explore the interactive campus map to find dorms, houses, and room locations.</p>
          </a>
          <!-- Search Rooms panel -->
          <a href="/rooms" class="feature-item" style="text-decoration: none; color: inherit; cursor: pointer;">
            <span class="feature-icon">🔍</span>
            <h3>Search Rooms</h3>
            <p>Browse and filter all rooms by dorm, house, and room attributes.</p>
          </a>
          <!-- Submit Room Info panel -->
          <div class="feature-item">
            <span class="feature-icon">📝</span>
            <h3>Submit Room Info</h3>
            <p>Select your dorm, house, and room to leave a review.</p>
            <form id="submit-room-form" style="margin-top: 1rem; text-align: left;">
              <label for="panel-dorm-select" style="font-size: 0.8rem;">Dorm</label>
              <select id="panel-dorm-select" style="width: 100%; margin-bottom: 0.5rem; padding: 0.5rem; border-radius: var(--radius-sm); border: 1.5px solid var(--border-color); font-size: 0.85rem;">
                <option value="">Select a dorm…</option>
              </select>
              <label for="panel-house-select" style="font-size: 0.8rem;">House</label>
              <select id="panel-house-select" disabled style="width: 100%; margin-bottom: 0.5rem; padding: 0.5rem; border-radius: var(--radius-sm); border: 1.5px solid var(--border-color); font-size: 0.85rem;">
                <option value="">Select a house…</option>
              </select>
              <label for="panel-room-select" style="font-size: 0.8rem;">Room</label>
              <select id="panel-room-select" disabled style="width: 100%; margin-bottom: 0.75rem; padding: 0.5rem; border-radius: var(--radius-sm); border: 1.5px solid var(--border-color); font-size: 0.85rem;">
                <option value="">Select a room…</option>
              </select>
              <button type="submit" disabled id="panel-room-go" style="width: 100%; padding: 0.6rem; font-size: 0.85rem;">Go to Review</button>
            </form>
          </div>
          <!-- Leave Feedback panel -->
          <div class="feature-item" style="cursor: pointer;" onclick="document.getElementById('feedback-section').scrollIntoView({ behavior: 'smooth' });">
            <span class="feature-icon">💬</span>
            <h3>Leave Feedback</h3>
            <p>Share your thoughts, report room issues, or suggest improvements to the site.</p>
          </div>
        </div>

        <script>
        (function() {
          var allHouses = [];
          var dormSelect = document.getElementById('panel-dorm-select');
          var houseSelect = document.getElementById('panel-house-select');
          var roomSelect = document.getElementById('panel-room-select');
          var goBtn = document.getElementById('panel-room-go');
          var form = document.getElementById('submit-room-form');

          // Fetch house data from API
          fetch('/api/houses')
            .then(function(r) { return r.json(); })
            .then(function(houses) {
              allHouses = houses;
              // Build unique dorm list
              var dorms = [];
              var seen = {};
              houses.forEach(function(h) {
                if (!seen[h.dorm]) {
                  seen[h.dorm] = true;
                  dorms.push(h.dorm);
                }
              });
              dorms.sort();
              dorms.forEach(function(d) {
                var opt = document.createElement('option');
                opt.value = d;
                opt.textContent = d;
                dormSelect.appendChild(opt);
              });
            })
            .catch(function() {
              dormSelect.innerHTML = '<option value="">Could not load data</option>';
            });

          dormSelect.addEventListener('change', function() {
            var dorm = dormSelect.value;
            houseSelect.innerHTML = '<option value="">Select a house…</option>';
            roomSelect.innerHTML = '<option value="">Select a room…</option>';
            roomSelect.disabled = true;
            goBtn.disabled = true;
            if (!dorm) {
              houseSelect.disabled = true;
              return;
            }
            houseSelect.disabled = false;
            var houses = allHouses.filter(function(h) { return h.dorm === dorm; });
            houses.sort(function(a, b) { return a.house.localeCompare(b.house); });
            houses.forEach(function(h) {
              var opt = document.createElement('option');
              opt.value = h.house;
              opt.textContent = h.house;
              houseSelect.appendChild(opt);
            });
          });

          houseSelect.addEventListener('change', function() {
            var dorm = dormSelect.value;
            var house = houseSelect.value;
            roomSelect.innerHTML = '<option value="">Loading rooms…</option>';
            roomSelect.disabled = true;
            goBtn.disabled = true;
            if (!house) {
              roomSelect.innerHTML = '<option value="">Select a room…</option>';
              return;
            }
            // Fetch rooms for this dorm/house via the search API
            fetch('/api/search?q=' + encodeURIComponent(house))
              .then(function(r) { return r.json(); })
              .then(function(results) {
                roomSelect.innerHTML = '<option value="">Select a room…</option>';
                var rooms = results.filter(function(r) {
                  return r.type === 'room' && r.dorm === dorm && r.name.indexOf(house) === 0;
                });
                rooms.sort(function(a, b) { return a.name.localeCompare(b.name); });
                if (rooms.length === 0) {
                  roomSelect.innerHTML = '<option value="">No rooms found</option>';
                  return;
                }
                roomSelect.disabled = false;
                rooms.forEach(function(r) {
                  var opt = document.createElement('option');
                  opt.value = r.url + '/review';
                  opt.textContent = r.name.replace(house + ' ', '');
                  roomSelect.appendChild(opt);
                });
              })
              .catch(function() {
                roomSelect.innerHTML = '<option value="">Error loading rooms</option>';
              });
          });

          roomSelect.addEventListener('change', function() {
            goBtn.disabled = !roomSelect.value;
          });

          form.addEventListener('submit', function(e) {
            e.preventDefault();
            if (roomSelect.value) {
              window.location.href = roomSelect.value;
            }
          });
        })();
        </script>
        <% } else { %>
        <div class="features-grid">
          <div class="feature-item">
            <span class="feature-icon">📝</span>
            <h3>Real Feedback</h3>
            <p>Submit and view real data regarding room conditions, noise levels, and house culture.</p>
          </div>
          <div class="feature-item">
            <span class="feature-icon">🔍</span>
            <h3>Smart Search</h3>
            <p>Filter by dorm, house, and even specific room attributes like ceiling height or window size.</p>
          </div>
          <div class="feature-item">
            <span class="feature-icon">📊</span>
            <h3>Data Driven</h3>
            <p>See aggregated statistics for house culture and noise levels to make informed decisions.</p>
          </div>
        </div>
        <% } %>

        <hr style="margin: 2rem 0; border: 0; border-top: 1px solid #eee;">

        <div id="feedback-section" style="max-width: 800px; margin: 0 auto; text-align: center;">
          <h2>Submit Feedback or Room Issues</h2>
          <p style="margin-bottom: 2rem; color: var(--text-secondary);">
            Help us improve! Let us know about common problems with rooms or give suggestions for the website.
          </p>

          <form method="POST" action="/feedback" class="form-container" style="text-align: left;">
            <label for="feedbackText">Your Feedback:</label>
            <textarea name="feedbackText" id="feedbackText" rows="4"
              placeholder="Describe any room problems or website ideas here..." required></textarea>
            <button type="submit" style="width: 100%; margin-top: 1rem;">Submit Feedback</button>
          </form>
        </div>
      </main>

      <footer style="text-align:center; margin-top:2rem;">
        <p>&copy; 2025 Room for Improvement</p>
      </footer>
  </body>

  </html>