<%- include('partials/head', { title: 'Submit Review | Room for Improvement' }) %>

  <body>
    <%- include('partials/nav') %>
    <style>
      /* Red asterisk for required fields */
      .req-star { color: #dc2626; font-weight: 700; margin-left: 0.15rem; }
      .opt-note { font-weight: normal; color: var(--text-secondary); font-size: 0.82rem; margin-left: 0.25rem; }

      /* Room selector section (integrated from submit-review) */
      .room-selector-section {
        max-width: 640px;
        margin: 0 auto 2rem;
        padding: 1.5rem;
        background: #fff;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-sm);
      }
      .room-selector-section h2 {
        margin: 0 0 0.25rem;
        font-size: 1.3rem;
      }
      .room-selector-section p {
        color: var(--text-secondary);
        margin: 0 0 1.25rem;
        font-size: 0.95rem;
      }
      .rs-field { margin-bottom: 1rem; }
      .rs-field label {
        display: block;
        font-weight: 600;
        font-size: 0.88rem;
        color: var(--text-secondary);
        margin-bottom: 0.4rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }
      .rs-field select, .rs-field input[type="text"] {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 2px solid var(--border-color);
        border-radius: var(--radius-md);
        font-size: 0.95rem;
        background: #fff;
        color: var(--text-primary);
        transition: border-color 0.2s;
        box-sizing: border-box;
      }
      .rs-field select:focus, .rs-field input[type="text"]:focus {
        outline: none;
        border-color: var(--primary-color);
        box-shadow: 0 0 0 3px rgba(123,0,26,0.1);
      }
      .rs-field select:disabled { background: #f9fafb; color: #aaa; cursor: not-allowed; }
      .rs-room-wrapper { position: relative; }
      .rs-room-dropdown {
        display: none;
        position: absolute;
        top: calc(100% + 4px);
        left: 0; right: 0;
        z-index: 200;
        background: #fff;
        border: 1.5px solid var(--border-color);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-lg);
        max-height: 280px;
        overflow-y: auto;
      }
      .rs-room-dropdown.open { display: block; }
      .rs-room-item {
        display: flex; align-items: center; gap: 0.75rem;
        padding: 0.6rem 1rem; cursor: pointer;
        border-bottom: 1px solid #f3f4f6;
        font-size: 0.9rem; transition: background 0.12s;
      }
      .rs-room-item:last-child { border-bottom: none; }
      .rs-room-item:hover { background: #fdf2f2; }
      .rs-room-item .rs-room-num { font-weight: 700; color: var(--text-primary); }
      .rs-room-item .rs-room-meta { font-size: 0.78rem; color: var(--text-secondary); }
      .rs-room-item.rs-add-new { color: var(--primary-color); font-weight: 600; font-style: italic; }
      .rs-room-item.rs-add-new:hover { background: rgba(123,0,26,0.05); }
      .rs-go-btn {
        width: 100%; padding: 0.85rem; font-size: 1rem;
        margin-top: 0.5rem; border-radius: var(--radius-full);
      }
      .rs-go-btn:disabled { opacity: 0.45; cursor: not-allowed; transform: none !important; box-shadow: none !important; }
    </style>

      <main>
        <!-- Back button — styled like house page back pill -->
        <% if (room) { %>
        <div style="margin-bottom: 1.5rem;">
          <a href="/rooms/<%= room.id %>"
             style="display:inline-flex; align-items:center; gap:0.4rem; background:rgba(128,0,0,0.85); color:#fff; font-size:0.85rem; font-weight:600; padding:0.5rem 1rem; border-radius:1.1rem; text-decoration:none; border:1px solid rgba(255,255,255,0.2); box-shadow:0 2px 8px rgba(0,0,0,0.15); transition:background 0.2s;"
             onmouseenter="this.style.background='rgba(128,0,0,1)'" onmouseleave="this.style.background='rgba(128,0,0,0.85)'">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="rgba(255,255,255,0.95)">
              <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
            </svg>
            ← Back to Room
          </a>
        </div>
        <% } else { %>
        <div style="margin-bottom: 1.5rem;">
          <a href="/"
             style="display:inline-flex; align-items:center; gap:0.4rem; background:rgba(128,0,0,0.85); color:#fff; font-size:0.85rem; font-weight:600; padding:0.5rem 1rem; border-radius:1.1rem; text-decoration:none; border:1px solid rgba(255,255,255,0.2); box-shadow:0 2px 8px rgba(0,0,0,0.15); transition:background 0.2s;"
             onmouseenter="this.style.background='rgba(128,0,0,1)'" onmouseleave="this.style.background='rgba(128,0,0,0.85)'">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="rgba(255,255,255,0.95)">
              <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
            </svg>
            ← Back to Home
          </a>
        </div>
        <% } %>

        <!-- ── Room Selector (shown when no room pre-selected) ── -->
        <% if (!room) { %>
        <div class="room-selector-section" id="room-selector-section">
          <h2>Submit Your Review</h2>
          <p>Select your dorm, house, and room to get started.</p>

          <div class="rs-field">
            <label for="rs-dorm-select">Dorm</label>
            <select id="rs-dorm-select">
              <option value="">Select a dorm…</option>
            </select>
          </div>
          <div class="rs-field">
            <label for="rs-house-select">House</label>
            <select id="rs-house-select" disabled>
              <option value="">Select a house…</option>
            </select>
          </div>
          <div class="rs-field">
            <label for="rs-room-input">Room Number</label>
            <div class="rs-room-wrapper">
              <input type="text" id="rs-room-input" placeholder="Type a room number…" autocomplete="off" disabled />
              <div class="rs-room-dropdown" id="rs-room-dropdown"></div>
            </div>
          </div>
          <button class="rs-go-btn" id="rs-go-btn" disabled>Continue to Review Form →</button>
        </div>
        <% } %>

        <% if (room) { %>
        <div style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center;">
          <div>
            <h1 style="margin-bottom: 0.25rem;">Submit Your Review</h1>
            <p style="color: var(--text-secondary); margin: 0; font-size: 0.95rem;">
              <%= room.dorm %> — <%= room.house %> <%= room.roomNumber %>
            </p>
          </div>
        </div>

        <% if (alreadySubmittedThisYear) { %>
          <div
            style="background: #fee2e2; color: #b91c1c; padding: 1.25rem; border-radius: 0.5rem; border: 1px solid #fecaca; margin-bottom: 2rem;">
            You have already submitted data for this room for <strong>
              <%= alreadySubmittedThisYear %>
            </strong>.<br />
            You can only submit once per academic year.
            <br /><br />
            <a href="/rooms/<%= room.id %>" style="color: #b91c1c; font-weight: 600;">&larr; Return to room details</a>
          </div>
        <% } else { %>

          <!-- V2 FORM -->
          <div class="form-container" style="max-width: 100%; margin-bottom: 2rem;">
            <form method="POST" action="/rooms/<%= room.id %>/submit" style="box-shadow: none; padding: 0;">
              <input type="hidden" name="form_version" value="v2">

              <!-- Shared fields -->
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.75rem;">
                <div>
                  <label for="academicYear-v2">Academic Year<span class="req-star">*</span></label>
                  <input type="text" id="academicYear-v2" name="academicYear" placeholder="e.g. 2024-2025" required
                    style="max-width: 200px;" />
                </div>
                <div>
                  <label for="customName-v2">Custom Room Name <span class="opt-note">(optional)</span></label>
                  <input type="text" id="customName-v2" name="customName"
                    placeholder="e.g. The Fortress of Solitude" style="max-width: 360px;" />
                </div>
              </div>

              <!-- ── SD Strip: Room Size ── -->
              <div class="form-section">
                <span class="form-sec-title">Room Size<span class="req-star">*</span></span>
                <div class="sd-strip">
                  <div class="sd-track"></div>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_room_size" value="1" required>
                    <span class="sd-label">Cramped</span>
                    <span class="sd-sublabel">(barely fits furniture)</span>
                  </label>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_room_size" value="2">
                    <span class="sd-label">Tight</span>
                    <span class="sd-sublabel">(close quarters)</span>
                  </label>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_room_size" value="3">
                    <span class="sd-label">Average</span>
                    <span class="sd-sublabel">(typical UChicago)</span>
                  </label>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_room_size" value="4">
                    <span class="sd-label">Spacious</span>
                    <span class="sd-sublabel">(noticeably open)</span>
                  </label>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_room_size" value="5">
                    <span class="sd-label">Expansive</span>
                    <span class="sd-sublabel">(unusually large)</span>
                  </label>
                </div>
              </div>

              <!-- ── SD Strip: Natural Light ── -->
              <div class="form-section">
                <span class="form-sec-title">Natural Light<span class="req-star">*</span></span>
                <div class="sd-strip">
                  <div class="sd-track"></div>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_natural_light" value="1" required>
                    <span class="sd-label">Very Dark</span>
                    <span class="sd-sublabel">(need lights midday)</span>
                  </label>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_natural_light" value="2">
                    <span class="sd-label">Dim</span>
                    <span class="sd-sublabel">(often gloomy)</span>
                  </label>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_natural_light" value="3">
                    <span class="sd-label">Moderate</span>
                    <span class="sd-sublabel">(adequate)</span>
                  </label>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_natural_light" value="4">
                    <span class="sd-label">Bright</span>
                    <span class="sd-sublabel">(well-lit naturally)</span>
                  </label>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_natural_light" value="5">
                    <span class="sd-label">Very Bright</span>
                    <span class="sd-sublabel">(exceptional)</span>
                  </label>
                </div>
              </div>

              <!-- ── SD Strip: Outside Noise ── -->
              <div class="form-section">
                <span class="form-sec-title">Outside Noise<span class="req-star">*</span></span>
                <div class="sd-strip">
                  <div class="sd-track"></div>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_outside_noise" value="1" required>
                    <span class="sd-label">Silent</span>
                    <span class="sd-sublabel">(essentially no sound)</span>
                  </label>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_outside_noise" value="2">
                    <span class="sd-label">Quiet</span>
                    <span class="sd-sublabel">(faint sounds)</span>
                  </label>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_outside_noise" value="3">
                    <span class="sd-label">Moderate</span>
                    <span class="sd-sublabel">(audible, manageable)</span>
                  </label>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_outside_noise" value="4">
                    <span class="sd-label">Noisy</span>
                    <span class="sd-sublabel">(often disruptive)</span>
                  </label>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_outside_noise" value="5">
                    <span class="sd-label">Very Noisy</span>
                    <span class="sd-sublabel">(constantly loud)</span>
                  </label>
                </div>
              </div>

              <!-- ── SD Strip: Temperature Control ── -->
              <div class="form-section">
                <span class="form-sec-title">Temperature Control<span class="req-star">*</span></span>
                <div class="sd-strip">
                  <div class="sd-track"></div>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_temp_control" value="1" required>
                    <span class="sd-label">Very Difficult</span>
                    <span class="sd-sublabel">(always uncomfortable)</span>
                  </label>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_temp_control" value="2">
                    <span class="sd-label">Difficult</span>
                    <span class="sd-sublabel">(often hot/cold)</span>
                  </label>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_temp_control" value="3">
                    <span class="sd-label">Manageable</span>
                    <span class="sd-sublabel">(usually okay)</span>
                  </label>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_temp_control" value="4">
                    <span class="sd-label">Easy</span>
                    <span class="sd-sublabel">(good control)</span>
                  </label>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_temp_control" value="5">
                    <span class="sd-label">Very Easy</span>
                    <span class="sd-sublabel">(excellent)</span>
                  </label>
                </div>
              </div>

              <!-- ── SD Strip: House Culture ── -->
              <div class="form-section">
                <span class="form-sec-title">House Culture<span class="req-star">*</span></span>
                <div class="sd-strip">
                  <div class="sd-track"></div>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_house_culture" value="1" required>
                    <span class="sd-label">Very Negative</span>
                  </label>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_house_culture" value="2">
                    <span class="sd-label">Negative</span>
                  </label>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_house_culture" value="3">
                    <span class="sd-label">Neutral</span>
                  </label>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_house_culture" value="4">
                    <span class="sd-label">Positive</span>
                  </label>
                  <label class="sd-opt">
                    <input type="radio" name="scalar_house_culture" value="5">
                    <span class="sd-label">Very Positive</span>
                  </label>
                </div>
              </div>

              <!-- ── Culture Note ── -->
              <div class="form-section">
                <label class="form-sec-title" for="culture_note">
                  In 1–5 words, what most shapes that rating?
                  <span class="opt-note">(optional — feeds the house word map)</span>
                </label>
                <input type="text" name="culture_note" id="culture_note" maxlength="60"
                  placeholder="e.g. super welcoming, lots of events"
                  style="max-width: 420px;" />
              </div>

              <!-- ── Culture Descriptor Chips ── -->
              <div class="form-section">
                <span class="form-sec-title">
                  House Culture Descriptors
                  <span class="opt-note">(optional — pick up to 3)</span>
                </span>
                <div class="culture-chips" id="culture-chips-container">
                  <input type="checkbox" class="chip-opt" id="chip-0" name="culture_tags" value="Welcoming / inclusive">
                  <label class="chip-label" for="chip-0">Welcoming / inclusive</label>

                  <input type="checkbox" class="chip-opt" id="chip-1" name="culture_tags" value="Tight-knit community">
                  <label class="chip-label" for="chip-1">Tight-knit community</label>

                  <input type="checkbox" class="chip-opt" id="chip-2" name="culture_tags" value="Quiet / studious">
                  <label class="chip-label" for="chip-2">Quiet / studious</label>

                  <input type="checkbox" class="chip-opt" id="chip-3" name="culture_tags" value="Lively / social">
                  <label class="chip-label" for="chip-3">Lively / social</label>

                  <input type="checkbox" class="chip-opt" id="chip-4" name="culture_tags" value="Party-oriented">
                  <label class="chip-label" for="chip-4">Party-oriented</label>

                  <input type="checkbox" class="chip-opt" id="chip-5" name="culture_tags" value="Friendly but independent">
                  <label class="chip-label" for="chip-5">Friendly but independent</label>

                  <input type="checkbox" class="chip-opt" id="chip-6" name="culture_tags" value="Cliquey / exclusive">
                  <label class="chip-label" for="chip-6">Cliquey / exclusive</label>

                  <input type="checkbox" class="chip-opt" id="chip-7" name="culture_tags" value="Competitive / high-pressure">
                  <label class="chip-label" for="chip-7">Competitive / high-pressure</label>

                  <input type="checkbox" class="chip-opt" id="chip-8" name="culture_tags" value="Disconnected / isolated">
                  <label class="chip-label" for="chip-8">Disconnected / isolated</label>

                  <input type="checkbox" class="chip-opt" id="chip-9" name="culture_tags" value="Diverse mix of people">
                  <label class="chip-label" for="chip-9">Diverse mix of people</label>

                  <input type="checkbox" class="chip-opt" id="chip-10" name="culture_tags" value="Active house programming">
                  <label class="chip-label" for="chip-10">Active house programming</label>

                  <input type="checkbox" class="chip-opt" id="chip-11" name="culture_tags" value="Floor rarely interacts">
                  <label class="chip-label" for="chip-11">Floor rarely interacts</label>
                </div>
              </div>

              <!-- ── House Descriptor (free-text, optional) ── -->
              <div class="form-section">
                <label class="form-sec-title" for="house_descriptor">
                  House Descriptor
                  <span class="opt-note">(optional — a few words that describe this house; feeds the house descriptor word cloud)</span>
                </label>
                <input type="text" name="house_descriptor" id="house_descriptor" maxlength="120"
                  placeholder="e.g. cozy brick, tight-knit, foodie hall"
                  style="max-width: 520px;" />
              </div>

              <!-- ── Optional Physical Tags ── -->
              <div class="form-section" id="optional-tags-section">
                <span class="form-sec-title">Optional Tags <span class="opt-note">(optional)</span></span>

                <div id="tag-conflict-banner"
                  role="alert"
                  style="display:none; margin:0.5rem 0 0.75rem; padding:0.6rem 0.85rem; background:#fee2e2; color:#b91c1c; border:1px solid #fecaca; border-radius:0.5rem; font-size:0.85rem; font-weight:500;">
                </div>

                <div class="tag-cat-title">Space &amp; Layout</div>
                <div class="v2-tag-grid">
                  <label><input type="checkbox" name="tags" value="Particularly high ceiling"> Particularly high ceiling</label>
                  <label><input type="checkbox" name="tags" value="Particularly low ceiling"> Particularly low ceiling</label>
                  <label><input type="checkbox" name="tags" value="Extra storage / closet space"> Extra storage / closet space</label>
                  <label><input type="checkbox" name="tags" value="Limited storage / closet space"> Limited storage / closet space</label>
                  <label><input type="checkbox" name="tags" value="Unusually shaped room"> Unusually shaped room</label>
                  <label><input type="checkbox" name="tags" value="Good furniture layout flexibility"> Good furniture layout flexibility</label>
                </div>

                <div class="tag-cat-title">Light &amp; Windows</div>
                <div class="v2-tag-grid">
                  <label><input type="checkbox" name="tags" value="Particularly big windows"> Particularly big windows</label>
                  <label><input type="checkbox" name="tags" value="Particularly small windows"> Particularly small windows</label>
                  <label><input type="checkbox" name="tags" value="Gets good sunlight"> Gets good sunlight</label>
                  <label><input type="checkbox" name="tags" value="Gets poor sunlight"> Gets poor sunlight</label>
                  <label><input type="checkbox" name="tags" value="Drafty windows"> Drafty windows</label>
                </div>

                <div class="tag-cat-title">Noise — Internal</div>
                <div class="v2-tag-grid">
                  <label><input type="checkbox" name="tags" value="Notable hallway noise"> Notable hallway noise</label>
                  <label><input type="checkbox" name="tags" value="Noise from adjacent rooms"> Noise from adjacent rooms</label>
                  <label><input type="checkbox" name="tags" value="Noise from above or below"> Noise from above or below</label>
                  <label><input type="checkbox" name="tags" value="Notably quiet"> Notably quiet</label>
                </div>

                <div class="tag-cat-title">Temperature &amp; Air</div>
                <div class="v2-tag-grid">
                  <label><input type="checkbox" name="tags" value="AC/heating issues"> AC/heating issues</label>
                  <label><input type="checkbox" name="tags" value="Gets very hot"> Gets very hot</label>
                  <label><input type="checkbox" name="tags" value="Gets very cold"> Gets very cold</label>
                  <label><input type="checkbox" name="tags" value="Good ventilation"> Good ventilation</label>
                  <label><input type="checkbox" name="tags" value="Poor ventilation"> Poor ventilation</label>
                  <label><input type="checkbox" name="tags" value="Significant radiator noise"> Significant radiator noise</label>
                </div>
              </div>

              <!-- ── Freetext Note ── -->
              <div class="form-section">
                <label class="form-sec-title" for="freetext_note">
                  Anything future residents should know about this room?
                  <span class="opt-note">(optional — max 280 chars)</span>
                </label>
                <textarea name="freetext_note" id="freetext_note" maxlength="280" rows="3"
                  style="max-width: 620px; resize: vertical;"
                  placeholder="e.g. radiator is loud in winter, great view of the quad..."></textarea>
              </div>

              <button type="submit">Submit Review</button>
            </form>
          </div>

          <script>
            // Culture chips: max 3
            (function() {
              var container = document.getElementById('culture-chips-container');
              if (!container) return;
              container.addEventListener('change', function(e) {
                var boxes = container.querySelectorAll('input[type="checkbox"]');
                var checked = Array.from(boxes).filter(function(b) { return b.checked; });
                if (checked.length >= 3) {
                  boxes.forEach(function(b) {
                    if (!b.checked) b.disabled = true;
                  });
                } else {
                  boxes.forEach(function(b) { b.disabled = false; });
                }
              });
            })();

            // Contradictory-tag mutual exclusion for the 4 defined pairs.
            // Matching is case-insensitive on the tag's value so slight wording
            // drift doesn't silently break the rule.
            (function() {
              var section = document.getElementById('optional-tags-section');
              var banner = document.getElementById('tag-conflict-banner');
              if (!section || !banner) return;

              var pairs = [
                ['particularly low ceiling',   'particularly high ceiling'],
                ['particularly small windows', 'particularly big windows'],
                ['poor sunlight',              'good sunlight'],
                ['poor ventilation',           'good ventilation']
              ];

              function norm(s) { return (s || '').trim().toLowerCase(); }

              function findBox(needle) {
                var boxes = section.querySelectorAll('input[type="checkbox"][name="tags"]');
                for (var i = 0; i < boxes.length; i++) {
                  if (norm(boxes[i].value).indexOf(norm(needle)) !== -1) return boxes[i];
                }
                return null;
              }

              var bannerTimer = null;
              function showBanner(msg) {
                banner.textContent = msg;
                banner.style.display = 'block';
                if (bannerTimer) clearTimeout(bannerTimer);
                bannerTimer = setTimeout(function() { banner.style.display = 'none'; }, 5000);
              }

              section.addEventListener('change', function(e) {
                var t = e.target;
                if (!t || t.type !== 'checkbox' || t.name !== 'tags' || !t.checked) return;
                var v = norm(t.value);
                for (var i = 0; i < pairs.length; i++) {
                  var a = pairs[i][0], b = pairs[i][1];
                  var other = null;
                  if (v.indexOf(a) !== -1) other = findBox(b);
                  else if (v.indexOf(b) !== -1) other = findBox(a);
                  if (other && other.checked) {
                    other.checked = false;
                    showBanner("You can't select both \"" + other.value + "\" and \"" + t.value + "\" — unchecked the opposite.");
                    return;
                  }
                }
              });
            })();
          </script>

        <% } %>

        <% } %> <%# end if (room) %>

      </main>

      <footer>
        <p>&copy; 2026 Room for Improvement</p>
      </footer>

      <!-- Room selector JS (only needed when no room pre-selected) -->
      <% if (!room) { %>
      <script>
      (function() {
        var allHouses = [];
        var allRooms = [];
        var selectedRoomId = null;
        var selectedRoomNumber = null;
        var selectedDorm = null;
        var selectedHouse = null;
        var isNewRoom = false;

        var dormSel = document.getElementById('rs-dorm-select');
        var houseSel = document.getElementById('rs-house-select');
        var roomInput = document.getElementById('rs-room-input');
        var roomDropdown = document.getElementById('rs-room-dropdown');
        var goBtn = document.getElementById('rs-go-btn');

        if (!dormSel) return;

        fetch('/api/houses')
          .then(function(r) { return r.json(); })
          .then(function(houses) {
            allHouses = houses;
            var dorms = [], seen = {};
            houses.forEach(function(h) {
              if (!seen[h.dorm]) { seen[h.dorm] = true; dorms.push(h.dorm); }
            });
            dorms.sort();
            dorms.forEach(function(d) {
              var opt = document.createElement('option');
              opt.value = d; opt.textContent = d.replace(/_/g, '-');
              dormSel.appendChild(opt);
            });
          });

        dormSel.addEventListener('change', function() {
          selectedDorm = dormSel.value;
          selectedHouse = null; selectedRoomId = null; selectedRoomNumber = null; isNewRoom = false;
          houseSel.innerHTML = '<option value="">Select a house\u2026</option>';
          houseSel.disabled = !selectedDorm;
          roomInput.value = ''; roomInput.disabled = true;
          roomDropdown.classList.remove('open');
          goBtn.disabled = true;
          if (!selectedDorm) return;
          var houses = allHouses.filter(function(h) { return h.dorm === selectedDorm; });
          houses.sort(function(a, b) { return a.house.localeCompare(b.house); });
          houses.forEach(function(h) {
            var opt = document.createElement('option');
            opt.value = h.house; opt.textContent = h.house;
            houseSel.appendChild(opt);
          });
        });

        houseSel.addEventListener('change', function() {
          selectedHouse = houseSel.value;
          selectedRoomId = null; selectedRoomNumber = null; isNewRoom = false;
          roomInput.value = ''; roomInput.disabled = !selectedHouse;
          roomDropdown.classList.remove('open');
          goBtn.disabled = true;
          allRooms = [];
          if (!selectedHouse) return;
          fetch('/api/rooms-by-house?dorm=' + encodeURIComponent(selectedDorm) + '&house=' + encodeURIComponent(selectedHouse))
            .then(function(r) { return r.json(); })
            .then(function(rooms) { allRooms = rooms; });
        });

        roomInput.addEventListener('input', function() {
          var q = roomInput.value.trim();
          selectedRoomId = null; selectedRoomNumber = null; isNewRoom = false;
          goBtn.disabled = true;
          if (!q) { roomDropdown.classList.remove('open'); return; }
          showRoomDropdown(q);
        });

        roomInput.addEventListener('focus', function() {
          var q = roomInput.value.trim();
          if (q) showRoomDropdown(q);
        });

        document.addEventListener('click', function(e) {
          if (!roomInput.contains(e.target) && !roomDropdown.contains(e.target)) {
            roomDropdown.classList.remove('open');
          }
        });

        function showRoomDropdown(q) {
          var matches = allRooms.filter(function(r) {
            return r.roomNumber.toLowerCase().includes(q.toLowerCase());
          });
          matches.sort(function(a, b) { return a.roomNumber.localeCompare(b.roomNumber, undefined, { numeric: true }); });
          roomDropdown.innerHTML = '';
          matches.slice(0, 12).forEach(function(r) {
            var item = document.createElement('div');
            item.className = 'rs-room-item';
            item.innerHTML = '<span class="rs-room-num">' + esc(r.roomNumber) + '</span>'
              + '<span class="rs-room-meta">' + esc(r.roomType || '') + (r.floor ? ' \u00b7 Floor ' + esc(r.floor) : '') + '</span>';
            item.addEventListener('mousedown', function(e) { e.preventDefault(); selectRoom(r); });
            roomDropdown.appendChild(item);
          });
          var exactMatch = allRooms.find(function(r) { return r.roomNumber.toLowerCase() === q.toLowerCase(); });
          if (!exactMatch) {
            var addItem = document.createElement('div');
            addItem.className = 'rs-room-item rs-add-new';
            addItem.innerHTML = '+ Add "' + esc(q) + '" as a new room';
            addItem.addEventListener('mousedown', function(e) { e.preventDefault(); selectNewRoom(q); });
            roomDropdown.appendChild(addItem);
          }
          roomDropdown.classList.toggle('open', roomDropdown.children.length > 0);
        }

        function selectRoom(r) {
          selectedRoomId = r.id; selectedRoomNumber = r.roomNumber; isNewRoom = false;
          roomInput.value = r.roomNumber;
          roomDropdown.classList.remove('open');
          goBtn.disabled = false;
        }

        function selectNewRoom(roomNumber) {
          selectedRoomId = null; selectedRoomNumber = roomNumber; isNewRoom = true;
          roomInput.value = roomNumber;
          roomDropdown.classList.remove('open');
          goBtn.disabled = false;
        }

        goBtn.addEventListener('click', function() {
          if (!selectedDorm || !selectedHouse || !selectedRoomNumber) return;
          if (isNewRoom) {
            fetch('/api/add-room', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ dorm: selectedDorm, house: selectedHouse, roomNumber: selectedRoomNumber })
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
              if (data.id) window.location.href = '/rooms/' + encodeURIComponent(data.id) + '/review';
              else alert('Error creating room. Please try again.');
            })
            .catch(function() { alert('Error creating room. Please try again.'); });
          } else {
            window.location.href = '/rooms/' + encodeURIComponent(selectedRoomId) + '/review';
          }
        });

        function esc(s) {
          return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }
      })();
      </script>
      <% } %>
  </body>

  </html>
