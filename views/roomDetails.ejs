<%- include('partials/head', { title: 'Room Details | Room for Improvement' }) %>

  <body>
    <%- include('partials/nav') %>

      <main>
        <div style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center;">
          <h1>
            <%= room.dorm %> - <%= room.house %>
                <%= room.roomNumber %>
          </h1>
          <a href="/rooms" style="font-weight: 500;">&larr; Back to All Rooms</a>
        </div>

        <!-- Current (Latest) Data -->
        <div class="stat-card" style="margin-bottom: 2rem;">
          <h2 style="margin-top: 0; border: none;">Latest Submission</h2>
          <% if (latestEntry) { %>
            <p style="color: var(--text-secondary); margin-bottom: 1rem;">
              <strong>Academic Year:</strong>
              <%= latestEntry.academicYear %>
            </p>

            <div style="margin-bottom: 1.5rem;">
              <h4 style="margin-bottom: 0.5rem;">Tags</h4>
              <% if (latestEntry.tags && latestEntry.tags.length> 0) { %>
                <% latestEntry.tags.forEach(tag=> { %>
                  <span class="tag">
                    <%= tag %>
                  </span>
                  <% }) %>
                    <% } else { %>
                      <span style="color: var(--text-secondary); font-style: italic;">None selected</span>
                      <% } %>
            </div>

            <div style="background: #f9f9f9; padding: 1rem; border-radius: 0.5rem;">
              <h4 style="margin-top: 0;">Ratings (1-5)</h4>
              <ul class="stat-list">
                <li>
                  <span>House Culture</span>
                  <strong>
                    <%= latestEntry.scalars["my house has a good culture"] %>/5
                  </strong>
                </li>
                <li>
                  <span>Outside Noise</span>
                  <strong>
                    <%= latestEntry.scalars["my room gets a lot of outside noise"] %>/5
                  </strong>
                </li>
              </ul>
            </div>
            <% } else { %>
              <p><em>No prior submissions for this room.</em></p>
              <% } %>
        </div>

        <!-- Submission Form -->
        <div class="form-container" style="max-width: 100%; margin-bottom: 2rem;">
          <h2 style="border: none; margin-top: 0;">Submit Your Data</h2>
          <% if (alreadySubmittedThisYear) { %>
            <div
              style="background: #fee2e2; color: #b91c1c; padding: 1rem; border-radius: 0.5rem; border: 1px solid #fecaca;">
              You have already submitted data for this room for <strong>
                <%= alreadySubmittedThisYear %>
              </strong>.<br />
              You can only submit once per academic year.
            </div>
            <% } else { %>
              <form method="POST" action="/rooms/<%= room.id %>/submit" style="box-shadow: none; padding: 0;">
                <div style="margin-bottom: 1.5rem;">
                  <label for="academicYear">Academic Year:</label>
                  <input type="text" name="academicYear" placeholder="e.g. 2023-2024" required
                    style="max-width: 200px;" />
                </div>

                <div style="margin-bottom: 1.5rem;">
                  <label for="customName">Custom Room Name (Optional):</label>
                  <input type="text" name="customName" placeholder="e.g. The Fortress of Solitude"
                    style="max-width: 400px;" />
                  <p style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.5rem;">
                    Give this room a custom nickname that will appear on the main list.
                  </p>
                </div>

                <div style="margin-bottom: 1.5rem;">
                  <label style="margin-bottom: 1rem;">Optional Tags:</label>
                  <div
                    style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 0.5rem;">
                    <label style="font-weight: normal;"><input type="checkbox" name="tags"
                        value="particularly high ceiling" /> High ceiling</label>
                    <label style="font-weight: normal;"><input type="checkbox" name="tags"
                        value="particularly low ceiling" /> Low ceiling</label>
                    <label style="font-weight: normal;"><input type="checkbox" name="tags"
                        value="particularly big windows" /> Big windows</label>
                    <label style="font-weight: normal;"><input type="checkbox" name="tags"
                        value="particularly small windows" /> Small windows</label>
                    <label style="font-weight: normal;"><input type="checkbox" name="tags"
                        value="issues with ac/heating temperature control" /> AC/Heating issues</label>
                    <label style="font-weight: normal;"><input type="checkbox" name="tags" value="drafty windows" />
                      Drafty windows</label>
                    <label style="font-weight: normal;"><input type="checkbox" name="tags"
                        value="tends to receive good sunlight when sunny" /> Good sunlight</label>
                    <label style="font-weight: normal;"><input type="checkbox" name="tags"
                        value="doesnt tend to receive good sunlight when sunny" /> Poor sunlight</label>
                  </div>
                </div>

                <div style="margin-bottom: 1.5rem;">
                  <label style="margin-bottom: 1rem;">Ratings (1-5, 3=Neutral):</label>
                  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div>
                      <label style="font-size: 0.9rem;">Good House Culture</label>
                      <select name="scalar_house_culture" required>
                        <option value="1">1 (Strongly Disagree)</option>
                        <option value="2">2 (Somewhat Disagree)</option>
                        <option value="3" selected>3 (Neither)</option>
                        <option value="4">4 (Somewhat Agree)</option>
                        <option value="5">5 (Strongly Agree)</option>
                      </select>
                    </div>
                    <div>
                      <label style="font-size: 0.9rem;">Lot of Outside Noise</label>
                      <select name="scalar_outside_noise" required>
                        <option value="1">1 (Strongly Disagree)</option>
                        <option value="2">2 (Somewhat Disagree)</option>
                        <option value="3" selected>3 (Neither)</option>
                        <option value="4">4 (Somewhat Agree)</option>
                        <option value="5">5 (Strongly Agree)</option>
                      </select>
                    </div>
                  </div>
                </div>

                <button type="submit">Submit Review</button>
              </form>
              <% } %>
        </div>

        <!-- Historical Data -->
        <div class="wrapper">
          <h3 style="border-bottom: 2px solid var(--border-color); padding-bottom: 0.5rem;">Historical Data</h3>
          <% if (allEntries && allEntries.length> 0) { %>
            <p>Below are all previous submissions for this room (oldest first):</p>
            <div style="margin-top: 1rem;">
              <%- include('partials/roomHistory') %>
            </div>
            <% } else { %>
              <p class="text-secondary">No data available yet. Be the first to add some!</p>
              <% } %>
        </div>

      </main>

      <footer>
        <p>&copy; 2025 Room for Improvement</p>
      </footer>
  </body>

  </html>