<%- include('partials/head', { title: 'Room Details | Room for Improvement' }) %>

  <body>
    <%- include('partials/nav') %>
    <style>
      /* Red asterisk for required fields */
      .req-star { color: #dc2626; font-weight: 700; margin-left: 0.15rem; }
      .opt-note { font-weight: normal; color: var(--text-secondary); font-size: 0.82rem; margin-left: 0.25rem; }

      /* Submit review CTA button */
      .review-cta-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        background: #800000;
        color: #fff;
        padding: 0.7rem 1.4rem;
        border-radius: 0.5rem;
        font-weight: 700;
        font-size: 1rem;
        text-decoration: none;
        box-shadow: 0 3px 12px rgba(128,0,0,0.28);
        transition: background 0.15s, transform 0.15s, box-shadow 0.15s;
      }
      .review-cta-btn:hover {
        background: #660000;
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(128,0,0,0.38);
        color: #fff;
        text-decoration: none;
      }
      .review-cta-btn svg {
        flex-shrink: 0;
      }

      /* Highlight animation for the latest submission after form submit */
      @keyframes reviewHighlight {
        0%   { background: #fef9c3; box-shadow: 0 0 0 3px #fbbf24; }
        60%  { background: #fef9c3; box-shadow: 0 0 0 3px #fbbf24; }
        100% { background: transparent; box-shadow: none; }
      }
      .review-just-submitted {
        animation: reviewHighlight 2.5s ease forwards;
        border-radius: 0.5rem;
        transition: background 0.4s, box-shadow 0.4s;
      }

      /* Big red moving gradient effect for custom room name */
      .custom-room-name {
        font-size: 3.2rem;
        font-weight: 900;
        text-transform: uppercase;
        background: linear-gradient(270deg, #d30000, #ff5555, #660000, #d30000);
        background-size: 300% 300%;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: fireGradient 5s ease infinite;
        filter: drop-shadow(0px 3px 6px rgba(180, 0, 0, 0.4));
        margin-bottom: 0.2rem;
        margin-top: 0;
        letter-spacing: 1px;
        line-height: 1.15;
        overflow-wrap: break-word;
        word-wrap: break-word;
      }
      
      @keyframes fireGradient {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
      }
    </style>

      <main>
        <div style="margin-bottom: 1rem;">
          <a href="/house/<%= encodeURIComponent(room.dorm) %>/<%= encodeURIComponent(room.house) %>" style="display:inline-flex; align-items:center; gap:0.45rem; font-weight:600; font-size:0.9rem; color:#800000; text-decoration:none; padding:0.45rem 0.9rem; background:rgba(128,0,0,0.07); border:1px solid rgba(128,0,0,0.18); border-radius:2rem; transition:background 0.15s, box-shadow 0.15s;" onmouseover="this.style.background='rgba(128,0,0,0.14)'" onmouseout="this.style.background='rgba(128,0,0,0.07)'">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#800000"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
            View all <%= room.house %> rooms
          </a>
        </div>
        <div style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center;">
          <% 
            let displayCustomName = null;
            if (allEntries && allEntries.length > 0) {
              for (let i = allEntries.length - 1; i >= 0; i--) {
                if (allEntries[i].customName) {
                  displayCustomName = allEntries[i].customName;
                  break;
                }
              }
            }
          %>
          <div style="flex: 1; min-width: 0; padding-right: 1rem;">
            <% if (displayCustomName) { %>
              <h1 class="custom-room-name"><%= displayCustomName %></h1>
              <h2 style="font-weight: normal; margin-top: 0; color: var(--text-secondary); font-size: 1.25rem; margin-bottom: 0;">
                (<em><%= room.dorm %> - <%= room.house %> <%= room.roomNumber %></em>)
              </h2>
            <% } else { %>
              <h1 style="margin: 0;">
                <%= room.dorm %> - <%= room.house %> <%= room.roomNumber %>
              </h1>
            <% } %>
          </div>
        </div>

        <!-- Current (Latest) Data -->
        <div class="stat-card" id="latest-submission-card" style="margin-bottom: 2rem;">
          <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem;">
            <h2 style="margin-top: 0; border: none;">Latest Submission</h2>
            <!-- Submit Review CTA -->
            <% if (!alreadySubmittedThisYear) { %>
              <a href="/rooms/<%= room.id %>/review" class="review-cta-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zm17.71-10.21a.996.996 0 0 0 0-1.41l-2.34-2.34a.996.996 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                </svg>
                Submit Your Data &rarr;
              </a>
            <% } else { %>
              <div style="background: #fee2e2; color: #b91c1c; padding: 0.6rem 1rem; border-radius: 0.5rem; border: 1px solid #fecaca; font-size: 0.9rem;">
                Already submitted for <strong><%= alreadySubmittedThisYear %></strong>
              </div>
            <% } %>
          </div>

          <% if (latestEntry) { %>
            <p style="color: var(--text-secondary); margin-bottom: 1rem;">
              <strong>Academic Year:</strong>
              <%= latestEntry.academicYear %>
            </p>

            <%
              const roomSzLabels   = ["","Cramped","Tight","Average","Spacious","Expansive"];
              const lightLabels    = ["","Very Dark","Dim","Moderate","Bright","Very Bright"];
              const noiseLabels    = ["","Silent","Quiet","Moderate","Noisy","Very Noisy"];
              const tempLabels     = ["","Very Difficult","Difficult","Manageable","Easy","Very Easy"];
              const cultureLabels  = ["","Very Negative","Negative","Neutral","Positive","Very Positive"];
            %>
            <div style="background: #f9f9f9; padding: 1rem; border-radius: 0.5rem; margin-bottom: 1rem;">
              <h4 style="margin-top: 0;">Ratings (1–5)</h4>
              <ul class="stat-list">
                <% if (latestEntry.scalars && latestEntry.scalars["room size"]) { %>
                <li><span>Room Size</span>
                  <strong><%= roomSzLabels[latestEntry.scalars["room size"]] || latestEntry.scalars["room size"] %> (<%= latestEntry.scalars["room size"] %>/5)</strong>
                </li>
                <% } %>
                <% if (latestEntry.scalars && latestEntry.scalars["natural light"]) { %>
                <li><span>Natural Light</span>
                  <strong><%= lightLabels[latestEntry.scalars["natural light"]] || latestEntry.scalars["natural light"] %> (<%= latestEntry.scalars["natural light"] %>/5)</strong>
                </li>
                <% } %>
                <% if (latestEntry.scalars && latestEntry.scalars["my room gets a lot of outside noise"]) { %>
                <li><span>Outside Noise</span>
                  <strong><%= noiseLabels[latestEntry.scalars["my room gets a lot of outside noise"]] || latestEntry.scalars["my room gets a lot of outside noise"] %> (<%= latestEntry.scalars["my room gets a lot of outside noise"] %>/5)</strong>
                </li>
                <% } %>
                <% if (latestEntry.scalars && latestEntry.scalars["temperature control"]) { %>
                <li><span>Temperature Control</span>
                  <strong><%= tempLabels[latestEntry.scalars["temperature control"]] || latestEntry.scalars["temperature control"] %> (<%= latestEntry.scalars["temperature control"] %>/5)</strong>
                </li>
                <% } %>
                <% if (latestEntry.scalars && latestEntry.scalars["my house has a good culture"]) { %>
                <li><span>House Culture</span>
                  <strong><%= cultureLabels[latestEntry.scalars["my house has a good culture"]] || latestEntry.scalars["my house has a good culture"] %> (<%= latestEntry.scalars["my house has a good culture"] %>/5)</strong>
                </li>
                <% } %>
              </ul>
            </div>

            <% if (latestEntry.cultureTags && latestEntry.cultureTags.length > 0) { %>
            <div style="margin-bottom: 1rem;">
              <h4 style="margin-bottom: 0.5rem;">House Culture Descriptors</h4>
              <div style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
                <% latestEntry.cultureTags.forEach(ct => { %>
                  <span class="tag"><%= ct %></span>
                <% }) %>
              </div>
            </div>
            <% } %>

            <% if (latestEntry.scalars && latestEntry.scalars["culture note"]) { %>
            <p style="margin-bottom: 0.75rem; font-size: 0.9rem;">
              <strong>Culture note:</strong> <em>"<%= latestEntry.scalars["culture note"] %>"</em>
            </p>
            <% } %>

            <% if (latestEntry.scalars && latestEntry.scalars["house descriptor"]) { %>
            <p style="margin-bottom: 0.75rem; font-size: 0.9rem;">
              <strong>House Descriptor:</strong> <em><%= latestEntry.scalars["house descriptor"] %></em>
            </p>
            <% } %>

            <% if (latestEntry.scalars && latestEntry.scalars["freetext note"]) { %>
            <div style="background: #fffbeb; border: 1px solid #fde68a; border-radius: 0.4rem; padding: 0.75rem; margin-bottom: 1rem; font-size: 0.9rem;">
              <strong>Room note:</strong> <%= latestEntry.scalars["freetext note"] %>
            </div>
            <% } %>

            <div style="margin-bottom: 0.5rem;">
              <h4 style="margin-bottom: 0.5rem;">Physical Tags</h4>
              <% if (latestEntry.tags && latestEntry.tags.length > 0) { %>
                <% latestEntry.tags.forEach(tag => { %>
                  <span class="tag"><%= tag %></span>
                <% }) %>
              <% } else { %>
                <span style="color: var(--text-secondary); font-style: italic;">None selected</span>
              <% } %>
            </div>

          <% } else { %>
            <p><em>No prior submissions for this room.</em></p>
          <% } %>
        </div>

        <!-- Historical Data -->
        <div class="wrapper">
          <h3 style="border-bottom: 2px solid var(--border-color); padding-bottom: 0.5rem;">Historical Data</h3>
          <% if (allEntries && allEntries.length > 0) { %>
            <p>Below are all previous submissions for this room (oldest first):</p>
            <div style="margin-top: 1rem;">
              <%- include('partials/roomHistory') %>
            </div>
          <% } else { %>
            <p class="text-secondary">No data available yet. Be the first to add some!</p>
          <% } %>
        </div>

      </main>

      <footer>
        <p>&copy; 2025 Room for Improvement</p>
      </footer>

      <!-- Highlight card if redirected after form submit -->
      <script>
        (function() {
          var params = new URLSearchParams(window.location.search);
          if (params.get('submitted') === '1') {
            var card = document.getElementById('latest-submission-card');
            if (card) {
              card.classList.add('review-just-submitted');
              // scroll into view
              card.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
            // Clean URL without refresh
            var newUrl = window.location.pathname;
            history.replaceState({}, '', newUrl);
          }
        })();
      </script>
  </body>

  </html>
