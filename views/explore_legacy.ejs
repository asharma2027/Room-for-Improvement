                            <text x="407" y="430" text-anchor="middle" fill="white" font-size="13" font-weight="700">I-House</text>
                            <text x="407" y="447" text-anchor="middle" fill="rgba(255,255,255,0.8)" font-size="10">5 Houses</text>
                            <text x="407" y="463" text-anchor="middle" fill="rgba(255,255,255,0.65)" font-size="9">Click to explore →</text>
                        </g>

                        <!-- Max Palevsky -->
                        <g class="dorm-group" onclick="window.location='/dorm/Max Palevsky'" style="cursor:pointer;">
                            <rect x="580" y="215" width="155" height="130" rx="6" fill="#1a5a1a" stroke="#0d3b0d" stroke-width="2" class="dorm-shape" data-dorm="Max Palevsky" opacity="0.85" />
                            <text x="657" y="268" text-anchor="middle" fill="white" font-size="13" font-weight="700">Max Palevsky</text>
                            <text x="657" y="285" text-anchor="middle" fill="rgba(255,255,255,0.8)" font-size="10">9 Houses</text>
                            <text x="657" y="301" text-anchor="middle" fill="rgba(255,255,255,0.65)" font-size="9">Click to explore →</text>
                        </g>

                        <!-- Renee GRC -->
                        <g class="dorm-group" onclick="window.location='/dorm/Renee_Granville-Grossman'" style="cursor:pointer;">
                            <rect x="555" y="80" width="160" height="100" rx="6" fill="#7a4a00" stroke="#4d2d00" stroke-width="2" class="dorm-shape" data-dorm="Renee_Granville-Grossman" opacity="0.85" />
                            <text x="635" y="120" text-anchor="middle" fill="white" font-size="11" font-weight="700">Renee</text>
                            <text x="635" y="135" text-anchor="middle" fill="white" font-size="11" font-weight="700">Granville-Grossman</text>
                            <text x="635" y="152" text-anchor="middle" fill="rgba(255,255,255,0.8)" font-size="10">7 Houses</text>
