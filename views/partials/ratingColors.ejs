<script>
  function ratingColor(val) {
    var colors = { 5: '#34877A', 4: '#92B89D', 3: '#D69772', 2: '#C27654', 1: '#AE5436' };
    return colors[Math.round(val)] || 'transparent';
  }
  function ratingTextColor(val) {
    return '#fff';
  }
  function noiseColor(val) {
    var colors = { 1: '#34877A', 2: '#92B89D', 3: '#D69772', 4: '#C27654', 5: '#AE5436' };
    return colors[Math.round(val)] || 'transparent';
  }
  function noiseTextColor(val) {
    return '#fff';
  }
</script>
