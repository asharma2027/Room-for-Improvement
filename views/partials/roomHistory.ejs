<!-- This partial is included in roomDetails.ejs for displaying historical data. -->

<%
  function ratingColor(val) {
    const colors = { 5: '#34877A', 4: '#92B89D', 3: '#D69772', 2: '#C27654', 1: '#AE5436' };
    return colors[Math.round(val)] || 'transparent';
  }
  function ratingTextColor(val) {
    return '#fff';
  }
%>

<div style="overflow-x: auto;">
<table>
  <thead>
    <tr>
      <th>Academic Year</th>
      <th>Submitted By</th>
      <th>Date</th>
      <th>Room Name</th>
      <th>Tags</th>
      <th>House Culture (1-5)</th>
      <th>Outside Noise (1-5)</th>
      <th>Room Size</th>
      <th>Natural Light</th>
      <th>Temp Control</th>
      <th>House Descriptor</th>
    </tr>
  </thead>
  <tbody>
    <% allEntries.forEach(entry => { %>
      <% const entryIsV2 = entry.scalars && entry.scalars["form version"] === "v2"; %>
      <tr>
        <td>
          <%= entry.academicYear %>
          <% if (entryIsV2) { %><span class="badge-v2">v2</span><% } %>
        </td>
        <td>
          <%= entry.userEmail %>
        </td>
        <td>
          <%= new Date(entry.timestamp).toLocaleString() %>
        </td>
        <td>
          <% if (entry.customName) { %>
            <strong><%= entry.customName %></strong>
          <% } else { %>
            <em style="color: var(--text-secondary);">Not set</em>
          <% } %>
        </td>
        <td>
          <% if (entry.tags && entry.tags.length > 0) { %>
            <%= entry.tags.join(', ') %>
          <% } else { %>
            <em>None</em>
          <% } %>
        </td>
        <td>
          <% const hcHistVal = entry.scalars["my house has a good culture"]; %>
          <% if (hcHistVal) { %>
            <span style="display:inline-block; padding:0.15rem 0.5rem; border-radius:0.3rem; background-color:<%= ratingColor(hcHistVal) %>; color:<%= ratingTextColor(hcHistVal) %>; font-weight:600;"><%= hcHistVal %></span>
          <% } else { %>
            <em style="color:var(--text-secondary);">—</em>
          <% } %>
        </td>
        <td>
          <% const onHistVal = entry.scalars["my room gets a lot of outside noise"]; %>
          <% if (onHistVal) { %>
            <span style="display:inline-block; padding:0.15rem 0.5rem; border-radius:0.3rem; background-color:<%= ratingColor(onHistVal) %>; color:<%= ratingTextColor(onHistVal) %>; font-weight:600;"><%= onHistVal %></span>
          <% } else { %>
            <em style="color:var(--text-secondary);">—</em>
          <% } %>
        </td>
        <td>
          <% if (entryIsV2 && entry.scalars["room size"]) { %>
            <% const rsHistVal = entry.scalars["room size"]; %>
            <span style="display:inline-block; padding:0.15rem 0.5rem; border-radius:0.3rem; background-color:<%= ratingColor(rsHistVal) %>; color:<%= ratingTextColor(rsHistVal) %>; font-weight:600;"><%= rsHistVal %></span>
          <% } else { %>
            <em style="color:var(--text-secondary);">—</em>
          <% } %>
        </td>
        <td>
          <% if (entryIsV2 && entry.scalars["natural light"]) { %>
            <% const nlHistVal = entry.scalars["natural light"]; %>
            <span style="display:inline-block; padding:0.15rem 0.5rem; border-radius:0.3rem; background-color:<%= ratingColor(nlHistVal) %>; color:<%= ratingTextColor(nlHistVal) %>; font-weight:600;"><%= nlHistVal %></span>
          <% } else { %>
            <em style="color:var(--text-secondary);">—</em>
          <% } %>
        </td>
        <td>
          <% if (entryIsV2 && entry.scalars["temperature control"]) { %>
            <% const tcHistVal = entry.scalars["temperature control"]; %>
            <span style="display:inline-block; padding:0.15rem 0.5rem; border-radius:0.3rem; background-color:<%= ratingColor(tcHistVal) %>; color:<%= ratingTextColor(tcHistVal) %>; font-weight:600;"><%= tcHistVal %></span>
          <% } else { %>
            <em style="color:var(--text-secondary);">—</em>
          <% } %>
        </td>
        <td>
          <% if (entry.scalars && entry.scalars["house descriptor"]) { %>
            <%= entry.scalars["house descriptor"] %>
          <% } else { %>
            <em style="color:var(--text-secondary);">—</em>
          <% } %>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>
</div>
