<%- include('partials/head', { title: dormName + ' Rankings | Room for Improvement' }) %>

    <body>
        <%- include('partials/nav') %>
        <style>
            .rank-row-inner {
                flex: 1;
                min-width: 0;
            }
            .rank-row-heading {
                display: block;
                margin-bottom: 0.35rem;
            }
            .rank-house-name {
                min-width: 0;
                font-weight: 800;
                font-size: 0.98rem;
                line-height: 1.18;
                color: var(--text-primary);
                white-space: normal;
                overflow: visible;
                text-overflow: clip;
                overflow-wrap: normal;
                word-break: normal;
            }
            .rank-review-count {
                display: inline;
                margin-left: 0.18rem;
                font-style: italic;
                font-weight: 600;
                color: var(--text-secondary);
                font-size: 0.86rem;
                line-height: 1.15;
                white-space: nowrap;
            }
            .rank-score-meta {
                display: grid;
                grid-template-columns: minmax(0, 1fr) 3.25rem;
                gap: 0.45rem;
                align-items: start;
                margin-top: 0.22rem;
                color: var(--text-secondary);
                font-size: 0.9rem;
                font-weight: 800;
                line-height: 1.12;
                text-align: right;
            }
            .rank-score-word {
                min-width: 0;
                white-space: normal;
                overflow-wrap: normal;
                word-break: normal;
                text-align: left;
            }
            .rank-score-value {
                color: var(--text-primary);
                font-size: 0.94rem;
                font-variant-numeric: tabular-nums;
                white-space: nowrap;
            }
        </style>

            <main style="max-width:1300px; margin:0 auto; padding:2rem 1.5rem;">

                <!-- Header -->
                <div style="display:flex; align-items:center; gap:1rem; margin-bottom:1.5rem;">
                    <a href="/explore"
                        style="display:inline-flex; align-items:center; gap:0.4rem; background:rgba(128,0,0,0.85); color:#fff; font-size:0.85rem; font-weight:600; padding:0.5rem 1rem; border-radius:1.1rem; text-decoration:none; border:1px solid rgba(255,255,255,0.2); box-shadow:0 2px 8px rgba(0,0,0,0.15); transition:background 0.2s;"
                        onmouseenter="this.style.background='rgba(128,0,0,1)'" onmouseleave="this.style.background='rgba(128,0,0,0.85)'">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="rgba(255,255,255,0.95)">
                            <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
                        </svg>
                        Explore Campus
                    </a>
                    <span style="color:var(--border-color);">|</span>
                    <h1 style="margin:0; font-size:1.75rem;">
                        <%= dormName.replace(/_/g, '-' ) %> — House Rankings
                    </h1>
                </div>

                <!-- Emblem Strip -->
                <div
                    style="background:#fff; border-radius:1rem; box-shadow:var(--shadow-md); padding:1.25rem 1.5rem; margin-bottom:1.75rem;">
                    <p
                        style="margin:0 0 1rem; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.08em; color:var(--text-secondary); font-weight:600;">
                        Hover an emblem to highlight in rankings · Right-click to lock the highlight · Click to visit that house's page
                    </p>
                    <div id="emblem-strip" style="display:flex; flex-wrap:wrap; gap:1rem; align-items:flex-start;">
                        <% rankings.forEach((h, i)=> { %>
                            <div class="emblem"
                                data-house="<%= i %>"
                                onmouseenter="hoverHouse(<%= i %>, true)"
                                onmouseleave="hoverHouse(<%= i %>, false)"
                                onclick="window.location='/house/<%= encodeURIComponent(dormName) %>/<%= encodeURIComponent(h.name) %>'"
                                title="<%= h.name %>"
                                style="display:flex; flex-direction:column; align-items:center; gap:0.35rem; cursor:pointer; transition:transform 0.2s;">
                                <div class="emblem-circle" id="emblem-<%= i %>" style="width:72px; height:72px; border-radius:50%; background:<%= h.color %>; <%= h.emblem ? `background-image:url('${h.emblem}'); background-size:cover; background-position:center; background-color:#fff;` : '' %>
                        display:flex; align-items:center; justify-content:center;
                        box-shadow: 0 3px 10px rgba(0,0,0,0.18);
                        border: 3px solid transparent; transition: all 0.25s; position:relative; overflow:hidden;">
                                    <% if (!h.emblem) { %>
                                        <span
                                            style="color:white; font-weight:800; font-size:1.1rem; letter-spacing:0.02em;">
                                            <%= h.initials %>
                                        </span>
                                        <% } %>
                                </div>
                                <span
                                    style="font-size:0.7rem; font-weight:600; color:var(--text-secondary); text-align:center; max-width:80px; min-height:2.4em; line-height:1.2;">
                                    <%= h.name %>
                                </span>
                            </div>
                            <% }) %>
                    </div>
                </div>

                <!-- Rankings Board -->
                <div id="rankings-board"
                    style="display:grid; grid-template-columns: repeat(5, minmax(220px, 1fr)); gap:1rem; align-items:start;">

                <%
                // Panel titles/keys aligned with the v2 room review form field labels
                // Order: House Culture, Room Size, Outside Noise (quietness), Temp Control, Natural Light
                const categories = [
                    { key: 'culture',     icon: '🏆',  label: 'House Culture',
                      note: 'Rated 1–5: 1 = Very Negative, 5 = Very Positive. Higher scores mean residents rate the house culture more positively.',
                      likert: [
                        { value: 1, label: 'Very Negative', sublabel: '' },
                        { value: 2, label: 'Negative',      sublabel: '' },
                        { value: 3, label: 'Neutral',       sublabel: '' },
                        { value: 4, label: 'Positive',      sublabel: '' },
                        { value: 5, label: 'Very Positive', sublabel: '' },
                      ],
                      textLabel: (v) => {
                        if (v >= 4.5) return 'Very Positive';
                        if (v >= 3.5) return 'Positive';
                        if (v >= 2.5) return 'Neutral';
                        if (v >= 1.5) return 'Negative';
                        return 'Very Negative';
                      }
                    },
                    { key: 'roomSize',    icon: '📦',  label: 'Room Size',
                      note: 'Rated 1–5: 1 = Cramped, 5 = Expansive. Higher scores mean rooms are larger on average.',
                      likert: [
                        { value: 1, label: 'Cramped',   sublabel: '(very tight)' },
                        { value: 2, label: 'Tight',     sublabel: '(below average)' },
                        { value: 3, label: 'Average',   sublabel: '(typical UChicago)' },
                        { value: 4, label: 'Spacious',  sublabel: '(noticeably open)' },
                        { value: 5, label: 'Expansive', sublabel: '(unusually large)' },
                      ],
                      textLabel: (v) => {
                        if (v >= 4.5) return 'Expansive';
                        if (v >= 3.5) return 'Spacious';
                        if (v >= 2.5) return 'Average';
                        if (v >= 1.5) return 'Tight';
                        return 'Cramped';
                      }
                    },
                    { key: 'quietness',   icon: '🔇',  label: 'Noise Level',
                      note: 'Rated 1–5: 1 = Very Noisy, 5 = Silent. Higher scores mean less outside noise.',
                      likert: [
                        { value: 1, label: 'Silent',     sublabel: '(essentially no sound)' },
                        { value: 2, label: 'Quiet',      sublabel: '(faint sounds)' },
                        { value: 3, label: 'Moderate',   sublabel: '(audible, manageable)' },
                        { value: 4, label: 'Noisy',      sublabel: '(often disruptive)' },
                        { value: 5, label: 'Very Noisy', sublabel: '(constantly loud)' },
                      ],
                      textLabel: (v) => {
                        if (v >= 4.5) return 'Silent';
                        if (v >= 3.5) return 'Quiet';
                        if (v >= 2.5) return 'Moderate';
                        if (v >= 1.5) return 'Noisy';
                        return 'Very Noisy';
                      }
                    },
                    { key: 'tempControl', icon: '🌡️', label: 'Temp Control',
                      note: 'Rated 1–5: 1 = Very Difficult, 5 = Very Easy. Higher scores mean temperature is easier to manage.',
                      likert: [
                        { value: 1, label: 'Very Difficult', sublabel: '(always uncomfortable)' },
                        { value: 2, label: 'Difficult',      sublabel: '(often hot/cold)' },
                        { value: 3, label: 'Manageable',     sublabel: '(usually okay)' },
                        { value: 4, label: 'Easy',           sublabel: '(good control)' },
                        { value: 5, label: 'Very Easy',      sublabel: '(excellent)' },
                      ],
                      textLabel: (v) => {
                        if (v >= 4.5) return 'Very Easy';
                        if (v >= 3.5) return 'Easy';
                        if (v >= 2.5) return 'Manageable';
                        if (v >= 1.5) return 'Difficult';
                        return 'Very Difficult';
                      }
                    },
                    { key: 'sunlight',    icon: '☀️', label: 'Natural Light',
                      note: 'Rated 1–5: 1 = Very Dark, 5 = Very Bright. Higher scores mean rooms get more natural light.',
                      likert: [
                        { value: 1, label: 'Very Dark',   sublabel: '(need lights midday)' },
                        { value: 2, label: 'Dim',         sublabel: '(often gloomy)' },
                        { value: 3, label: 'Moderate',    sublabel: '(adequate)' },
                        { value: 4, label: 'Bright',      sublabel: '(well-lit naturally)' },
                        { value: 5, label: 'Very Bright', sublabel: '(exceptional)' },
                      ],
                      textLabel: (v) => {
                        if (v >= 4.5) return 'Very Bright';
                        if (v >= 3.5) return 'Bright';
                        if (v >= 2.5) return 'Moderate';
                        if (v >= 1.5) return 'Dim';
                        return 'Very Dark';
                      }
                    },
                ];
                %>

                        <% categories.forEach((cat, catIdx)=> { %>
                            <div class="ranking-column-wrapper">
                                <!-- Column header -->
                                <div
                                    style="text-align:center; padding:0.85rem 0.5rem 0.65rem; background:#fff; border-radius:0.75rem 0.75rem 0 0; border-bottom:2px solid var(--border-color); box-shadow:var(--shadow-sm);">
                                    <div style="font-size:2rem; line-height:1; margin-bottom:0.3rem;">
                                        <%= cat.icon %>
                                    </div>
                                    <div style="font-weight:700; font-size:0.9rem; color:var(--text-primary);">
                                        <%= cat.label %>
                                    </div>
                                    <!-- Likert scale: show only bubbles 1, 3, 5 with a dashed arrow line behind them -->
                                    <div style="position:relative; display:flex; justify-content:space-between; align-items:flex-start; margin-top:0.55rem; padding:0 0.15rem;">
                                        <!-- Dashed line with arrowhead spanning the full width behind the bubbles -->
                                        <div style="position:absolute; top:11px; left:11px; right:11px; height:0; border-top:2px dashed #ccc; z-index:0;"></div>
                                        <!-- Left arrowhead -->
                                        <div style="position:absolute; top:5px; left:5px; width:0; height:0; border-top:6px solid transparent; border-bottom:6px solid transparent; border-right:8px solid #ccc; z-index:1;"></div>
                                        <!-- Right arrowhead -->
                                        <div style="position:absolute; top:5px; right:5px; width:0; height:0; border-top:6px solid transparent; border-bottom:6px solid transparent; border-left:8px solid #ccc; z-index:1;"></div>
                                        <% cat.likert.forEach(function(opt, oi) { %>
                                        <% if (oi === 0 || oi === 2 || oi === 4) {
                                           // Color: value 1 = #AE5436, value 3 = #D69772, value 5 = #34877A
                                           var bubbleColors = { 1: '#AE5436', 3: '#D69772', 5: '#34877A' };
                                           var bColor = bubbleColors[opt.value] || '#bbb';
                                        %>
                                        <div style="display:flex; flex-direction:column; align-items:center; gap:0.18rem; z-index:2; flex:0 0 auto; width:30%;">
                                            <div style="width:22px; height:22px; border-radius:50%; border:2px solid <%= bColor %>; background:#f9fafb; display:flex; align-items:center; justify-content:center; font-size:0.62rem; font-weight:700; color:#000; flex-shrink:0;">
                                                <%= opt.value %>
                                            </div>
                                            <span class="dorm-likert-label" data-sublabel="<%= opt.sublabel %>" style="font-size:0.58rem; color:#000; font-weight:600; text-align:center; line-height:1.2; word-break:break-word; cursor:default; width:100%;"><%= opt.label %></span>
                                        </div>
                                        <% } %>
                                        <% }); %>
                                    </div>
                                </div>

                                <!-- Scrollable list -->
                                <div class="ranking-scroll" id="scroll-<%= catIdx %>" style="background:#fff; border-radius:0 0 0.75rem 0.75rem; box-shadow:var(--shadow-md);
                      height:440px; overflow-y:auto; scroll-behavior:smooth; padding:0.5rem 0;">
                                    <%
                                    // Sort houses by this category (descending; null scores go last)
                                    const sorted = [...rankings].sort((a, b) => {
                                        const va = a.scores[cat.key];
                                        const vb = b.scores[cat.key];
                                        if (va === null && vb === null) return 0;
                                        if (va === null) return 1;
                                        if (vb === null) return -1;
                                        return vb - va;
                                    });

                                    // Max score is always 5 (1-5 scale)
                                    const maxScore = 5;
                                    %>

                                    <%
                                    // Match the numeric score color scale used by the Explore dorm rankings.
                                    function scoreBarColor(score) {
                                        const colors = { 5: '#34877A', 4: '#92B89D', 3: '#D69772', 2: '#C27654', 1: '#AE5436' };
                                        return colors[Math.round(score)] || '#D69772';
                                    }
                                    %>
                                    <% sorted.forEach((h, rank)=> {
                                        const houseIdx = rankings.findIndex(r => r.name === h.name);
                                        const score = h.scores[cat.key];
                                        const pct = score === null ? 0 : Math.max(4, Math.min(100, ((score - 1) / 4) * 100));
                                        const barColor = score !== null ? scoreBarColor(score) : '#e5e7eb';
                                    %>
                                        <div class="rank-row"
                                             id="row-<%= catIdx %>-<%= houseIdx %>"
                                             data-house-idx="<%= houseIdx %>"
                                             onclick="window.location='/house/<%= encodeURIComponent(dormName) %>/<%= encodeURIComponent(h.name) %>'"
                                             style="display:flex; align-items:center; gap:0.5rem; padding:0.52rem 0.75rem;
                                                    border-bottom:1px solid #f3f4f6; cursor:pointer; transition:background 0.15s;">

                                            <div class="rank-row-inner">
                                                <div class="rank-row-heading">
                                                    <span class="rank-house-name">
                                                        <%= h.name %><% if (h.reviewCount > 0) { %><em class="rank-review-count">(<%= h.reviewCount %>)</em><% } %>
                                                    </span>
                                                    <% if (score !== null) { %>
                                                        <span class="rank-score-meta">
                                                            <span class="rank-score-word" style="color:<%= barColor %>;"><%= cat.textLabel(score) %></span>
                                                            <span class="rank-score-value"><%= score.toFixed(2) %></span>
                                                        </span>
                                                    <% } else { %>
                                                        <span style="font-size:0.7rem; color:#ccc; font-style:italic; flex-shrink:0;">--</span>
                                                    <% } %>
                                                </div>
                                                <!-- Horizontal score bar -->
                                                <div style="position:relative; height:16px; background:#f1f1f4; border-radius:3px; overflow:hidden;">
                                                    <% if (score !== null) { %>
                                                        <div class="rank-bar"
                                                             style="position:absolute; left:0; top:0; height:100%; width:<%= pct %>%; background:<%= barColor %>; border-radius:3px; transition:width 0.3s;"></div>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </div>
                                    <% }) %>
                                </div>
                            </div>
                            <% }) %>
                </div>

                <!-- Hint -->
                <p style="text-align:center; color:var(--text-secondary); font-size:0.85rem; margin-top:1.25rem;">
                    💡 Click any row to view all rooms in that house &nbsp;·&nbsp; Hover an emblem to spotlight that
                    house across every ranking &nbsp;·&nbsp; Right-click an emblem to lock/unlock the spotlight
                </p>
            </main>

            <footer>
                <p>&copy; 2026 Room for Improvement</p>
            </footer>

            <!-- Likert label tooltip (same style as word cloud tooltip in house page) -->
            <div id="dorm-likert-tooltip" style="position:fixed; z-index:9999; pointer-events:none; background:rgba(30,30,30,0.92); color:#fff; padding:0.45rem 0.75rem; border-radius:0.4rem; font-size:0.82rem; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; white-space:nowrap; box-shadow:0 3px 12px rgba(0,0,0,0.25); opacity:0; transition:opacity 0.15s ease;"></div>

            <!-- Review count tooltip (same style as word cloud tooltips) -->
            <div id="review-count-tooltip" style="position:fixed; z-index:9999; pointer-events:none; background:rgba(30,30,30,0.92); color:#fff; padding:0.45rem 0.75rem; border-radius:0.4rem; font-size:0.82rem; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; white-space:nowrap; box-shadow:0 3px 12px rgba(0,0,0,0.25); opacity:0; transition:opacity 0.15s ease;"></div>

            <script id="rankings-data" type="application/json"><%- rankingsJson %></script>
            <script>
                const rankings = JSON.parse(document.getElementById('rankings-data').textContent);
                const NUM_CATS = 5;

                // Track which house is "locked" via right-click
                var lockedHouseIdx = null;

                function hoverHouse(houseIdx, isHover) {
                    // If a house is locked and this is a mouseleave, ignore it
                    if (lockedHouseIdx !== null && !isHover && houseIdx === lockedHouseIdx) return;
                    // If a house is locked and this is a mouseenter for a different house, ignore it
                    if (lockedHouseIdx !== null && isHover && houseIdx !== lockedHouseIdx) return;

                    const embEl = document.getElementById('emblem-' + houseIdx);
                    if (embEl) {
                        if (isHover) {
                            embEl.style.border = '3px solid white';
                            embEl.style.boxShadow = '0 0 0 3px ' + rankings[houseIdx].color + ', 0 4px 16px rgba(0,0,0,0.3)';
                            embEl.style.transform = 'scale(1.12)';
                        } else {
                            embEl.style.border = '3px solid transparent';
                            embEl.style.boxShadow = '0 3px 10px rgba(0,0,0,0.18)';
                            embEl.style.transform = '';
                        }
                    }

                    // Dim all other emblems in the strip
                    for (let i = 0; i < rankings.length; i++) {
                        if (i === houseIdx) continue;
                        const otherEmb = document.getElementById('emblem-' + i);
                        if (otherEmb) {
                            otherEmb.style.opacity = isHover ? '0.3' : '';
                        }
                        // Also dim the emblem label (parent div's span)
                        const embDiv = otherEmb ? otherEmb.closest('.emblem') : null;
                        if (embDiv) embDiv.style.opacity = isHover ? '0.3' : '';
                    }

                    // Show/hide ranking overlay on dimmed emblems
                    for (let i = 0; i < rankings.length; i++) {
                        if (i === houseIdx) continue;
                        const otherEmb = document.getElementById('emblem-' + i);
                        if (!otherEmb) continue;
                        var existingOverlay = otherEmb.querySelector('.emblem-rank-overlay');
                        if (isHover) {
                            if (!existingOverlay) {
                                // Compute overall rank for this house across all categories
                                var catKeys = ['culture', 'roomSize', 'quietness', 'tempControl', 'sunlight'];
                                var vals = catKeys.map(function(k) { return rankings[i].scores[k]; }).filter(function(v) { return v != null; });
                                var overallScore = vals.length ? vals.reduce(function(a, b) { return a + b; }, 0) / vals.length : null;
                                // Rank among all houses by overall score
                                var allOveralls = rankings.map(function(h, idx) {
                                    var hVals = catKeys.map(function(k) { return h.scores[k]; }).filter(function(v) { return v != null; });
                                    return { idx: idx, overall: hVals.length ? hVals.reduce(function(a, b) { return a + b; }, 0) / hVals.length : null };
                                }).filter(function(h) { return h.overall != null; }).sort(function(a, b) { return b.overall - a.overall; });
                                var overallRank = null;
                                var totalRanked = allOveralls.length;
                                for (var ri = 0; ri < allOveralls.length; ri++) {
                                    if (allOveralls[ri].idx === i) { overallRank = ri + 1; break; }
                                }
                                // Gradient color: rank 1 (best) = green, rank totalRanked (worst) = red
                                var overlayColor = (function(r, t) {
                                    if (!r || !t) return '#6b6b6b';
                                    var pct = (r - 1) / Math.max(t - 1, 1); // 0 = best, 1 = worst
                                    var stops = [
                                        { p: 0,    r: 0x34, g: 0x87, b: 0x7A },
                                        { p: 0.25, r: 0x92, g: 0xB8, b: 0x9D },
                                        { p: 0.5,  r: 0xD6, g: 0x97, b: 0x72 },
                                        { p: 0.75, r: 0xC2, g: 0x76, b: 0x54 },
                                        { p: 1,    r: 0xAE, g: 0x54, b: 0x36 }
                                    ];
                                    var lo = stops[0], hi = stops[stops.length - 1];
                                    for (var si = 0; si < stops.length - 1; si++) {
                                        if (pct >= stops[si].p && pct <= stops[si + 1].p) {
                                            lo = stops[si]; hi = stops[si + 1]; break;
                                        }
                                    }
                                    var segPct = (hi.p === lo.p) ? 0 : (pct - lo.p) / (hi.p - lo.p);
                                    var cr = Math.round(lo.r + (hi.r - lo.r) * segPct);
                                    var cg = Math.round(lo.g + (hi.g - lo.g) * segPct);
                                    var cb = Math.round(lo.b + (hi.b - lo.b) * segPct);
                                    return 'rgb(' + cr + ',' + cg + ',' + cb + ')';
                                })(overallRank, totalRanked);
                                var overlay = document.createElement('div');
                                overlay.className = 'emblem-rank-overlay';
                                overlay.style.cssText = 'position:absolute; inset:0; border-radius:50%; background:' + overlayColor + '; display:flex; align-items:center; justify-content:center; color:#fff; font-weight:800; font-size:0.82rem; z-index:5; pointer-events:none;';
                                overlay.textContent = overallRank ? '#' + overallRank : '?';
                                otherEmb.appendChild(overlay);
                            }
                        } else {
                            if (existingOverlay) existingOverlay.remove();
                        }
                    }

                    // Highlight the hovered house rows; dim all other rows
                    for (let catIdx = 0; catIdx < NUM_CATS; catIdx++) {
                        for (let i = 0; i < rankings.length; i++) {
                            const row = document.getElementById('row-' + catIdx + '-' + i);
                            if (!row) continue;
                            if (i === houseIdx) {
                                if (isHover) {
                                    row.classList.add('rank-row-highlight');
                                    row.style.background = rankings[houseIdx].color + '22';
                                    row.style.borderLeft = '4px solid ' + rankings[houseIdx].color;
                                    row.style.opacity = '';
                                } else {
                                    row.classList.remove('rank-row-highlight');
                                    row.style.transition = 'none';
                                    row.style.background = '';
                                    row.style.borderLeft = '';
                                    row.style.opacity = '';
                                    // Force reflow then restore transition
                                    void row.offsetHeight;
                                    row.style.transition = '';
                                }
                            } else {
                                if (isHover) {
                                    row.style.opacity = '0.3';
                                } else {
                                    row.style.transition = 'none';
                                    row.style.opacity = '';
                                    void row.offsetHeight;
                                    row.style.transition = '';
                                }
                            }
                        }

                        // Scroll the panel so the hovered house's row is visible
                        if (isHover) {
                            var targetRow = document.getElementById('row-' + catIdx + '-' + houseIdx);
                            var scrollContainer = document.getElementById('scroll-' + catIdx);
                            if (targetRow && scrollContainer) {
                                var rowTop = targetRow.offsetTop - scrollContainer.offsetTop;
                                var rowHeight = targetRow.offsetHeight;
                                var scrollTop = scrollContainer.scrollTop;
                                var containerHeight = scrollContainer.clientHeight;
                                if (rowTop < scrollTop || rowTop + rowHeight > scrollTop + containerHeight) {
                                    scrollContainer.scrollTop = rowTop - containerHeight / 2 + rowHeight / 2;
                                }
                            }
                        }
                    }
                }

                // Right-click on emblems to toggle lock
                document.getElementById('emblem-strip').addEventListener('contextmenu', function(e) {
                    var emblemDiv = e.target.closest('.emblem');
                    if (!emblemDiv) return;
                    e.preventDefault();
                    var houseIdx = parseInt(emblemDiv.dataset.house, 10);
                    if (isNaN(houseIdx)) return;

                    if (lockedHouseIdx === houseIdx) {
                        // Unlock: clear the highlight
                        lockedHouseIdx = null;
                        hoverHouse(houseIdx, false);
                    } else {
                        // If another house was locked, clear it first
                        if (lockedHouseIdx !== null) {
                            var prev = lockedHouseIdx;
                            lockedHouseIdx = null;
                            hoverHouse(prev, false);
                        }
                        // Lock this house
                        lockedHouseIdx = houseIdx;
                        hoverHouse(houseIdx, true);
                    }
                });

                // Click anywhere else to unlock
                document.addEventListener('click', function(e) {
                    if (lockedHouseIdx === null) return;
                    var emblemDiv = e.target.closest('.emblem');
                    if (emblemDiv) return; // clicking an emblem (left-click navigates)
                    var prev = lockedHouseIdx;
                    lockedHouseIdx = null;
                    hoverHouse(prev, false);
                });
            </script>

            <script>
                // ── Likert label tooltips (same style as word cloud tooltips in house page) ──
                (function() {
                    var tooltip = document.getElementById('dorm-likert-tooltip');
                    if (!tooltip) return;
                    document.querySelectorAll('.dorm-likert-label').forEach(function(labelEl) {
                        var sublabel = labelEl.dataset.sublabel || '';
                        if (!sublabel) return;
                        labelEl.addEventListener('mouseenter', function(e) {
                            tooltip.textContent = sublabel;
                            var tx = e.clientX + 14;
                            var ty = e.clientY + 18;
                            var tw = tooltip.offsetWidth || 160;
                            var th = tooltip.offsetHeight || 36;
                            if (tx + tw > window.innerWidth - 8) tx = e.clientX - tw - 10;
                            if (ty + th > window.innerHeight - 8) ty = e.clientY - th - 10;
                            if (ty < 8) ty = 8;
                            tooltip.style.left = tx + 'px';
                            tooltip.style.top = ty + 'px';
                            tooltip.style.opacity = '1';
                        });
                        labelEl.addEventListener('mousemove', function(e) {
                            var tx = e.clientX + 14;
                            var ty = e.clientY + 18;
                            var tw = tooltip.offsetWidth || 160;
                            var th = tooltip.offsetHeight || 36;
                            if (tx + tw > window.innerWidth - 8) tx = e.clientX - tw - 10;
                            if (ty + th > window.innerHeight - 8) ty = e.clientY - th - 10;
                            if (ty < 8) ty = 8;
                            tooltip.style.left = tx + 'px';
                            tooltip.style.top = ty + 'px';
                        });
                        labelEl.addEventListener('mouseleave', function() {
                            tooltip.style.opacity = '0';
                        });
                    });
                })();
            </script>

            <script>
                // ── Review count tooltips — only appear after 1 second hover ──
                (function() {
                    var tooltip = document.getElementById('review-count-tooltip');
                    if (!tooltip) return;
                    document.querySelectorAll('.rank-review-count').forEach(function(el) {
                        var hoverTimer = null;
                        el.style.cursor = 'default';
                        el.addEventListener('mouseenter', function(e) {
                            e.stopPropagation();
                            // Extract the review count number from the text "(68)" → 68
                            var countText = (el.textContent || '').replace(/[^0-9]/g, '');
                            tooltip.textContent = countText + ' reviews submitted for this house';
                            hoverTimer = setTimeout(function() {
                                var tx = e.clientX + 14;
                                var ty = e.clientY + 18;
                                var tw = tooltip.offsetWidth || 200;
                                var th = tooltip.offsetHeight || 36;
                                if (tx + tw > window.innerWidth - 8) tx = e.clientX - tw - 10;
                                if (ty + th > window.innerHeight - 8) ty = e.clientY - th - 10;
                                if (ty < 8) ty = 8;
                                tooltip.style.left = tx + 'px';
                                tooltip.style.top = ty + 'px';
                                tooltip.style.opacity = '1';
                            }, 1000);
                        });
                        el.addEventListener('mousemove', function(e) {
                            if (tooltip.style.opacity === '1') {
                                var tx = e.clientX + 14;
                                var ty = e.clientY + 18;
                                var tw = tooltip.offsetWidth || 200;
                                var th = tooltip.offsetHeight || 36;
                                if (tx + tw > window.innerWidth - 8) tx = e.clientX - tw - 10;
                                if (ty + th > window.innerHeight - 8) ty = e.clientY - th - 10;
                                if (ty < 8) ty = 8;
                                tooltip.style.left = tx + 'px';
                                tooltip.style.top = ty + 'px';
                            }
                        });
                        el.addEventListener('mouseleave', function() {
                            if (hoverTimer) { clearTimeout(hoverTimer); hoverTimer = null; }
                            tooltip.style.opacity = '0';
                        });
                    });
                })();
            </script>

            <script>
                // ── Emblem hover: show numeric rank labels in ranking rows ──
                // On emblem hover, each highlighted row gets a rank number badge
                // prepended, the bar compresses, and name/score shift right.
                // Also: row hover triggers dimming after 1 second (same as emblem hover).
                (function() {
                    var catKeys = ['culture', 'roomSize', 'quietness', 'tempControl', 'sunlight'];

                    // Pre-compute per-category sorted order so we know each house's rank
                    var rankByCatAndHouse = {}; // rankByCatAndHouse[catIdx][houseIdx] = rank (1-based)
                    var totalRankedByCat = {}; // totalRankedByCat[catIdx] = number of ranked houses
                    for (var catIdx = 0; catIdx < catKeys.length; catIdx++) {
                        rankByCatAndHouse[catIdx] = {};
                        var key = catKeys[catIdx];
                        // Sort rankings by this category descending (null last)
                        var sorted = rankings.slice().sort(function(a, b) {
                            var va = a.scores[key];
                            var vb = b.scores[key];
                            if (va === null && vb === null) return 0;
                            if (va === null) return 1;
                            if (vb === null) return -1;
                            return vb - va;
                        });
                        var rankedCount = sorted.filter(function(h) { return h.scores[key] !== null; }).length;
                        totalRankedByCat[catIdx] = rankedCount;
                        sorted.forEach(function(h, rank) {
                            var origIdx = rankings.findIndex(function(r) { return r.name === h.name; });
                            rankByCatAndHouse[catIdx][origIdx] = rank + 1;
                        });
                    }

                    // Override hoverHouse to add rank badges and animated swipe
                    var origHoverHouse = window.hoverHouse || hoverHouse;

                    window.hoverHouse = function(houseIdx, isHover) {
                        // Call original highlight/dim logic
                        origHoverHouse(houseIdx, isHover);

                        // Add or remove rank badges with swipe animation
                        for (var catIdx = 0; catIdx < NUM_CATS; catIdx++) {
                            (function(catIdx) {
                                var row = document.getElementById('row-' + catIdx + '-' + houseIdx);
                                if (!row) return;

                                var existingBadge = row.querySelector('.rank-num-badge');
                                if (isHover) {
                                    if (!existingBadge) {
                                        var rank = rankByCatAndHouse[catIdx][houseIdx];
                                        var total = totalRankedByCat[catIdx];
                                        var badge = document.createElement('div');
                                        badge.className = 'rank-num-badge';
                                        // Color follows red→green gradient based on ranking position
                                        var badgeColor = (function(r, t) {
                                            if (!r || !t) return '#6b6b6b';
                                            // rank 1 = best (green), rank t = worst (red)
                                            // Interpolate from green (#34877A) to red (#AE5436)
                                            var pct = (r - 1) / Math.max(t - 1, 1); // 0 = best, 1 = worst
                                            // 5-stop gradient matching the rating color scale
                                            var stops = [
                                                { p: 0,    r: 0x34, g: 0x87, b: 0x7A }, // #34877A (best)
                                                { p: 0.25, r: 0x92, g: 0xB8, b: 0x9D }, // #92B89D
                                                { p: 0.5,  r: 0xD6, g: 0x97, b: 0x72 }, // #D69772
                                                { p: 0.75, r: 0xC2, g: 0x76, b: 0x54 }, // #C27654
                                                { p: 1,    r: 0xAE, g: 0x54, b: 0x36 }  // #AE5436 (worst)
                                            ];
                                            // Find the two stops to interpolate between
                                            var lo = stops[0], hi = stops[stops.length - 1];
                                            for (var si = 0; si < stops.length - 1; si++) {
                                                if (pct >= stops[si].p && pct <= stops[si + 1].p) {
                                                    lo = stops[si]; hi = stops[si + 1]; break;
                                                }
                                            }
                                            var segPct = (hi.p === lo.p) ? 0 : (pct - lo.p) / (hi.p - lo.p);
                                            var cr = Math.round(lo.r + (hi.r - lo.r) * segPct);
                                            var cg = Math.round(lo.g + (hi.g - lo.g) * segPct);
                                            var cb = Math.round(lo.b + (hi.b - lo.b) * segPct);
                                            return 'rgb(' + cr + ',' + cg + ',' + cb + ')';
                                        })(rank, total);
                                        badge.style.cssText = 'flex-shrink:0; width:36px; height:36px; border-radius:50%; background:' + badgeColor + '; color:#fff; font-size:0.82rem; font-weight:800; display:flex; align-items:center; justify-content:center; margin-right:0.35rem; box-shadow:0 2px 6px rgba(0,0,0,0.2); opacity:0; transform:translateX(-20px); transition:all 0.3s ease;';
                                        badge.textContent = rank ? rank + '/' + total : '—';
                                        row.insertBefore(badge, row.firstChild);
                                        // Trigger animation — capture badge in closure
                                        (function(b) {
                                            requestAnimationFrame(function() {
                                                b.style.opacity = '1';
                                                b.style.transform = 'translateX(0)';
                                            });
                                        })(badge);
                                    }
                                    // Animate the row inner to swipe right
                                    var rowInner = row.querySelector('.rank-row-inner');
                                    if (rowInner) {
                                        rowInner.style.transition = 'transform 0.3s ease';
                                        rowInner.style.transform = 'translateX(4px)';
                                    }
                                    // Compress the bar
                                    var barWrap = row.querySelector('.rank-row-inner > div:last-child');
                                    if (barWrap) {
                                        barWrap.style.transition = 'height 0.3s ease';
                                        barWrap.style.height = '10px';
                                    }
                                } else {
                                    // Snap back instantly — no animated transition
                                    if (existingBadge) {
                                        existingBadge.remove();
                                    }
                                    // Reset row inner transform instantly
                                    var rowInner = row.querySelector('.rank-row-inner');
                                    if (rowInner) {
                                        rowInner.style.transition = 'none';
                                        rowInner.style.transform = '';
                                    }
                                    // Restore bar height instantly
                                    var barWrap = row.querySelector('.rank-row-inner > div:last-child');
                                    if (barWrap) {
                                        barWrap.style.transition = 'none';
                                        barWrap.style.height = '16px';
                                    }
                                }
                            })(catIdx);
                        }
                    };

                    // ── Row hover: after 1 second, trigger the same dimming effect as emblem hover ──
                    var rowHoverTimer = null;
                    var rowHoverActiveIdx = null;

                    function clearRowHoverEffect() {
                        if (rowHoverActiveIdx !== null) {
                            // Only clear if not locked
                            if (lockedHouseIdx === null) {
                                hoverHouse(rowHoverActiveIdx, false);
                            }
                            rowHoverActiveIdx = null;
                        }
                        if (rowHoverTimer) {
                            clearTimeout(rowHoverTimer);
                            rowHoverTimer = null;
                        }
                    }

                    document.querySelectorAll('.rank-row').forEach(function(row) {
                        row.addEventListener('mouseenter', function() {
                            var houseIdx = parseInt(row.dataset.houseIdx, 10);
                            if (isNaN(houseIdx)) return;
                            if (lockedHouseIdx !== null) return; // don't override lock
                            rowHoverTimer = setTimeout(function() {
                                rowHoverActiveIdx = houseIdx;
                                hoverHouse(houseIdx, true);
                            }, 1000);
                        });
                        row.addEventListener('mouseleave', function() {
                            clearRowHoverEffect();
                        });
                    });
                })();
            </script>
    </body>

    </html>
