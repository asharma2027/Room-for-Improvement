<%- include('partials/head', { title: dormName + ' Rankings | Room for Improvement' }) %>

    <body>
        <%- include('partials/nav') %>

            <main style="max-width:1300px; margin:0 auto; padding:2rem 1.5rem;">

                <!-- Header -->
                <div style="display:flex; align-items:center; gap:1rem; margin-bottom:1.5rem;">
                    <a href="/map"
                        style="display:flex; align-items:center; gap:0.4rem; color:var(--text-secondary); font-size:0.9rem; font-weight:500;">
                        ← Map
                    </a>
                    <span style="color:var(--border-color);">|</span>
                    <h1 style="margin:0; font-size:1.75rem;">
                        <%= dormName.replace(/_/g, '-' ) %> — House Rankings
                    </h1>
                </div>

                <!-- Emblem Strip -->
                <div
                    style="background:#fff; border-radius:1rem; box-shadow:var(--shadow-md); padding:1.25rem 1.5rem; margin-bottom:1.75rem;">
                    <p
                        style="margin:0 0 1rem; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.08em; color:var(--text-secondary); font-weight:600;">
                        Hover an emblem to highlight in rankings · Click to visit that house's page
                    </p>
                    <div id="emblem-strip" style="display:flex; flex-wrap:wrap; gap:1rem; align-items:center;">
                        <% rankings.forEach((h, i)=> { %>
                            <div class="emblem"
                                data-house="<%= i %>"
                                onmouseenter="hoverHouse(<%= i %>, true)"
                                onmouseleave="hoverHouse(<%= i %>, false)"
                                onclick="window.location='/house/<%= encodeURIComponent(dormName) %>/<%= encodeURIComponent(h.name) %>'"
                                title="<%= h.name %>"
                                style="display:flex; flex-direction:column; align-items:center; gap:0.35rem; cursor:pointer; transition:transform 0.2s;">
                                <div class="emblem-circle" id="emblem-<%= i %>" style="width:52px; height:52px; border-radius:50%; background:<%= h.color %>; <%= h.emblem ? `background-image:url('${h.emblem}'); background-size:cover; background-position:center; background-color:#fff;` : '' %>
                        display:flex; align-items:center; justify-content:center;
                        box-shadow: 0 3px 10px rgba(0,0,0,0.18);
                        border: 3px solid transparent; transition: all 0.25s; position:relative; overflow:hidden;">
                                    <% if (!h.emblem) { %>
                                        <span
                                            style="color:white; font-weight:800; font-size:0.85rem; letter-spacing:0.02em;">
                                            <%= h.initials %>
                                        </span>
                                        <% } %>
                                </div>
                                <span
                                    style="font-size:0.7rem; font-weight:600; color:var(--text-secondary); text-align:center; max-width:64px; line-height:1.2;">
                                    <%= h.name %>
                                </span>
                            </div>
                            <% }) %>
                    </div>
                </div>

                <!-- Rankings Board -->
                <div id="rankings-board"
                    style="display:grid; grid-template-columns: repeat(5, 1fr); gap:1rem; align-items:start;">

                    <%
                    // Panel titles/keys aligned with the v2 room review form field labels
                    // (House Culture, Outside Noise, Natural Light, Room Size, Temperature Control)
                    const categories = [
                        { key: 'culture',     icon: '🏆',  label: 'House Culture',       note: 'Higher = better' },
                        { key: 'quietness',   icon: '🔇',  label: 'Outside Noise',       note: 'Higher = quieter' },
                        { key: 'sunlight',    icon: '☀️', label: 'Natural Light',       note: 'Higher = brighter' },
                        { key: 'roomSize',    icon: '📦',  label: 'Room Size',           note: 'Higher = bigger' },
                        { key: 'tempControl', icon: '❄️', label: 'Temperature Control', note: 'Higher = easier to control' }
                    ];
                    %>

                        <% categories.forEach((cat, catIdx)=> { %>
                            <div class="ranking-column-wrapper">
                                <!-- Column header -->
                                <div
                                    style="text-align:center; padding:0.85rem 0.5rem 0.65rem; background:#fff; border-radius:0.75rem 0.75rem 0 0; border-bottom:2px solid var(--border-color); box-shadow:var(--shadow-sm);">
                                    <div style="font-size:2rem; line-height:1; margin-bottom:0.3rem;">
                                        <%= cat.icon %>
                                    </div>
                                    <div style="font-weight:700; font-size:0.9rem; color:var(--text-primary);">
                                        <%= cat.label %>
                                    </div>
                                    <div style="font-size:0.7rem; color:var(--text-secondary); margin-top:0.2rem;">
                                        <%= cat.note %>
                                    </div>
                                </div>

                                <!-- Scrollable list -->
                                <div class="ranking-scroll" id="scroll-<%= catIdx %>" style="background:#fff; border-radius:0 0 0.75rem 0.75rem; box-shadow:var(--shadow-md);
                      height:440px; overflow-y:auto; scroll-behavior:smooth; padding:0.5rem 0;">
                                    <%
                                    // Sort houses by this category (descending; null scores go last)
                                    const sorted = [...rankings].sort((a, b) => {
                                        const va = a.scores[cat.key];
                                        const vb = b.scores[cat.key];
                                        if (va === null && vb === null) return 0;
                                        if (va === null) return 1;
                                        if (vb === null) return -1;
                                        return vb - va;
                                    });

                                    // Max absolute score for this column (used to size the bars)
                                    const maxScore = sorted.reduce((m, h) => {
                                        const v = h.scores[cat.key];
                                        return (v !== null && Math.abs(v) > m) ? Math.abs(v) : m;
                                    }, 0) || 1;
                                    %>

                                    <% sorted.forEach((h, rank)=> {
                                        const houseIdx = rankings.findIndex(r => r.name === h.name);
                                        const score = h.scores[cat.key];
                                        const pct = score === null ? 0 : Math.max(2, Math.min(100, (Math.abs(score) / maxScore) * 100));
                                    %>
                                        <div class="rank-row"
                                             id="row-<%= catIdx %>-<%= houseIdx %>"
                                             data-house-idx="<%= houseIdx %>"
                                             onclick="window.location='/house/<%= encodeURIComponent(dormName) %>/<%= encodeURIComponent(h.name) %>'"
                                             style="display:flex; align-items:center; gap:0.5rem; padding:0.5rem 0.75rem;
                                                    border-bottom:1px solid #f3f4f6; cursor:pointer; transition:background 0.15s;">

                                            <div style="width:20px; text-align:center; flex-shrink:0;">
                                                <span style="font-size:0.8rem; font-weight:800; color:#888;">
                                                    <%= rank + 1 %>
                                                </span>
                                            </div>

                                            <div style="flex:1; min-width:0;">
                                                <div style="display:flex; justify-content:space-between; align-items:baseline; gap:0.5rem; margin-bottom:0.2rem;">
                                                    <span style="font-weight:600; font-size:0.78rem; color:var(--text-primary); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                                        <%= h.name %>
                                                    </span>
                                                    <% if (score !== null) { %>
                                                        <span style="font-size:0.72rem; font-weight:700; color:var(--text-secondary); flex-shrink:0;">
                                                            <%= score.toFixed(2) %>
                                                        </span>
                                                    <% } else { %>
                                                        <span style="font-size:0.7rem; color:#ccc; font-style:italic; flex-shrink:0;">--</span>
                                                    <% } %>
                                                </div>
                                                <!-- Horizontal score bar -->
                                                <div style="height:6px; background:#f1f1f4; border-radius:3px; overflow:hidden;">
                                                    <% if (score !== null) { %>
                                                        <div class="rank-bar"
                                                             style="height:100%; width:<%= pct %>%; background:<%= h.color %>; border-radius:3px; transition:width 0.3s;"></div>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </div>
                                    <% }) %>
                                </div>
                            </div>
                            <% }) %>
                </div>

                <!-- Hint -->
                <p style="text-align:center; color:var(--text-secondary); font-size:0.85rem; margin-top:1.25rem;">
                    💡 Click any row to view all rooms in that house &nbsp;·&nbsp; Hover an emblem to spotlight that
                    house across every ranking
                </p>
            </main>

            <footer>
                <p>&copy; 2025 Room for Improvement</p>
            </footer>

            <script id="rankings-data" type="application/json"><%- rankingsJson %></script>
            <script>
                const rankings = JSON.parse(document.getElementById('rankings-data').textContent);
                const NUM_CATS = 5;

                function hoverHouse(houseIdx, isHover) {
                    const embEl = document.getElementById('emblem-' + houseIdx);
                    if (embEl) {
                        if (isHover) {
                            embEl.style.border = '3px solid white';
                            embEl.style.boxShadow = '0 0 0 3px ' + rankings[houseIdx].color + ', 0 4px 16px rgba(0,0,0,0.3)';
                            embEl.style.transform = 'scale(1.12)';
                        } else {
                            embEl.style.border = '3px solid transparent';
                            embEl.style.boxShadow = '0 3px 10px rgba(0,0,0,0.18)';
                            embEl.style.transform = '';
                        }
                    }
                    for (let catIdx = 0; catIdx < NUM_CATS; catIdx++) {
                        const row = document.getElementById('row-' + catIdx + '-' + houseIdx);
                        if (!row) continue;
                        if (isHover) {
                            row.classList.add('rank-row-highlight');
                            row.style.background = rankings[houseIdx].color + '22';
                            row.style.borderLeft = '4px solid ' + rankings[houseIdx].color;
                        } else {
                            row.classList.remove('rank-row-highlight');
                            row.style.background = '';
                            row.style.borderLeft = '';
                        }
                    }
                }
            </script>
    </body>

    </html>
