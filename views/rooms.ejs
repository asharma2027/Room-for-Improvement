<%- include('partials/head', { title: 'Rooms | Room for Improvement' }) %>

  <body>
    <%- include('partials/nav') %>

      <main style="max-width:1300px; margin:0 auto; padding:2rem 1.5rem;">
        
        <!-- Hero Banner for All Rooms -->
        <div class="house-banner" style="background-color: var(--primary-dark); position: relative; overflow: visible;">
            <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; position:relative; z-index:2; padding: 2.5rem 0;">
                <div style="width:72px; height:72px; border-radius:50%; background:var(--primary-color); display:flex; align-items:center; justify-content:center; box-shadow: 0 4px 16px rgba(0,0,0,0.4); border: 3px solid rgba(255,255,255,0.2); margin-bottom:1rem;">
                    <span style="color:white; font-size:2rem;">🏛️</span>
                </div>
                <h1 style="margin:0; font-size:2.5rem; font-weight:800; text-shadow:0 2px 4px rgba(0,0,0,0.5); color:white; text-align:center;">
                    All Campus Rooms
                </h1>
            </div>
        </div>

        <!-- Inline Stats Row (Campus-wide) -->
        <div class="house-stats-row" style="display:flex; align-items:center; justify-content:space-between; flex-wrap:nowrap; overflow-x:auto;">
            <% const ratedRooms = rooms.filter(r => r.houseCultureVal || r.outsideNoiseVal);
               const cultureRated = rooms.filter(r => r.houseCultureVal);
               const avgCulture = cultureRated.length ? (cultureRated.reduce((s,r) => s + parseFloat(r.houseCultureVal), 0) / cultureRated.length).toFixed(1) : null;
               const noiseRated = rooms.filter(r => r.outsideNoiseVal);
               const avgNoise = noiseRated.length ? (noiseRated.reduce((s,r) => s + parseFloat(r.outsideNoiseVal), 0) / noiseRated.length).toFixed(1) : null;
            %>
            <div style="display:flex; gap:1rem; flex-wrap:nowrap; align-items:center;">
                <div class="house-stat-mini">
                    <span class="house-stat-val" style="color:var(--text-primary);"><%= rooms.length %></span>
                    <span class="house-stat-lbl">Total Rooms</span>
                </div>
                <div class="house-stat-mini" style="border-left:1px solid var(--border-color); padding-left:1rem;">
                    <span class="house-stat-val" style="color:var(--accent-color);"><%= ratedRooms.length > 0 ? ratedRooms.length : '—' %></span>
                    <span class="house-stat-lbl">Reviews</span>
                </div>
                <% if (avgCulture !== null) { %>
                <div class="house-stat-mini" style="border-left:1px solid var(--border-color); padding-left:1rem;">
                    <span class="house-stat-val" style="color:var(--success-color);">
                        <%= avgCulture %>/5
                    </span>
                    <span class="house-stat-lbl">House Culture</span>
                </div>
                <% } %>
                <% if (avgNoise !== null) { %>
                <div class="house-stat-mini" style="border-left:1px solid var(--border-color); padding-left:1rem;">
                    <span class="house-stat-val" style="color:var(--error-color);">
                        <%= avgNoise %>/5
                    </span>
                    <span class="house-stat-lbl">Outside Noise</span>
                </div>
                <% } %>
            </div>
            
            <form method="GET" action="/rooms" style="display: flex; gap: 0.5rem; margin: 0; align-items: center; padding-left: 1rem; border-left: 1px solid var(--border-color); margin-left: auto;">
                <input type="text" name="q" value="<%= query %>" placeholder="Search..." style="width: 200px; padding: 0.5rem 1rem; border-radius: 2rem; border: 1px solid var(--border-color);" />
                <button type="submit" style="padding: 0.5rem 1rem; border-radius: 2rem;" class="btn-primary">Search</button>
            </form>
        </div>

        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; margin-top: 1.5rem; padding: 0 0.5rem;">
            <!-- Filters -->
          <div class="stat-card">
            <h3>🏆 Best House Culture (Higher is Better)</h3>
            <ol class="stat-list" id="culture-list">
              <% if (topHousesCulture && topHousesCulture.length> 0) { %>
                <% topHousesCulture.forEach(h=> { %>
                  <li><span>
                      <%= h.houseName %>
                    </span> <span>
                      <%= h.avg.toFixed(2) %>
                    </span></li>
                  <% }) %>
                    <% } else { %>
                      <p>No data available.</p>
                      <% } %>
            </ol>
          </div>

          <div class="stat-card" style="border-left-color: var(--secondary-color);">
            <h3>🔇 Quietest Houses (Lower is Better)</h3>
            <ol class="stat-list" id="noise-list">
              <% if (topHousesNoise && topHousesNoise.length> 0) { %>
                <% topHousesNoise.forEach(h=> { %>
                  <li><span>
                      <%= h.houseName %>
                    </span> <span>
                      <%= h.avg.toFixed(2) %>
                    </span></li>
                  <% }) %>
                    <% } else { %>
                      <p>No data available.</p>
                      <% } %>
            </ol>
          </div>
        </div>

        <!-- Filters -->
        <style>
            /* ── Room type tag buttons (rooms page) ── */
            .roomtype-tag-filters {
                display: flex;
                flex-wrap: wrap;
                gap: 0.4rem;
                align-items: center;
            }
            .roomtype-tag-btn {
                display: inline-flex;
                align-items: center;
                padding: 0.25rem 0.7rem;
                border: 1.5px solid #800000;
                border-radius: 2rem;
                background: #fff;
                color: #800000;
                font-size: 0.8rem;
                font-weight: 600;
                cursor: pointer;
                transition: background 0.15s, color 0.15s;
                user-select: none;
            }
            .roomtype-tag-btn:hover { background: rgba(128,0,0,0.08); }
            .roomtype-tag-btn.active { background: #800000; color: #fff; }

            /* ── Active tag filter chips ── */
            .active-tag-chips {
                display: flex;
                flex-wrap: wrap;
                gap: 0.35rem;
                align-items: center;
            }
            .active-tag-chip {
                display: inline-flex;
                align-items: center;
                gap: 0.25rem;
                padding: 0.2rem 0.55rem;
                background: #800000;
                color: #fff;
                border-radius: 2rem;
                font-size: 0.78rem;
                font-weight: 600;
                cursor: default;
            }
            .active-tag-chip .chip-remove {
                cursor: pointer;
                font-size: 0.9rem;
                line-height: 1;
                opacity: 0.8;
                margin-left: 0.15rem;
            }
            .active-tag-chip .chip-remove:hover { opacity: 1; }

            /* ── Room-filter bar ── */
            .room-filters {
                display: flex;
                flex-wrap: wrap;
                gap: 1rem;
                align-items: center;
                margin: 1rem 0 0.75rem;
                padding: 0.75rem 1rem;
                background: #f9fafb;
                border: 1px solid var(--border-color);
                border-radius: 0.5rem;
            }
            .room-filters label {
                font-size: 0.85rem;
                font-weight: 600;
                color: var(--text-secondary);
                margin: 0;
                display: flex;
                align-items: center;
                gap: 0.4rem;
            }
            .room-filters select {
                font-size: 0.85rem;
                padding: 0.3rem 0.5rem;
                border: 1px solid var(--border-color);
                border-radius: 0.35rem;
                background: #fff;
            }
            .room-filters .filter-clear-btn {
                margin-left: auto;
                background: none;
                border: 1px solid var(--border-color);
                padding: 0.3rem 0.7rem;
                border-radius: 0.35rem;
                cursor: pointer;
                font-size: 0.8rem;
                color: var(--text-secondary);
            }
            .room-filters .filter-clear-btn:hover { background: #fff; }

            /* ── Sortable headers ── */
            th.sortable { cursor: pointer; user-select: none; }
            th.sortable:hover { background: rgba(0,0,0,0.03); }
            th.sortable .sort-indicator { display: inline-block; margin-left: 0.3rem; font-size: 0.75rem; opacity: 0.45; }
            th.sortable.sort-asc .sort-indicator,
            th.sortable.sort-desc .sort-indicator { opacity: 1; color: var(--primary-color, #800000); }

            /* ── Clickable tags ── */
            #rooms-table .tag { cursor: pointer; transition: opacity 0.15s; }
            #rooms-table .tag:hover { opacity: 0.75; }
        </style>

        <!-- Dorm / House legacy filters (preserved) -->
        <div class="filters"
          style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; margin-bottom: 0.5rem;">
          <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
            <div>
              <%# Hidden select keeps existing JS (applyFilters, onDormChange, clear-filters) working %>
              <select id="dorm-filter" style="display:none;">
                <option value="">All Dorms</option>
                <option value="Burton-Judson">Burton-Judson</option>
                <option value="I-House">I-House</option>
                <option value="Max Palevsky">Max Palevsky</option>
                <option value="Renee_Granville-Grossman">Renee Granville-Grossman</option>
                <option value="Snell_Hitchcock">Snell-Hitchcock</option>
                <option value="Woodlawn">Woodlawn</option>
              </select>

              <%# Custom dorm filter dropdown (R5) %>
              <div class="dorm-filter-dropdown-wrapper">
                <button type="button" class="filter-tags-btn" id="dorm-filter-btn">Filter by Dorm ▾</button>
                <div class="filter-tags-dropdown" id="dorm-filter-dropdown">
                  <div class="dorm-filter-item" data-dorm="Burton-Judson">
                    <span class="dorm-check">✓</span> Burton-Judson
                  </div>
                  <div class="dorm-filter-item" data-dorm="I-House">
                    <span class="dorm-check">✓</span> I-House
                  </div>
                  <div class="dorm-filter-item" data-dorm="Max Palevsky">
                    <span class="dorm-check">✓</span> Max Palevsky
                  </div>
                  <div class="dorm-filter-item" data-dorm="Renee_Granville-Grossman">
                    <span class="dorm-check">✓</span> Renee Granville-Grossman
                  </div>
                  <div class="dorm-filter-item" data-dorm="Snell_Hitchcock">
                    <span class="dorm-check">✓</span> Snell-Hitchcock
                  </div>
                  <div class="dorm-filter-item" data-dorm="Woodlawn">
                    <span class="dorm-check">✓</span> Woodlawn
                  </div>
                </div>
              </div>
            </div>

            <%# Custom house filter dropdown (R12) %>
            <div class="dorm-filter-dropdown-wrapper">
              <button type="button" class="filter-tags-btn" id="house-filter-btn">Filter by Houses ▾</button>
              <div class="filter-tags-dropdown" id="house-filter-dropdown">
                <% Object.keys(dormHousesMap).sort().forEach(function(dorm) { %>
                  <div class="house-filter-dorm-header" data-dorm="<%= dorm %>">
                    <%= dorm %>
                  </div>
                  <% (dormHousesMap[dorm] || []).sort().forEach(function(house) { %>
                    <div class="house-filter-item" data-dorm="<%= dorm %>" data-house="<%= house %>">
                      <span class="house-check">✓</span> <%= house %>
                    </div>
                  <% }) %>
                <% }) %>
              </div>
            </div>

            <%# Hidden legacy house select — kept for applyFilters compatibility %>
            <select id="house-filter" style="display:none;" onchange="applyFilters()">
              <option value="">All Houses</option>
            </select>
          </div>

          <div class="profanity-toggle-group" style="margin-top: 0.5rem;">
            <span class="profanity-label">Profanity:</span>
            <span class="profanity-info-icon" tabindex="0" aria-label="Info about profanity toggle">
                ⓘ
                <span class="profanity-tooltip">Toggles visibility of profane language in custom room names and notes. Some submissions contain adult language — this filter hides that content by default.</span>
            </span>
            <label class="toggle-switch">
              <input type="checkbox" id="censor-toggle" onchange="toggleCensorship()">
              <span class="toggle-slider"></span>
            </label>
          </div>
        </div>

        <!-- Extended filter bar (floor, room type tags, has review, active tag chips) -->
        <div class="room-filters" id="room-filters">
            <label>
                Floor:
                <select id="filter-floor">
                    <option value="">All</option>
                    <% const allFloors = [...new Set(rooms.map(r => r.floor).filter(Boolean))].sort((a,b)=>{ const na=parseFloat(a),nb=parseFloat(b); return isNaN(na)||isNaN(nb)?String(a).localeCompare(String(b)):na-nb; }); %>
                    <% allFloors.forEach(f => { %>
                        <option value="<%= f %>"><%= f %></option>
                    <% }) %>
                </select>
            </label>

            <!-- Room Type: clickable tag buttons -->
            <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
                <span style="font-size:0.85rem; font-weight:600; color:var(--text-secondary);">Room Type:</span>
                <div class="roomtype-tag-filters" id="roomtype-tag-filters">
                    <% const allRoomTypes = [...new Set(rooms.map(r => r.roomType).filter(Boolean))].sort(); %>
                    <% allRoomTypes.forEach(t => { %>
                        <button type="button" class="roomtype-tag-btn" data-roomtype="<%= t %>"><%= t %></button>
                    <% }) %>
                </div>
            </div>

            <label>
                <input type="checkbox" id="filter-hasreview">
                Has Review
            </label>

            <!-- Active tag filter chips -->
            <div class="active-tag-chips" id="active-tag-chips" style="display:none;"></div>

            <button type="button" class="filter-clear-btn" id="filter-clear-btn">Clear filters</button>
        </div>

        <!-- Stats Section -->
        <div class="top-stats-grid" style="margin-bottom: 2rem;">

        <div class="table-container">
          <table id="rooms-table">
            <thead>
              <tr>
                <th class="sortable" data-sort-key="name" style="width: 200px;">ROOM <span class="sort-indicator"></span></th>
                <th class="sortable" data-sort-key="dorm">Dorm <span class="sort-indicator"></span></th>
                <th class="sortable" data-sort-key="house">House <span class="sort-indicator"></span></th>
                <th class="sortable" data-sort-key="floor">Floor <span class="sort-indicator"></span></th>
                <th class="sortable" data-sort-key="roomtype">Type <span class="sort-indicator"></span></th>
                <th>Tags</th>
                <th class="sortable" data-sort-key="culture">Culture <span class="sort-indicator"></span></th>
                <th class="sortable" data-sort-key="noise">Noise <span class="sort-indicator"></span></th>
              </tr>
            </thead>
            <tbody id="rooms-body">
              <% rooms.forEach(room=> { %>
                <%
                  const hasReviewR = !!(room.houseCultureVal || room.customName || room.tags);
                  const displayNameR = room.customName ? room.customName : (room.house + ' ' + room.roomNumber);
                %>
                <tr style="cursor:pointer;"
                  data-dorm="<%= room.dorm %>"
                  data-house="<%= room.house %>"
                  data-floor="<%= room.floor || '' %>"
                  data-roomtype="<%= room.roomType || '' %>"
                  data-hasreview="<%= hasReviewR ? '1' : '0' %>"
                  data-name="<%= displayNameR %>"
                  data-tags="<%= room.tags || '' %>"
                  data-culture="<%= room.houseCultureVal || '' %>"
                  data-noise="<%= room.outsideNoiseVal || '' %>"
                  data-roomnumber="<%= parseInt(room.roomNumber) || 0 %>"
                  onclick="window.location='/rooms/<%= room.id %>'">

                  <td data-label="Room" style="font-weight: 600; font-size: 1.05em;">
                    <% if (room.customName) { %>
                      <div>
                        <span class="room-name" data-original="<%= room.customName %>" style="color:#800000;">
                          <%= room.customName %>
                        </span>
                        <div style="font-size:0.75em; font-style:italic; font-weight: 400; color: var(--text-secondary); margin-top: 0.15rem;">
                          (<%= room.house %> <%= room.roomNumber %>)
                        </div>
                      </div>
                    <% } else { %>
                      <span class="room-name" data-original="<%= room.house %> <%= room.roomNumber %>">
                        <%= room.house %> <%= room.roomNumber %>
                      </span>
                    <% } %>
                  </td>

                  <td data-label="Dorm"><%= room.dorm %></td>

                  <td data-label="House"><%= room.house || '\u2014' %></td>

                  <td data-label="Floor"><%= room.floor || '\u2014' %></td>

                  <td data-label="Type">
                    <% if (room.roomType) { %>
                      <span style="display:inline-block; padding:0.2em 0.6em; border-radius:0.4rem; font-size:0.78rem; font-weight:600;
                        background: <%= room.roomType && room.roomType.toLowerCase().includes('double') ? '#dbeafe' : room.roomType && room.roomType.toLowerCase().includes('suite') ? '#f3e8ff' : '#f3f4f6' %>;
                        color: <%= room.roomType && room.roomType.toLowerCase().includes('double') ? '#1d4ed8' : room.roomType && room.roomType.toLowerCase().includes('suite') ? '#7c3aed' : '#374151' %>;"
                      ><%= room.roomType %></span>
                    <% } else { %>
                      <span style="color:#ccc; font-size:0.85rem;">&mdash;</span>
                    <% } %>
                  </td>

                  <% const getTagEmojiR=(tag)=>{
                    const tl = tag.toLowerCase();
                    if (tl.includes('sunny') || tl.includes('light') || tl.includes('bright')) return '\u2600\ufe0f';
                    if (tl.includes('dark') || tl.includes('dim')) return '\ud83c\udf11';
                    if (tl.includes('loud') || tl.includes('noise') || tl.includes('busy')) return '\ud83d\udd0a';
                    if (tl.includes('quiet') || tl.includes('silent')) return '\ud83d\udd07';
                    if (tl.includes('large') || tl.includes('spacious') || tl.includes('big')) return '\ud83c\udff0';
                    if (tl.includes('small') || tl.includes('tiny') || tl.includes('cramped')) return '\ud83d\udce6';
                    if (tl.includes('high ceiling')) return '\ud83c\udfdb\ufe0f';
                    if (tl.includes('low ceiling')) return '\ud83c\udfe0';
                    if (tl.includes('cold') || tl.includes('draft') || tl.includes('freeze')) return '\u2744\ufe0f';
                    if (tl.includes('warm') || tl.includes('hot') || tl.includes('heat')) return '\ud83d\udd25';
                    if (tl.includes('window')) return '\ud83e\ude9f';
                    if (tl.includes('view')) return '\ud83d\udc40';
                    if (tl.includes('bathroom') || tl.includes('toilet')) return '\ud83d\udebd';
                    if (tl.includes('kitchen')) return '\ud83c\udf73';
                    if (tl.includes('ac') || tl.includes('a/c')) return '\ud83d\udca8';
                    return '\ud83c\udff7\ufe0f';
                  }; %>

                  <td data-label="Tags">
                    <% if (room.tags) { %>
                      <div class="tags-container">
                        <% room.tags.split(', ').forEach(t => {
                            var tagSentiment = 'neutral';
                            var tl = t.toLowerCase();
                            if (tl === 'particularly high ceiling' || tl === 'extra storage / closet space' || tl === 'good furniture layout flexibility' || tl === 'particularly big windows' || tl === 'gets good sunlight' || tl === 'notably quiet' || tl === 'good ventilation') tagSentiment = 'positive';
                            else if (tl === 'limited storage / closet space' || tl === 'gets poor sunlight' || tl === 'notable hallway noise' || tl === 'noise from adjacent rooms' || tl === 'noise from above or below' || tl === 'ac/heating issues' || tl === 'poor ventilation') tagSentiment = 'negative';
                            else if (tl === 'particularly small windows' || tl === 'particularly low ceiling' || tl === 'drafty windows' || tl === 'gets very hot' || tl === 'gets very cold' || tl === 'significant radiator noise') tagSentiment = 'mild-negative';
                        %>
                          <span class="tag" data-tag-sentiment="<%= tagSentiment %>" title="<%= t %>" onclick="event.stopPropagation(); addRoomsTagFilter('<%= t.replace(/'/g, "&#39;") %>')">
                            <%= getTagEmojiR(t) %> <%= t %>
                          </span>
                        <% }) %>
                      </div>
                    <% } else { %>
                      <span style="color:#ccc; font-size:0.85rem;">&mdash;</span>
                    <% } %>
                  </td>

                  <td data-label="Culture">
                    <% if (room.houseCultureVal) { %>
                      <%
                        var cultureRounded = Math.round(parseFloat(room.houseCultureVal));
                        var cultureColors = { 5: '#34877A', 4: '#92B89D', 3: '#D69772', 2: '#C27654', 1: '#AE5436' };
                        var cultureBg = cultureColors[cultureRounded] || 'transparent';
                      %>
                      <div style="display:flex; align-items:center; gap:0.4rem;">
                        <span style="display:inline-block; width:2.2em; text-align:center; padding:0.15em 0; border-radius:0.3rem; font-size:0.85rem; font-weight:600; background-color:<%= cultureBg %>; color:#fff;"><%= room.houseCultureVal %></span>
                      </div>
                    <% } else { %><span style="color:#ccc;">&mdash;</span><% } %>
                  </td>

                  <td data-label="Noise">
                    <% if (room.outsideNoiseVal) { %>
                      <%
                        var noiseRounded = Math.round(parseFloat(room.outsideNoiseVal));
                        var noiseColors = { 1: '#34877A', 2: '#92B89D', 3: '#D69772', 4: '#C27654', 5: '#AE5436' };
                        var noiseBg = noiseColors[noiseRounded] || 'transparent';
                      %>
                      <div style="display:flex; align-items:center; gap:0.4rem;">
                        <span style="display:inline-block; width:2.2em; text-align:center; padding:0.15em 0; border-radius:0.3rem; font-size:0.85rem; font-weight:600; background-color:<%= noiseBg %>; color:#fff;"><%= room.outsideNoiseVal %></span>
                      </div>
                    <% } else { %><span style="color:#ccc;">&mdash;</span><% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <p id="no-results" style="display: none; padding: 2rem; text-align: center; color: var(--text-secondary);">No rooms match your filters.</p>
        </div>
      </main>

      <footer>
        <p>&copy; 2025 Room for Improvement</p>
      </footer>

      <!-- Server Data Injection -->
      <script id="dorm-houses-data" type="application/json">
        <%- (typeof dormHousesMapJson !== 'undefined' && dormHousesMapJson) ? dormHousesMapJson : '{}' %>
      </script>
      <script id="all-rooms-data" type="application/json">
        <%- (typeof allRoomsDataJson !== 'undefined' && allRoomsDataJson) ? allRoomsDataJson : '[]' %>
      </script>

      <script>
        let dormHousesMap = {};
        let allRoomsData = [];

        try {
          const dormDataText = document.getElementById('dorm-houses-data').textContent;
          const roomsDataText = document.getElementById('all-rooms-data').textContent;
          if (dormDataText) dormHousesMap = JSON.parse(dormDataText);
          if (roomsDataText) allRoomsData = JSON.parse(roomsDataText);
        } catch (e) {
          console.error("Failed to parse server data", e);
        }

        // ── Dorm / House legacy filter ─────────────────────────────
        function onDormChange(selectedDorm) {
          const houseFilter = document.getElementById("house-filter");
          if (!selectedDorm) {
            houseFilter.innerHTML = '<option value="">All Houses</option>';
            houseFilter.disabled = true;
          } else {
            houseFilter.disabled = false;
            const houses = dormHousesMap[selectedDorm] || [];
            let options = '<option value="">All Houses</option>';
            houses.sort().forEach(h => {
              options += `<option value="${h}">${h}</option>`;
            });
            houseFilter.innerHTML = options;
          }
          houseFilter.value = "";
          applyFilters();
        }

        // ── Room Type Tag Buttons ──────────────────────────────────
        (function() {
          var activeRoomType = '';
          var roomTypeBtns = document.querySelectorAll('#roomtype-tag-filters .roomtype-tag-btn');
          roomTypeBtns.forEach(function(btn) {
            btn.addEventListener('click', function() {
              var val = btn.dataset.roomtype;
              if (activeRoomType === val) {
                activeRoomType = '';
                btn.classList.remove('active');
              } else {
                roomTypeBtns.forEach(function(b) { b.classList.remove('active'); });
                activeRoomType = val;
                btn.classList.add('active');
              }
              window._activeRoomType = activeRoomType;
              applyFilters();
            });
          });
          window._activeRoomType = '';
          window._clearRoomTypeBtns = function() {
            activeRoomType = '';
            window._activeRoomType = '';
            roomTypeBtns.forEach(function(b) { b.classList.remove('active'); });
          };
        })();

        // ── Active Tag Chips ───────────────────────────────────────
        var activeTagFilters = [];
        var chipsContainer = document.getElementById('active-tag-chips');

        window.addRoomsTagFilter = function(tag) {
          if (activeTagFilters.indexOf(tag) !== -1) return;
          activeTagFilters.push(tag);
          renderTagChips();
          applyFilters();
        };

        window.removeRoomsTagFilter = function(tag) {
          var idx = activeTagFilters.indexOf(tag);
          if (idx !== -1) activeTagFilters.splice(idx, 1);
          renderTagChips();
          applyFilters();
        };

        function renderTagChips() {
          if (!chipsContainer) return;
          if (activeTagFilters.length === 0) {
            chipsContainer.style.display = 'none';
            chipsContainer.innerHTML = '';
            return;
          }
          chipsContainer.style.display = 'flex';
          chipsContainer.innerHTML = activeTagFilters.map(function(tag) {
            return '<span class="active-tag-chip">'
              + tag
              + '<span class="chip-remove" title="Remove filter" onclick="removeRoomsTagFilter(\'' + tag.replace(/'/g,"\\'") + '\')">&times;</span></span>';
          }).join('');
        }

        // ── Unified applyFilters ───────────────────────────────────
        // selectedHouseFilters is managed by the house filter dropdown
        var selectedHouseFilters = [];

        function applyFilters() {
          const selectedDorm = document.getElementById("dorm-filter").value;
          const floorSel = document.getElementById("filter-floor");
          const reviewChk = document.getElementById("filter-hasreview");
          const selectedFloor = floorSel ? floorSel.value : '';
          const activeRoomTyp = window._activeRoomType || '';
          const hasReview = reviewChk ? reviewChk.checked : false;

          const rows = document.querySelectorAll("#rooms-body tr");
          let visibleCount = 0;
          const visibleIndices = [];

          rows.forEach((row, index) => {
            const rowDorm = row.getAttribute("data-dorm") || "";
            const rowHouse = row.getAttribute("data-house") || "";
            const rowFloor = row.getAttribute("data-floor") || "";
            const rowType = row.getAttribute("data-roomtype") || "";
            const rowHasReview = row.getAttribute("data-hasreview") || "0";
            const rowTags = (row.getAttribute("data-tags") || "").split(', ').map(s => s.trim().toLowerCase());

            let show = true;
            if (selectedDorm && rowDorm !== selectedDorm) show = false;
            // House filter: if houses are selected, row must match one of them
            if (show && selectedHouseFilters.length > 0) {
              if (selectedHouseFilters.indexOf(rowHouse) === -1) show = false;
            }
            if (show && selectedFloor && rowFloor !== selectedFloor) show = false;
            if (show && activeRoomTyp && rowType !== activeRoomTyp) show = false;
            if (show && hasReview && rowHasReview !== '1') show = false;
            if (show && activeTagFilters.length > 0) {
              const allMatch = activeTagFilters.every(tag => rowTags.indexOf(tag.trim().toLowerCase()) !== -1);
              if (!allMatch) show = false;
            }

            if (show) {
              row.style.display = "";
              visibleCount++;
              visibleIndices.push(index);
            } else {
              row.style.display = "none";
            }
          });

          document.getElementById("no-results").style.display = visibleCount === 0 ? "block" : "none";
          updateStats(visibleIndices);
        }

        // ── Clear Filters ─────────────────────────────────────────
        document.getElementById('filter-clear-btn').addEventListener('click', function() {
          document.getElementById('dorm-filter').value = '';
          const hf = document.getElementById('house-filter');
          hf.innerHTML = '<option value="">All Houses</option>';
          hf.disabled = true;
          // Clear house filter dropdown selections
          selectedHouseFilters = [];
          var hfItems = document.querySelectorAll('#house-filter-dropdown .house-filter-item');
          hfItems.forEach(function(i) { i.classList.remove('selected'); });
          var hfBtn = document.getElementById('house-filter-btn');
          if (hfBtn) hfBtn.textContent = 'Filter by Houses ▾';
          // Show all dorm headers and house items in the house dropdown
          var hfHeaders = document.querySelectorAll('#house-filter-dropdown .house-filter-dorm-header');
          hfHeaders.forEach(function(h) { h.style.display = ''; });
          hfItems.forEach(function(i) { i.style.display = ''; });

          const ff = document.getElementById('filter-floor');
          if (ff) ff.value = '';
          if (window._clearRoomTypeBtns) window._clearRoomTypeBtns();
          const rc = document.getElementById('filter-hasreview');
          if (rc) rc.checked = false;
          activeTagFilters = [];
          renderTagChips();
          applyFilters();
        });
        if (document.getElementById('filter-floor')) {
          document.getElementById('filter-floor').addEventListener('change', applyFilters);
        }
        if (document.getElementById('filter-hasreview')) {
          document.getElementById('filter-hasreview').addEventListener('change', applyFilters);
        }

        // ── Column Sorting ────────────────────────────────────────
        (function() {
          var table = document.getElementById('rooms-table');
          if (!table) return;
          var tbody = table.tBodies[0];
          var currentSort = { key: null, dir: 1 };
          var descFirstKeys = new Set(['culture','noise']);
          var headers = table.querySelectorAll('th.sortable');

          function getAllRows() {
            return Array.prototype.slice.call(tbody.rows);
          }

          function getKey(row, key) {
            var v = row.dataset[key.toLowerCase()] || '';
            if (['culture','noise','roomnumber'].indexOf(key.toLowerCase()) !== -1) {
              var n = parseFloat(v);
              return isNaN(n) ? null : n;
            }
            if (key === 'floor') {
              var fn = parseFloat(v);
              return isNaN(fn) ? v.toLowerCase() : fn;
            }
            return v.toLowerCase();
          }

          function clearIndicators() {
            headers.forEach(function(h) {
              h.classList.remove('sort-asc','sort-desc');
              var ind = h.querySelector('.sort-indicator');
              if (ind) ind.textContent = '';
            });
          }

          function sortBy(key) {
            var dir;
            if (currentSort.key === key) {
              dir = -currentSort.dir;
            } else {
              dir = descFirstKeys.has(key) ? -1 : 1;
            }
            currentSort = { key: key, dir: dir };

            var sorted = getAllRows().sort(function(a, b) {
              var va = getKey(a, key);
              var vb = getKey(b, key);
              var aEmpty = (va === null || va === undefined || va === '');
              var bEmpty = (vb === null || vb === undefined || vb === '');
              if (aEmpty && !bEmpty) return 1;
              if (!aEmpty && bEmpty) return -1;
              if (aEmpty && bEmpty) return 0;
              if (typeof va === 'number' && typeof vb === 'number') return (va - vb) * dir;
              return String(va).localeCompare(String(vb)) * dir;
            });

            sorted.forEach(function(row) { tbody.appendChild(row); });
            clearIndicators();
            var th = table.querySelector('th.sortable[data-sort-key="' + key + '"]');
            if (th) {
              th.classList.add(dir === 1 ? 'sort-asc' : 'sort-desc');
              var ind = th.querySelector('.sort-indicator');
              if (ind) ind.textContent = dir === 1 ? '▲' : '▼';
            }
          }

          headers.forEach(function(h) {
            h.addEventListener('click', function() { sortBy(h.dataset.sortKey); });
          });
        })();

        // ── Stats updater (using JSON data) ───────────────────────
        function updateStats(visibleIndices) {
          const currentRooms = visibleIndices.map(i => allRoomsData[i]);

          function getTop3(rooms, field, sortAscending = false) {
            const grouped = {};
            rooms.forEach(r => {
              if (!r || !r.house) return;
              const val = parseFloat(r[field]);
              if (!isNaN(val)) {
                if (!grouped[r.house]) grouped[r.house] = [];
                grouped[r.house].push(val);
              }
            });
            const results = [];
            for (const h in grouped) {
              const arr = grouped[h];
              const avg = arr.reduce((a, b) => a + b, 0) / arr.length;
              results.push({ houseName: h, avg });
            }
            results.sort((a, b) => sortAscending ? a.avg - b.avg : b.avg - a.avg);
            return results.slice(0, 3);
          }

          const topCulture = getTop3(currentRooms, 'houseCultureVal', false);
          const topNoise = getTop3(currentRooms, 'outsideNoiseVal', true);
          renderList('culture-list', topCulture);
          renderList('noise-list', topNoise);
        }

        function renderList(elementId, items) {
          const el = document.getElementById(elementId);
          if (!el) return;
          if (items.length === 0) {
            el.innerHTML = '<p>No data available.</p>';
            return;
          }
          el.innerHTML = items.map(item =>
            `<li><span>${item.houseName}</span> <span>${item.avg.toFixed(2)}</span></li>`
          ).join('');
        }

        // ── Profanity filter ──────────────────────────────────────
        const badWords = ['damn', 'hell', 'fuck', 'shit', 'ass', 'bitch', 'bastard', 'crap', 'piss', 'cock', 'dick', 'pussy', 'slut', 'whore', 'fag', 'nigger', 'nigga', 'cunt', 'twat'];

        function censorText(text) {
          let censored = text;
          badWords.forEach(word => {
            const regex = new RegExp(word, 'gi');
            censored = censored.replace(regex, (match) => '*'.repeat(match.length));
          });
          return censored;
        }

        function toggleCensorship() {
          const isChecked = document.getElementById('censor-toggle').checked;
          const roomNames = document.querySelectorAll('.room-name');
          roomNames.forEach(name => {
            const original = name.getAttribute('data-original');
            if (original) {
              name.textContent = isChecked ? original : censorText(original);
            }
          });
        }

        document.addEventListener('DOMContentLoaded', function () {
          toggleCensorship();
        });

        // ── Custom Dorm Filter Dropdown (R5) ──────────────────────
        (function() {
          var btn = document.getElementById('dorm-filter-btn');
          var dropdown = document.getElementById('dorm-filter-dropdown');
          var hiddenSelect = document.getElementById('dorm-filter');
          var items = dropdown.querySelectorAll('.dorm-filter-item');
          var selectedDorm = '';

          // Toggle dropdown open/close
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            var isOpen = dropdown.classList.contains('open');
            dropdown.classList.toggle('open');
            btn.classList.toggle('open');
            // Close house dropdown if open
            var houseDropdown = document.getElementById('house-filter-dropdown');
            var houseBtn = document.getElementById('house-filter-btn');
            if (houseDropdown) houseDropdown.classList.remove('open');
            if (houseBtn) houseBtn.classList.remove('open');
          });

          // Click on a dorm item: select or deselect
          items.forEach(function(item) {
            item.addEventListener('click', function(e) {
              e.stopPropagation();
              var dorm = item.getAttribute('data-dorm');

              if (selectedDorm === dorm) {
                // Deselect (click again)
                selectedDorm = '';
                item.classList.remove('selected');
                btn.textContent = 'Filter by Dorm ▾';
              } else {
                // Deselect previous
                items.forEach(function(i) { i.classList.remove('selected'); });
                // Select new
                selectedDorm = dorm;
                item.classList.add('selected');
                btn.textContent = dorm + ' ▾';
              }

              // Sync hidden select and trigger existing filter logic
              hiddenSelect.value = selectedDorm;
              onDormChange(selectedDorm);

              // When dorm filter changes, clear house selections that no longer belong
              // and update house dropdown visibility
              updateHouseDropdownForDorm(selectedDorm);

              // Close dropdown after selection
              dropdown.classList.remove('open');
              btn.classList.remove('open');
            });
          });

          // Close dropdown on outside click
          document.addEventListener('click', function(e) {
            if (!btn.contains(e.target) && !dropdown.contains(e.target)) {
              dropdown.classList.remove('open');
              btn.classList.remove('open');
            }
          });

          // Sync dropdown state when clear-filters resets the hidden select
          var origClearHandler = document.getElementById('filter-clear-btn');
          if (origClearHandler) {
            origClearHandler.addEventListener('click', function() {
              selectedDorm = '';
              items.forEach(function(i) { i.classList.remove('selected'); });
              btn.textContent = 'Filter by Dorm ▾';
            });
          }
        })();

        // ── Custom House Filter Dropdown (R12) ────────────────────
        function updateHouseDropdownForDorm(activeDorm) {
          var houseItems = document.querySelectorAll('#house-filter-dropdown .house-filter-item');
          var dormHeaders = document.querySelectorAll('#house-filter-dropdown .house-filter-dorm-header');

          if (!activeDorm) {
            // No dorm filter — show all houses and headers
            dormHeaders.forEach(function(h) { h.style.display = ''; });
            houseItems.forEach(function(i) { i.style.display = ''; });
          } else {
            // Show only houses within the selected dorm
            dormHeaders.forEach(function(h) {
              h.style.display = h.getAttribute('data-dorm') === activeDorm ? '' : 'none';
            });
            houseItems.forEach(function(i) {
              i.style.display = i.getAttribute('data-dorm') === activeDorm ? '' : 'none';
            });
          }

          // Clear house selections that no longer belong to the selected dorm
          var changed = false;
          for (var idx = selectedHouseFilters.length - 1; idx >= 0; idx--) {
            var house = selectedHouseFilters[idx];
            // Find the item for this house and check its dorm
            var matchItem = document.querySelector('#house-filter-dropdown .house-filter-item[data-house="' + house + '"]');
            if (matchItem) {
              var itemDorm = matchItem.getAttribute('data-dorm');
              if (activeDorm && itemDorm !== activeDorm) {
                matchItem.classList.remove('selected');
                selectedHouseFilters.splice(idx, 1);
                changed = true;
              }
            }
          }

          // Update button text
          var houseBtn = document.getElementById('house-filter-btn');
          if (selectedHouseFilters.length === 0) {
            houseBtn.textContent = 'Filter by Houses ▾';
          } else if (selectedHouseFilters.length === 1) {
            houseBtn.textContent = selectedHouseFilters[0] + ' ▾';
          } else {
            houseBtn.textContent = selectedHouseFilters.length + ' Houses ▾';
          }

          if (changed) applyFilters();
        }

        (function() {
          var btn = document.getElementById('house-filter-btn');
          var dropdown = document.getElementById('house-filter-dropdown');
          var items = dropdown.querySelectorAll('.house-filter-item');

          // Toggle dropdown open/close
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            dropdown.classList.toggle('open');
            btn.classList.toggle('open');
            // Close dorm dropdown if open
            var dormDropdown = document.getElementById('dorm-filter-dropdown');
            var dormBtn = document.getElementById('dorm-filter-btn');
            if (dormDropdown) dormDropdown.classList.remove('open');
            if (dormBtn) dormBtn.classList.remove('open');
          });

          // Click on a house item: toggle selection
          items.forEach(function(item) {
            item.addEventListener('click', function(e) {
              e.stopPropagation();
              var house = item.getAttribute('data-house');

              if (item.classList.contains('selected')) {
                // Deselect
                item.classList.remove('selected');
                var idx = selectedHouseFilters.indexOf(house);
                if (idx !== -1) selectedHouseFilters.splice(idx, 1);
              } else {
                // Select
                item.classList.add('selected');
                selectedHouseFilters.push(house);
              }

              // Update button text
              if (selectedHouseFilters.length === 0) {
                btn.textContent = 'Filter by Houses ▾';
              } else if (selectedHouseFilters.length === 1) {
                btn.textContent = selectedHouseFilters[0] + ' ▾';
              } else {
                btn.textContent = selectedHouseFilters.length + ' Houses ▾';
              }

              applyFilters();
            });
          });

          // Close dropdown on outside click
          document.addEventListener('click', function(e) {
            if (!btn.contains(e.target) && !dropdown.contains(e.target)) {
              dropdown.classList.remove('open');
              btn.classList.remove('open');
            }
          });
        })();
      </script>
  </body>

  </html>