<%- include('partials/head', { title: 'Rooms | Room for Improvement' }) %>

  <body>
    <%- include('partials/nav') %>

      <main style="max-width:1200px; margin:0 auto; padding:2rem 1.5rem;">
        
        <!-- Hero Banner for All Rooms -->
        <div class="house-banner" style="background-color: var(--primary-dark); position: relative; overflow: visible;">
            <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; position:relative; z-index:2; padding: 2.5rem 0;">
                <div style="width:72px; height:72px; border-radius:50%; background:var(--primary-color); display:flex; align-items:center; justify-content:center; box-shadow: 0 4px 16px rgba(0,0,0,0.4); border: 3px solid rgba(255,255,255,0.2); margin-bottom:1rem;">
                    <span style="color:white; font-size:2rem;">🏛️</span>
                </div>
                <h1 style="margin:0; font-size:2.5rem; font-weight:800; text-shadow:0 2px 4px rgba(0,0,0,0.5); color:white; text-align:center;">
                    All Campus Rooms
                </h1>
            </div>
        </div>

        <!-- Inline Stats Row (Campus-wide) -->
        <div class="house-stats-row" style="display:flex; align-items:center; justify-content:space-between; flex-wrap:nowrap; overflow-x:auto;">
            <% const ratedRooms = rooms.filter(r => r.houseCultureVal || r.outsideNoiseVal);
               const cultureRated = rooms.filter(r => r.houseCultureVal);
               const avgCulture = cultureRated.length ? (cultureRated.reduce((s,r) => s + parseFloat(r.houseCultureVal), 0) / cultureRated.length).toFixed(1) : null;
               const noiseRated = rooms.filter(r => r.outsideNoiseVal);
               const avgNoise = noiseRated.length ? (noiseRated.reduce((s,r) => s + parseFloat(r.outsideNoiseVal), 0) / noiseRated.length).toFixed(1) : null;
            %>
            <div style="display:flex; gap:1rem; flex-wrap:nowrap; align-items:center;">
                <div class="house-stat-mini">
                    <span class="house-stat-val" style="color:var(--text-primary);"><%= rooms.length %></span>
                    <span class="house-stat-lbl">Total Rooms</span>
                </div>
                <div class="house-stat-mini" style="border-left:1px solid var(--border-color); padding-left:1rem;">
                    <span class="house-stat-val" style="color:var(--accent-color);"><%= ratedRooms.length > 0 ? ratedRooms.length : '—' %></span>
                    <span class="house-stat-lbl">Reviews</span>
                </div>
                <% if (avgCulture !== null) { %>
                <div class="house-stat-mini" style="border-left:1px solid var(--border-color); padding-left:1rem;">
                    <span class="house-stat-val" style="color:var(--success-color);"><%= avgCulture %>/5</span>
                    <span class="house-stat-lbl">Avg Culture</span>
                </div>
                <% } %>
                <% if (avgNoise !== null) { %>
                <div class="house-stat-mini" style="border-left:1px solid var(--border-color); padding-left:1rem;">
                    <span class="house-stat-val" style="color:var(--error-color);"><%= avgNoise %>/5</span>
                    <span class="house-stat-lbl">Avg Noise</span>
                </div>
                <% } %>
            </div>
            
            <form method="GET" action="/rooms" style="display: flex; gap: 0.5rem; margin: 0; align-items: center; padding-left: 1rem; border-left: 1px solid var(--border-color); margin-left: auto;">
                <input type="text" name="q" value="<%= query %>" placeholder="Search..." style="width: 200px; padding: 0.5rem 1rem; border-radius: 2rem; border: 1px solid var(--border-color);" />
                <button type="submit" style="padding: 0.5rem 1rem; border-radius: 2rem;" class="btn-primary">Search</button>
            </form>
        </div>

        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; margin-top: 1.5rem; padding: 0 0.5rem;">
            <!-- Filters -->
          <div class="stat-card">
            <h3>🏆 Best House Culture (Higher is Better)</h3>
            <ol class="stat-list" id="culture-list">
              <% if (topHousesCulture && topHousesCulture.length> 0) { %>
                <% topHousesCulture.forEach(h=> { %>
                  <li><span>
                      <%= h.houseName %>
                    </span> <span>
                      <%= h.avg.toFixed(2) %>
                    </span></li>
                  <% }) %>
                    <% } else { %>
                      <p>No data available.</p>
                      <% } %>
            </ol>
          </div>

          <div class="stat-card" style="border-left-color: var(--secondary-color);">
            <h3>🔇 Quietest Houses (Lower is Better)</h3>
            <ol class="stat-list" id="noise-list">
              <% if (topHousesNoise && topHousesNoise.length> 0) { %>
                <% topHousesNoise.forEach(h=> { %>
                  <li><span>
                      <%= h.houseName %>
                    </span> <span>
                      <%= h.avg.toFixed(2) %>
                    </span></li>
                  <% }) %>
                    <% } else { %>
                      <p>No data available.</p>
                      <% } %>
            </ol>
          </div>
        </div>

        <!-- Filters -->
        <div class="filters"
          style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;">
          <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
            <div>
              <label for="dorm-filter" style="margin-bottom: 0.25rem; font-size: 0.85rem;">Filter by Dorm</label>
              <%# Dorm values must match exactly what Building Name contains in colored_rooms.csv %>
              <%# To revert to legacy (rooms.csv) data, set USE_FLOORPLAN_CSV=false in server.js %>
              <select id="dorm-filter" onchange="onDormChange(this.value)">
                <option value="">All Dorms</option>
                <option value="Burton-Judson">Burton-Judson</option>
                <option value="I-House">I-House</option>
                <option value="Max Palevsky">Max Palevsky</option>
                <option value="Renee_Granville-Grossman">Renee Granville-Grossman</option>
                <option value="Snell_Hitchcock">Snell-Hitchcock</option>
                <option value="Woodlawn">Woodlawn</option>
              </select>
            </div>

            <div>
              <label for="house-filter" style="margin-bottom: 0.25rem; font-size: 0.85rem;">Filter by House</label>
              <select id="house-filter" onchange="applyFilters()" disabled>
                <option value="">All Houses</option>
              </select>
            </div>
          </div>

          <div style="display: flex; align-items: center; gap: 0.5rem; margin-top: 0.5rem;">
            <span style="font-size: 1.3rem; cursor: help;" title="Toggle content filter">🔞</span>
            <label class="toggle-switch">
              <input type="checkbox" id="censor-toggle" onchange="toggleCensorship()">
              <span class="toggle-slider"></span>
            </label>
          </div>
        </div>
        
        <!-- Stats Section -->
        <div class="top-stats-grid" style="margin-bottom: 2rem;">

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th style="width: 200px;">ROOM</th>
                <th>Dorm</th>
                <th>Tags</th>
                <th>Culture</th>
                <th>Noise</th>
              </tr>
            </thead>
            <tbody id="rooms-body">
              <% rooms.forEach(room=> { %>
                <tr style="cursor:pointer;" data-dorm="<%= room.dorm %>" data-house="<%= room.house %>"
                  data-room-number="<%= room.roomNumber %>" onclick="window.location='/rooms/<%= room.id %>'">

                  <td style="font-weight: 600; font-size: 1.05em;">
                    <% if (room.customName) { %>
                      <div>
                        <span class="room-name" data-original="<%= room.customName %>" style="color:#800000;">
                          <%= room.customName %>
                        </span>
                        <div
                          style="font-size:0.75em; font-style:italic; font-weight: 400; color: var(--text-secondary); margin-top: 0.15rem;">
                          (<%= room.house %> <%= room.roomNumber %>)
                        </div>
                      </div>
                      <% } else { %>
                        <span class="room-name" data-original="<%= room.house %> <%= room.roomNumber %>">
                          <%= room.house %>
                            <%= room.roomNumber %>
                        </span>
                        <% } %>
                  </td>

                  <td>
                    <%= room.dorm %>
                  </td>

                  <% const getTagEmoji=(tag)=> {
                    const t = tag.toLowerCase();
                    if (t.includes('sunny') || t.includes('light') || t.includes('bright')) return '☀️';
                    if (t.includes('dark') || t.includes('dim')) return '🌑';
                    if (t.includes('loud') || t.includes('noise') || t.includes('busy')) return '🔊';
                    if (t.includes('quiet') || t.includes('silent')) return '🔇';
                    if (t.includes('large') || t.includes('spacious') || t.includes('big')) return '🏰';
                    if (t.includes('small') || t.includes('tiny') || t.includes('cramped')) return '📦';
                    if (t.includes('high ceiling')) return '🏛️';
                    if (t.includes('low ceiling')) return '🏠';
                    if (t.includes('cold') || t.includes('draft') || t.includes('freeze')) return '❄️';
                    if (t.includes('warm') || t.includes('hot') || t.includes('heat')) return '🔥';
                    if (t.includes('window')) return '🪟';
                    if (t.includes('view')) return '👀';
                    if (t.includes('bathroom') || t.includes('toilet')) return '🚽';
                    if (t.includes('kitchen')) return '🍳';
                    if (t.includes('ac') || t.includes('a/c')) return '💨';
                    return '🏷️';
                    };
                    %>

                    <td>
                      <% if (room.tags) { %>
                        <div class="tags-container">
                          <% room.tags.split(', ').forEach(t => { %>
                              <span class="tag" title="<%= t %>"><%= getTagEmoji(t) %> <%= t %></span>
                          <% }) %>
                      </div>
                    <% } %>
                </td>
                
                <td><%= room.houseCultureVal ? room.houseCultureVal : ' -' %>
                    </td>
                    <td>
                      <%= room.outsideNoiseVal ? room.outsideNoiseVal : '-' %>
                    </td>
                </tr>
                <% }) %>
            </tbody>
          </table>
          <p id="no-results" style="display: none; padding: 2rem; text-align: center; color: var(--text-secondary);">No
            rooms match your filters.</p>
        </div>
      </main>

      <footer>
        <p>&copy; 2025 Room for Improvement</p>
      </footer>

      <!-- Server Data Injection -->
      <script id="dorm-houses-data" type="application/json">
        <%- (typeof dormHousesMapJson !== 'undefined' && dormHousesMapJson) ? dormHousesMapJson : '{}' %>
      </script>
      <script id="all-rooms-data" type="application/json">
        <%- (typeof allRoomsDataJson !== 'undefined' && allRoomsDataJson) ? allRoomsDataJson : '[]' %>
      </script>

      <script>
        let dormHousesMap = {};
        let allRoomsData = [];

        try {
          const dormDataText = document.getElementById('dorm-houses-data').textContent;
          const roomsDataText = document.getElementById('all-rooms-data').textContent;
          if (dormDataText) dormHousesMap = JSON.parse(dormDataText);
          if (roomsDataText) allRoomsData = JSON.parse(roomsDataText);
        } catch (e) {
          console.error("Failed to parse server data", e);
        }

        function onDormChange(selectedDorm) {
          const houseFilter = document.getElementById("house-filter");

          // Populate houses
          if (!selectedDorm) {
            houseFilter.innerHTML = '<option value="">All Houses</option>';
            houseFilter.disabled = true;
          } else {
            houseFilter.disabled = false;
            const houses = dormHousesMap[selectedDorm] || [];
            let options = '<option value="">All Houses</option>';
            houses.sort().forEach(h => {
              options += `<option value="${h}">${h}</option>`;
            });
            houseFilter.innerHTML = options;
          }
          // Reset house selection
          houseFilter.value = "";

          applyFilters();
        }

        function applyFilters() {
          const selectedDorm = document.getElementById("dorm-filter").value;
          const selectedHouse = document.getElementById("house-filter").value;
          const rows = document.querySelectorAll("#rooms-body tr");
          let visibleCount = 0;

          // Filter logic
          const visibleIndices = [];

          rows.forEach((row, index) => {
            const rowDorm = row.getAttribute("data-dorm") || "";
            const rowHouse = row.getAttribute("data-house") || "";

            let show = true;
            if (selectedDorm && rowDorm !== selectedDorm) show = false;
            // Only check house if show is still true
            if (show && selectedHouse && rowHouse !== selectedHouse) show = false;

            if (show) {
              row.style.display = "";
              visibleCount++;
              visibleIndices.push(index);
            } else {
              row.style.display = "none";
            }
          });

          // Show/Hide no results message
          document.getElementById("no-results").style.display = visibleCount === 0 ? "block" : "none";

          // Recalculate Stats based on visible rooms
          updateStats(visibleIndices);
        }

        function updateStats(visibleIndices) {
          // Filter the data array based on visible indices
          const currentRooms = visibleIndices.map(i => allRoomsData[i]);

          // Helper to compute stats
          function getTop3(rooms, field, sortAscending = false) {
            const grouped = {}; // { HouseName: [val1, val2] }

            rooms.forEach(r => {
              if (!r.house) return;
              const val = parseFloat(r[field]);
              if (!isNaN(val)) {
                if (!grouped[r.house]) grouped[r.house] = [];
                grouped[r.house].push(val);
              }
            });

            const results = [];
            for (const h in grouped) {
              const arr = grouped[h];
              const avg = arr.reduce((a, b) => a + b, 0) / arr.length;
              results.push({ houseName: h, avg });
            }

            results.sort((a, b) => sortAscending ? a.avg - b.avg : b.avg - a.avg);
            return results.slice(0, 3);
          }

          const topCulture = getTop3(currentRooms, 'houseCultureVal', false); // Descending (Higher is better)
          const topNoise = getTop3(currentRooms, 'outsideNoiseVal', true); // Ascending (Lower is better)

          // Render Lists
          renderList('culture-list', topCulture);
          renderList('noise-list', topNoise);
        }

        function renderList(elementId, items) {
          const el = document.getElementById(elementId);
          if (items.length === 0) {
            el.innerHTML = '<p>No data available.</p>';
            return;
          }
          el.innerHTML = items.map(item =>
            `<li><span>${item.houseName}</span> <span>${item.avg.toFixed(2)}</span></li>`
          ).join('');
        }

        // Profanity filter - common inappropriate words
        const badWords = ['damn', 'hell', 'fuck', 'shit', 'ass', 'bitch', 'bastard', 'crap', 'piss', 'cock', 'dick', 'pussy', 'slut', 'whore', 'fag', 'nigger', 'nigga', 'cunt', 'twat'];

        function censorText(text) {
          let censored = text;
          const lowerText = text.toLowerCase();

          badWords.forEach(word => {
            const regex = new RegExp(word, 'gi');
            censored = censored.replace(regex, (match) => {
              return '*'.repeat(match.length);
            });
          });

          return censored;
        }

        function toggleCensorship() {
          const isChecked = document.getElementById('censor-toggle').checked;
          const roomNames = document.querySelectorAll('.room-name');

          roomNames.forEach(name => {
            const original = name.getAttribute('data-original');
            if (original) {
              if (isChecked) {
                // Show original
                name.textContent = original;
              } else {
                // Apply censorship
                name.textContent = censorText(original);
              }
            }
          });
        }

        // Apply censorship on page load (default state is censored)
        document.addEventListener('DOMContentLoaded', function () {
          toggleCensorship();
        });
      </script>
  </body>

  </html>