            // Thin light-gray strips representing major pedestrian walkways.
            const SIDEWALKS = [
                // Main Quad diagonal paths (NW-SE and NE-SW)
                { name: 'Quad Path NW-SE',
                  points: [
                    { lat: 41.7908, lng: -87.6010 },
                    { lat: 41.7882, lng: -87.5980 }
                  ], width: 3 },
                { name: 'Quad Path NE-SW',
                  points: [
                    { lat: 41.7908, lng: -87.5980 },
                    { lat: 41.7882, lng: -87.6010 }
                  ], width: 3 },
                // Main Quad N-S center path
                { name: 'Quad Center N-S',
                  points: [
                    { lat: 41.7908, lng: -87.5995 },
                    { lat: 41.7882, lng: -87.5995 }
                  ], width: 3 },
                // Main Quad E-W center path
                { name: 'Quad Center E-W',
                  points: [
                    { lat: 41.7895, lng: -87.6010 },
                    { lat: 41.7895, lng: -87.5980 }
                  ], width: 3 },
                // 57th St campus walk (between Regenstein and Bartlett)
                { name: '57th Walk',
                  points: [
                    { lat: 41.7920, lng: -87.6030 },
                    { lat: 41.7920, lng: -87.5960 }
                  ], width: 4 },
                // Ellis Ave campus walk (west side of quads)
                { name: 'Ellis Walk',
                  points: [
                    { lat: 41.7875, lng: -87.6010 },
                    { lat: 41.7940, lng: -87.6010 }
                  ], width: 3 },
                // University Ave campus walk
                { name: 'University Walk',
                  points: [
                    { lat: 41.7875, lng: -87.5985 },
                    { lat: 41.7940, lng: -87.5985 }
                  ], width: 3 },
                // Woodlawn Ave campus walk
                { name: 'Woodlawn Walk',
                  points: [
                    { lat: 41.7875, lng: -87.5960 },
                    { lat: 41.7940, lng: -87.5960 }
                  ], width: 3 },
                // South campus E-W path (between BJ and RGG)
                { name: 'South Campus Walk',
                  points: [
                    { lat: 41.7850, lng: -87.6010 },
                    { lat: 41.7850, lng: -87.5960 }
                  ], width: 3 },
                // Midway N edge path
                { name: 'Midway North Walk',
                  points: [
                    { lat: 41.7838, lng: -87.6040 },
