                      { lat: 41.788635494,  lng: -87.5968907489, w: 12.6, d: 15.6, h: 61.0 }
                  ] },

                // ── Precise-footprint landmarks (extruded from ArcGIS polygons) ──
                // category: 'museum' | 'other' — drives the extrusion fill color.
                // label text is shown once per building even for multi-part ones.
                { type: 'building', name: 'Court Theatre',
                  footprintId: 'court_theatre', category: 'museum',
                  label: 'Court Theatre' },

                { type: 'building', name: 'Smart Museum',
                  footprintId: 'smart_museum', category: 'museum',
                  label: 'Smart Museum' },

                { type: 'building', name: 'Institute for the Study of Ancient Cultures',
                  footprintId: 'isac', category: 'museum',
                  label: 'Institute for the Study of Ancient Cultures' },

                { type: 'building', name: 'Robie House',
                  footprintId: 'robie_house', category: 'museum',
                  label: 'Robie House' },

                { type: 'building', name: 'Hutchinson Commons',
                  footprintId: 'hutchinson_commons', category: 'other',
                  label: 'Hutchinson Commons' },

                { type: 'building', name: 'Harper Center',
                  footprintId: 'harper_center', category: 'other',
                  label: 'Harper Center' },

                { type: 'building', name: 'Bond Chapel',
                  footprintId: 'bond_chapel', category: 'other',
                  label: 'Bond Chapel' },

                { type: 'building', name: 'Saieh Hall',
                  footprintId: 'saieh_hall', category: 'other',
                  label: 'Saieh Hall' },

                // These landmark buildings previously had the road drawn on
                // top of them (or their cuboid wasn't accurate). Use the
                // precise footprint polygon so the road/building stop clipping.
                { type: 'building', name: 'Eckhart Hall',
                  footprintId: 'eckhart_hall', category: 'other',
                  label: 'Eckhart Hall' },

                { type: 'building', name: 'Bartlett Commons',
                  footprintId: 'bartlett_commons', category: 'other',
                  label: 'Bartlett' },

                { type: 'building', name: 'Ratner Athletics Center',
                  footprintId: 'ratner', category: 'other',
                  label: 'Ratner' },

                { type: 'building', name: 'John Crerar Library',
                  footprintId: 'crerar', category: 'other',
                  label: 'Crerar' }
            ];

            // ── Three.js scene setup ────────────────────────────────────────
            const wrap = document.getElementById('campus-3d-canvas-wrap');
            const canvas = document.getElementById('campus-3d-canvas');

            const scene = new THREE.Scene();
            scene.background = new THREE.Color('#e7eee0');
            // No fog: the user requested everything stay clearly visible.

            // Camera is fully locked: no user-driven pan/zoom/orbit. The
            // initial pose fits all dorms, recomputed on resize. Selecting
            // a dorm smoothly zooms in (no orbiting around the building).
            const CAMERA_FOV = 45;
            const camera = new THREE.PerspectiveCamera(CAMERA_FOV, 1, 1, 4000);
            camera.up.set(0, 1, 0);

            const overviewTarget = new THREE.Vector3(0, 0, 0);
            let overviewDistance = 700;
            const VIEW_PITCH = Math.PI * 0.32;
            const OVERVIEW_YAW = 0;
            let cameraTarget = new THREE.Vector3(0, 0, 0);
            let cameraDistance = 700;
            let cameraYaw = OVERVIEW_YAW;
            let cameraPitch = VIEW_PITCH;
            let focusTargetVec = new THREE.Vector3();
            let focusDistance = overviewDistance;
            let focusing = false;

            // hoverZoomOffset is declared near the animate loop below;
            // applyCameraPose reads it to apply a subtle pull-in on hover.
            let hoverZoomOffset = 0;

            // Hover yaw state — on hover the camera rotates to face the dorm,
            // Hover look-at state — on hover the camera keeps its position
            // but rotates to face the dorm. On exit it eases back to normal.
            const hoverLookAtCurrent = new THREE.Vector3(); // current interpolated look-at point
            let   hoverLookAtActive  = false;               // true while hover look-at is in effect

            // Kept for clearSelection / setOverviewPose compatibility
            const hoverTargetVec  = new THREE.Vector3();
            let   hoverTargetActive = false;

            function applyCameraPose() {
                const yaw = cameraYaw;
                const cosP = Math.cos(cameraPitch);
                const sinP = Math.sin(cameraPitch);
                const dist = cameraDistance + hoverZoomOffset;
                const dx = Math.sin(yaw) * cosP * dist;
                const dz = Math.cos(yaw) * cosP * dist;
                const dy = sinP * dist;
                camera.position.set(
                    cameraTarget.x + dx,
                    cameraTarget.y + dy,
                    cameraTarget.z + dz
                );
                camera.up.set(0, 1, 0);
                // During hover, look toward the dorm instead of cameraTarget
                if (hoverLookAtActive) {
                    camera.lookAt(hoverLookAtCurrent);
                } else {
                    camera.lookAt(cameraTarget);
                }
            }

            const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            renderer.shadowMap.enabled = true;
            renderer.shadowMap.type = THREE.PCFSoftShadowMap;

            const ambient = new THREE.AmbientLight(0xffffff, 0.6);
            scene.add(ambient);
            const sun = new THREE.DirectionalLight(0xffffff, 0.95);
            sun.position.set(220, 380, 160);
            sun.castShadow = true;
            sun.shadow.mapSize.set(1024, 1024);
            sun.shadow.camera.left = -500;
            sun.shadow.camera.right = 500;
            sun.shadow.camera.top = 500;
            sun.shadow.camera.bottom = -500;
            sun.shadow.camera.near = 1;
            sun.shadow.camera.far = 1500;
            scene.add(sun);

            const ground = new THREE.Mesh(
                new THREE.PlaneGeometry(2000, 2000),
                new THREE.MeshLambertMaterial({ color: 0xdfe6d6 })
            );
            ground.rotation.x = -Math.PI / 2;
            ground.receiveShadow = true;
            scene.add(ground);

            const grid = new THREE.GridHelper(1600, 32, 0xc4cfb6, 0xd6decc);
            grid.position.y = 0.05;
            grid.material.opacity = 0.45;
            grid.material.transparent = true;
            scene.add(grid);

            // ── Render roads ────────────────────────────────────────────────
            const ROAD_COLOR = 0x9e9e9e;
            const ROAD_MAT = new THREE.MeshLambertMaterial({ color: ROAD_COLOR });
            ROADS.forEach(rd => {
                if (rd.lat !== undefined) {
                    // East-West road
                    const p1 = latLngToXZ(rd.lat, rd.lngStart);
                    const p2 = latLngToXZ(rd.lat, rd.lngEnd);
                    const length = Math.abs(p2.x - p1.x);
                    const cx = (p1.x + p2.x) / 2;
                    const cz = p1.z;
                    const mesh = new THREE.Mesh(
                        new THREE.BoxGeometry(length, 0.15, rd.width),
                        ROAD_MAT
                    );
                    mesh.position.set(cx, 0.08, cz);
                    mesh.receiveShadow = true;
                    scene.add(mesh);
                } else {
                    // North-South road
                    const p1 = latLngToXZ(rd.latStart, rd.lng);
                    const p2 = latLngToXZ(rd.latEnd, rd.lng);
                    const length = Math.abs(p2.z - p1.z);
                    const cx = p1.x;
                    const cz = (p1.z + p2.z) / 2;
                    const mesh = new THREE.Mesh(
                        new THREE.BoxGeometry(rd.width, 0.15, length),
                        ROAD_MAT
                    );
                    mesh.position.set(cx, 0.08, cz);
                    mesh.receiveShadow = true;
                    scene.add(mesh);
                }
            });

            // ── Render sidewalks / campus paths ─────────────────────────────
            const SIDEWALK_MAT = new THREE.MeshLambertMaterial({ color: 0xc8c0b0 });
            SIDEWALKS.forEach(sw => {
                const pts = sw.points;
                if (pts.length < 2) return;
                const p0 = latLngToXZ(pts[0].lat, pts[0].lng);
                const p1 = latLngToXZ(pts[1].lat, pts[1].lng);
                const dx = p1.x - p0.x;
                const dz = p1.z - p0.z;
                const length = Math.sqrt(dx * dx + dz * dz);
                const angle = Math.atan2(dx, dz);
                const mesh = new THREE.Mesh(
                    new THREE.BoxGeometry(sw.width, 0.12, length),
                    SIDEWALK_MAT
                );
                mesh.position.set((p0.x + p1.x) / 2, 0.12, (p0.z + p1.z) / 2);
                mesh.rotation.y = angle;
                mesh.receiveShadow = true;
                scene.add(mesh);
            });

            // 3D north arrow removed — replaced by a 2D compass in the UI overlay.

            // ── Render quad (green grass patch) ─────────────────────────────
            LANDMARKS.filter(l => l.type === 'quad').forEach(q => {
                const pos = latLngToXZ(q.lat, q.lng);
                const grass = new THREE.Mesh(
                    new THREE.BoxGeometry(q.w, q.h, q.d),
                    new THREE.MeshLambertMaterial({ color: 0x7fb37f })
                );
                grass.position.set(pos.x, q.h / 2, pos.z);
                grass.receiveShadow = true;
                scene.add(grass);
                const lbl = makeTextSprite(q.name, { color: '#2f5d2f', fontSize: 48, weight: 700, bg: 'rgba(255,255,255,0.7)' });
                lbl.position.set(pos.x, 6, pos.z);
                const qAspect = lbl.userData.canvasWidth / lbl.userData.canvasHeight;
                const LABEL_H = 36;
                lbl.scale.set(LABEL_H * qAspect, LABEL_H, 1);
                scene.add(lbl);
            })();

            // ── Footprint extrusion helpers ─────────────────────────────────
            // Convert a polygon footprint (lon/lat outer ring + holes) into a
            // single THREE.ExtrudeGeometry whose vertical axis is Y. Heights
            // are in meters. ArcGIS rings: outer = CW (signed area > 0),
            // holes = CCW (signed area < 0). THREE.Shape expects outer in
            // either winding and holes via Shape.holes, with vertices given
            // in 2D (x, z); we emit them in scene-X / scene-Z (which we then
            // rotate to lay flat on the ground).
            const FT_TO_M = 0.3048;
            // Default extrusion height for any unknown / zero-height footprint
            const DEFAULT_HEIGHT_M = 30 * FT_TO_M;

            function ringSignedArea(ring) {
                let s = 0;
                for (let i = 0; i < ring.length - 1; i++) {
                    const [x1, y1] = ring[i];
                    const [x2, y2] = ring[i + 1];
                    s += (x2 - x1) * (y2 + y1);
                }
                return s;
            }

            function buildFootprintMeshes(footprint, material) {
                // Returns { meshes: [Mesh,...], maxTopY, anchor: {x, z} }.
                // One ExtrudeGeometry per part (a part may have holes).
                const meshes = [];
                let maxTopY = 0;
                let centroidX = 0, centroidZ = 0, centroidN = 0;

                footprint.parts.forEach(part => {
                    // Convert lon/lat → scene (x, z)
                    const ringToXZ = ring => ring.map(([lon, lat]) => {
                        const p = latLngToXZ(lat, lon);
                        return [p.x, p.z];
                    });

                    const outerXZ = ringToXZ(part.outer);
                    const holesXZ = (part.holes || []).map(ringToXZ);

                    // Build a THREE.Shape. THREE wants the outline in 2D — we
                    // give it (sceneX, sceneZ) directly. Because three's
                    // ExtrudeGeometry extrudes along +Z (its local) we need
                    // to remap: pass (x, z) as Shape's (x, y) then later rotate
                    // the mesh -90° about X so y-up is correct.
                    const shape = new THREE.Shape();
                    if (outerXZ.length) {
                        shape.moveTo(outerXZ[0][0], outerXZ[0][1]);
                        for (let i = 1; i < outerXZ.length; i++) shape.lineTo(outerXZ[i][0], outerXZ[i][1]);
                        shape.closePath();
                    }
                    holesXZ.forEach(h => {
                        const hole = new THREE.Path();
                        hole.moveTo(h[0][0], h[0][1]);
                        for (let i = 1; i < h.length; i++) hole.lineTo(h[i][0], h[i][1]);
                        hole.closePath();
                        shape.holes.push(hole);
                    });

                    const heightM = (part.height_ft && part.height_ft > 0)
                        ? part.height_ft * FT_TO_M
                        : DEFAULT_HEIGHT_M;

                    const geo = new THREE.ExtrudeGeometry(shape, {
                        depth: heightM,
                        bevelEnabled: false,
                        steps: 1
                    });
                    // Rotate so the polygon lies on the XZ plane and extrudes upward.
                    geo.rotateX(-Math.PI / 2);
                    // After rotateX the mesh sits between y=0 and y=-heightM. Lift it up.
                    geo.translate(0, heightM, 0);

                    const mesh = new THREE.Mesh(geo, material);
                    mesh.castShadow = true;
                    mesh.receiveShadow = true;
                    meshes.push(mesh);

                    if (heightM > maxTopY) maxTopY = heightM;

                    // Vertex average for label anchor (more accurate than
                    // the Lat/Lon attribute for U-shaped polygons because we
                    // weight by ring length).
                    outerXZ.forEach(([x, z]) => { centroidX += x; centroidZ += z; centroidN++; });
                });

                const anchor = centroidN > 0
                    ? { x: centroidX / centroidN, z: centroidZ / centroidN }
                    : { x: 0, z: 0 };
                return { meshes, maxTopY, anchor };
            }

            // ── Render landmark (non-dorm) buildings ────────────────────────
            const LANDMARK_MAT_DEFAULT = new THREE.MeshLambertMaterial({ color: 0xcfcfcf });
            const LANDMARK_MAT_MUSEUM  = new THREE.MeshLambertMaterial({ color: 0xb59ac7 }); // muted violet — "museum"
            const LANDMARK_MAT_OTHER   = new THREE.MeshLambertMaterial({ color: 0xb6c3b0 }); // muted sage — "other"
            function landmarkMaterial(category) {
                if (category === 'museum') return LANDMARK_MAT_MUSEUM;
                if (category === 'other')  return LANDMARK_MAT_OTHER;
                return LANDMARK_MAT_DEFAULT;
            }

            LANDMARKS.filter(l => l.type === 'building').forEach(l => {
                let labelX, labelZ, maxTop = 0;
                const labelText = l.label || l.name;
                const fp = l.footprintId ? FOOTPRINT_BY_ID[l.footprintId] : null;

                if (fp && fp.parts && fp.parts.length) {
                    // Precise extruded polygon path
                    const mat = landmarkMaterial(l.category);
                    const { meshes, maxTopY, anchor } = buildFootprintMeshes(fp, mat);
                    meshes.forEach(m => {
                        m.userData = { kind: 'landmark', name: l.name };
                        scene.add(m);
                    });
                    maxTop = maxTopY;
                    labelX = anchor.x;
                    labelZ = anchor.z;
                } else {
                    // Legacy AABB cuboid path
                    const cuboids = (l.parts && l.parts.length) ? l.parts : [{ lat: l.lat, lng: l.lng, w: l.w, d: l.d, h: l.h }];
                    cuboids.forEach(c => {
                        const pos = latLngToXZ(c.lat, c.lng);
                        const mesh = new THREE.Mesh(new THREE.BoxGeometry(c.w, c.h, c.d), LANDMARK_MAT_DEFAULT);
                        mesh.position.set(pos.x, c.h / 2, pos.z);
                        mesh.castShadow = true;
                        mesh.receiveShadow = true;
                        mesh.userData = { kind: 'landmark', name: l.name };
                        scene.add(mesh);
                        if (c.h > maxTop) maxTop = c.h;
                    });
                    const labelPos = latLngToXZ(l.lat, l.lng);
                    labelX = labelPos.x; labelZ = labelPos.z;
                }

                // Single label per landmark, even when multi-part.
                const lbl = makeTextSprite(labelText, { color: '#444', fontSize: 48, weight: 600, bg: 'rgba(255,255,255,0.85)' });
                lbl.position.set(labelX, maxTop + 6, labelZ);
                const lmAspect = lbl.userData.canvasWidth / lbl.userData.canvasHeight;
                const LM_LABEL_H = 36;
                lbl.scale.set(LM_LABEL_H * lmAspect, LM_LABEL_H, 1);
                scene.add(lbl);
            });

            // ── Render dorms ────────────────────────────────────────────────
            // Each dorm gets a 3D cuboid in the scene, but the text label
            // and ranking circle are rendered as 2D HTML elements in a
            // screen-space overlay. This keeps their size and spacing
            // uniform regardless of camera distance.
            //
            // ── CONFIGURABLE LAYOUT KNOBS ───────────────────────────────────
            // Adjust these to change the relative positioning of labels and
            // circles uniformly across ALL dorms.
            const LABEL_PX_ABOVE_ANCHOR = -18;   // px above the projected anchor point for the label
            const CIRCLE_PX_BELOW_LABEL = 2;   // px gap between label bottom and circle top
            // ANCHOR_Y_ABOVE_ROOF is declared above (before the landmark loop)

            // ── CAMERA HORIZONTAL OFFSET (north/south) ──────────────────────
            // Shifts the overview camera target along the Z axis (scene coords).
            // Positive values = south, negative values = north.
            // Tweak this single number to pan the default view north or south.
            const CAMERA_Z_OFFSET = 79;

            const DORM_BASE_COLOR  = new THREE.Color('#7a1f1f');
            const DORM_HOVER_COLOR = new THREE.Color('#a83434');
            const DORM_SELECT_COLOR= new THREE.Color('#d97a2c');
            const dormMeshes = [];
            const dormByName = {};
            // Per-dorm "anchor" world position used by the hover card
            // connector and the 2D label projection.
            const dormAnchor = {};
            // Store references to the 2D overlay elements for each dorm
            const dormOverlayEls = {};

            DORMS.forEach(d => {
                const sharedMat = new THREE.MeshLambertMaterial({ color: DORM_BASE_COLOR.clone() });
                const meshes = [];
                let maxTop = 0;
                let anchorX, anchorZ;

                const fp = d.footprintId ? FOOTPRINT_BY_ID[d.footprintId] : null;
                if (fp && fp.parts && fp.parts.length) {
                    // Extrude the precise polygon footprint(s). Each part gets
                    // its own mesh so tall/short sections render at real heights.
                    const built = buildFootprintMeshes(fp, sharedMat);
                    built.meshes.forEach(mesh => {
                        mesh.rotation.y = d.rotY || 0;
                        mesh.userData = { kind: 'dorm', name: d.name, label: d.label };
                        scene.add(mesh);
                        dormMeshes.push(mesh);
                        meshes.push(mesh);
                    });
                    maxTop = built.maxTopY;
                    anchorX = built.anchor.x;
                    anchorZ = built.anchor.z;
                } else {
                    // Legacy AABB cuboid path
                    const cuboids = (d.parts && d.parts.length) ? d.parts : [{ lat: d.lat, lng: d.lng, w: d.w, d: d.d, h: d.h }];
                    cuboids.forEach(c => {
                        const pos = latLngToXZ(c.lat, c.lng);
                        const mesh = new THREE.Mesh(new THREE.BoxGeometry(c.w, c.h, c.d), sharedMat);
                        mesh.position.set(pos.x, c.h / 2, pos.z);
                        mesh.rotation.y = d.rotY || 0;
                        mesh.castShadow = true;
                        mesh.receiveShadow = true;
                        mesh.userData = { kind: 'dorm', name: d.name, label: d.label };
                        scene.add(mesh);
                        dormMeshes.push(mesh);
                        meshes.push(mesh);
                        if (c.h > maxTop) maxTop = c.h;
                    });
                    const labelPos = latLngToXZ(d.lat, d.lng);
                    anchorX = labelPos.x; anchorZ = labelPos.z;
                }
                dormByName[d.name] = meshes;

                // Anchor point: top of the dorm silhouette + offset
                dormAnchor[d.name] = new THREE.Vector3(anchorX, maxTop + ANCHOR_Y_ABOVE_ROOF, anchorZ);

                // ── Create 2D overlay element for this dorm ─────────────
                const rank = DORM_RANKS.rankByName[d.name];
                const overall = DORM_RANKS.overallByName[d.name];
                const total = DORM_RANKS.total || 0;

                const el = document.createElement('div');
                el.className = 'dorm-label-2d';
                el.style.gap = CIRCLE_PX_BELOW_LABEL + 'px';

                // Text label
                const textEl = document.createElement('div');
                textEl.className = 'dorm-label-2d__text';
                textEl.textContent = d.label;

                // Rank circle
                const circleEl = document.createElement('div');
                circleEl.className = 'dorm-label-2d__circle';
                const circleColor = rank ? rankColor(rank, total) : '#6b6b6b';
                circleEl.style.background = circleColor;
                if (rank) {
                    circleEl.textContent = '#' + rank;
                } else {
                    circleEl.textContent = '?';
                    circleEl.classList.add('dorm-label-2d__circle--unranked');
                }

                el.appendChild(textEl);
                el.appendChild(circleEl);
                labelsOverlay.appendChild(el);

                dormOverlayEls[d.name] = el;
            });

            // ── Connector dot sprite (rendered in 3D scene, behind labels) ──
            // This replaces the SVG circles so that dorm text labels (which
            // have renderOrder: 2) appear on top of the connector dot.
            const connectorDotSprite = (function() {
                const size = 64;
                const c = document.createElement('canvas');
                c.width = size; c.height = size;
                const ctx = c.getContext('2d');
                // Outer ring (white with dark stroke)
                ctx.beginPath();
                ctx.arc(size/2, size/2, size/2 - 4, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(255,255,255,0.92)';
                ctx.fill();
                ctx.lineWidth = 4;
                ctx.strokeStyle = '#1f1f1f';
                ctx.stroke();
                // Inner dot
                ctx.beginPath();
                ctx.arc(size/2, size/2, size * 3/32, 0, Math.PI * 2);
                ctx.fillStyle = '#d97a2c';
                ctx.fill();
                const tex = new THREE.CanvasTexture(c);
                tex.minFilter = THREE.LinearFilter;
                const mat = new THREE.SpriteMaterial({ map: tex, transparent: true, depthTest: false });
                const sprite = new THREE.Sprite(mat);
                sprite.scale.set(24, 24, 1);
                sprite.renderOrder = 1; // behind labels (renderOrder 2), above badges (renderOrder 0)
                sprite.visible = false;
                scene.add(sprite);
                return sprite;
            })();

            // ── Connector circuit-trace line (rendered in 3D scene, behind labels) ──
            // Replaces the old dashed line with an animated circuit-board trace effect.
            // The line connects the dorm anchor (world space) to the hover card edge.
            //
            // We draw the circuit trace as a 2D canvas overlay so we can render
            // the characteristic right-angle "PCB trace" look with animated pulses.
            const circuitCanvas = document.createElement('canvas');
            circuitCanvas.style.cssText = 'position:absolute; inset:0; pointer-events:none; z-index:8;';
            wrap.appendChild(circuitCanvas);

            // Circuit trace state
            let circuitVisible = false;
            let circuitAnchorScreen = null;   // { x, y } in canvas pixels
            let circuitCardEdge = null;        // { x, y } in canvas pixels

            function resizeCircuitCanvas() {
                const r = wrap.getBoundingClientRect();
                circuitCanvas.width  = r.width;
                circuitCanvas.height = r.height;
            }
            resizeCircuitCanvas();
            window.addEventListener('resize', resizeCircuitCanvas);

            // Draw the circuit trace each frame.
            // Shape: PCB-style 45° routing — a short straight run out from the
            // anchor, a 45° diagonal transition, then a straight run into the
            // card edge. No animation, no motion — just a clean static trace.
            function drawCircuitTrace() {
                const ctx = circuitCanvas.getContext('2d');
                ctx.clearRect(0, 0, circuitCanvas.width, circuitCanvas.height);
                if (!circuitVisible || !circuitAnchorScreen || !circuitCardEdge) return;

                const ax = circuitAnchorScreen.x, ay = circuitAnchorScreen.y;
                const bx = circuitCardEdge.x,     by = circuitCardEdge.y;

                // Build a 45°-routed path:
                //   A  →  P1  (short horizontal stub out from anchor)
                //   P1 →  P2  (45° diagonal)
                //   P2 →  B   (vertical run into card edge)
                //
                // The diagonal covers the full vertical delta; the horizontal
                // stub is just enough to clear the building label.
                const STUB = 28;                        // px of horizontal stub at anchor
                const dx = bx > ax ? STUB : -STUB;     // stub direction matches card side
                const dy = by - ay;                     // total vertical travel
                const diagLen = Math.abs(dy);           // 45° means equal horiz + vert

                const p1 = { x: ax + dx,              y: ay };
                const p2 = { x: ax + dx + (bx > ax ? diagLen : -diagLen), y: by };

                // If p2 overshoots bx, clamp and fall back to a simple L
                const pts = (bx > ax ? p2.x <= bx : p2.x >= bx)
                    ? [ { x: ax, y: ay }, p1, p2, { x: bx, y: by } ]
                    : [ { x: ax, y: ay }, { x: bx, y: ay }, { x: bx, y: by } ];

                function drawPath(pts) {
                    ctx.beginPath();
                    ctx.moveTo(pts[0].x, pts[0].y);
                    for (let i = 1; i < pts.length; i++) ctx.lineTo(pts[i].x, pts[i].y);
                    ctx.stroke();
                }

                // ── Glow layer ──
                ctx.save();
                ctx.strokeStyle = 'rgba(255, 255, 255, 0.08)';
                ctx.lineWidth = 6;
                ctx.lineCap = 'square';
                ctx.lineJoin = 'miter';
                drawPath(pts);
                ctx.restore();

                // ── Main trace ──
                ctx.save();
                ctx.strokeStyle = 'rgba(255, 255, 255, 0.70)';
                ctx.lineWidth = 1.5;
                ctx.lineCap = 'square';
                ctx.lineJoin = 'miter';
                drawPath(pts);
                ctx.restore();

                // ── Via pads at each bend (small filled squares) ──
                const PAD = 3;
                ctx.save();
                ctx.fillStyle = 'rgba(255, 255, 255, 0.88)';
                for (let i = 1; i < pts.length - 1; i++) {
                    ctx.fillRect(pts[i].x - PAD, pts[i].y - PAD, PAD * 2, PAD * 2);
                }
                ctx.restore();

                // ── Anchor pad (circle at building end) ──
                ctx.save();
                ctx.beginPath();
                ctx.arc(ax, ay, 3, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(255, 255, 255, 0.88)';
                ctx.fill();
                ctx.restore();
            }

            // No animation — tickCircuitPulse is a no-op kept so the animate
            // loop call doesn't error if referenced elsewhere.
            function tickCircuitPulse(dt) {}

            // Dummy Three.js objects kept so positionConnector() still works
            // (it sets positions on these; we just ignore them for rendering)
            const connectorLineMat = new THREE.LineBasicMaterial({ visible: false });
            const connectorLineGeo = new THREE.BufferGeometry().setFromPoints([
                new THREE.Vector3(0, 0, 0),
                new THREE.Vector3(0, 0, 0)
            ]);
            const connectorLine3D = new THREE.Line(connectorLineGeo, connectorLineMat);
            connectorLine3D.renderOrder = 1;
            connectorLine3D.visible = false;
            connectorLine3D.frustumCulled = false;
            scene.add(connectorLine3D);

            // Helper: unproject a screen-space pixel coordinate to a world-space
            // point on a plane at the same camera-distance as a reference point.
            function screenToWorld(screenX, screenY, refWorldPos) {
                const r = wrap.getBoundingClientRect();
                const ndcX = (screenX / r.width) * 2 - 1;
                const ndcY = -(screenY / r.height) * 2 + 1;
                // Project the reference point to get its NDC z-depth
                const refProj = refWorldPos.clone().project(camera);
                const v = new THREE.Vector3(ndcX, ndcY, refProj.z);
                v.unproject(camera);
                return v;
            }

            // ── Compute the overview camera pose ────────────────────────────
            function computeOverviewPose() {
                let minX = Infinity, maxX = -Infinity, minZ = Infinity, maxZ = -Infinity;
                DORMS.forEach(d => {
                    const fp = d.footprintId ? FOOTPRINT_BY_ID[d.footprintId] : null;
                    if (fp && fp.parts && fp.parts.length) {
                        fp.parts.forEach(part => {
                            part.outer.forEach(([lon, lat]) => {
                                const p = latLngToXZ(lat, lon);
                                if (p.x < minX) minX = p.x;
                                if (p.x > maxX) maxX = p.x;
                                if (p.z < minZ) minZ = p.z;
                                if (p.z > maxZ) maxZ = p.z;
                            });
                        });
                        return;
                    }
                    const cuboids = (d.parts && d.parts.length) ? d.parts : [{ lat: d.lat, lng: d.lng, w: d.w, d: d.d }];
                    cuboids.forEach(c => {
                        const pos = latLngToXZ(c.lat, c.lng);
                        const halfW = c.w / 2;
                        const halfD = c.d / 2;
                        if (pos.x - halfW < minX) minX = pos.x - halfW;
                        if (pos.x + halfW > maxX) maxX = pos.x + halfW;
                        if (pos.z - halfD < minZ) minZ = pos.z - halfD;
                        if (pos.z + halfD > maxZ) maxZ = pos.z + halfD;
                    });
                });
                const cx = (minX + maxX) / 2;
                const cz = (minZ + maxZ) / 2;
                const spanX = Math.max(maxX - minX, 1);
                const spanZ = Math.max(maxZ - minZ, 1);

                const r = wrap.getBoundingClientRect();
                const aspect = r.width / Math.max(r.height, 1);

                const padding = 1.09;
                const vFovRad = CAMERA_FOV * Math.PI / 180;
                const hFovRad = 2 * Math.atan(Math.tan(vFovRad / 2) * aspect);
                const groundY = Math.sin(cameraPitch);
                const distV = (spanZ * groundY * 0.5 * padding) / Math.tan(vFovRad / 2);
                const distH = (spanX * 0.5 * padding) / Math.tan(hFovRad / 2);
                const dist = Math.max(distV, distH, 220);

                // Center on Main Quad (origin 0,0) and shift south (+Z in scene coords)
                // so the camera looks down at the quad from a slightly southern vantage.
                const mainQuadPos = latLngToXZ(ORIGIN_LAT, ORIGIN_LNG); // (0, 0)
                overviewTarget.set(mainQuadPos.x, 0, mainQuadPos.z + CAMERA_Z_OFFSET);
                overviewDistance = dist;
            }

            function setOverviewPose() {
                cameraTarget.copy(overviewTarget);
                cameraDistance = overviewDistance;
                cameraYaw = OVERVIEW_YAW;
                cameraPitch = VIEW_PITCH;
                focusing = false;
                hoverTargetVec.copy(overviewTarget);
                hoverTargetActive = false;
                hoverLookAtActive = false;
                hoverLookAtCurrent.copy(overviewTarget);
                applyCameraPose();
            }

            let selectedName = null;

            // ── Hover guide card DOM refs ───────────────────────────────────
            // Declared here (before resize) so positionConnector() can safely
            // reference hoverCard when resize() is called on first load.
            const hoverCard      = document.getElementById('dorm-hover-card');
            const hoverRankEl    = document.getElementById('dorm-hover-rank');
            const hoverRankSubEl = document.getElementById('dorm-hover-rank-sub');
            const hoverTitleEl   = document.getElementById('dorm-hover-title');
            const hoverMetaEl    = document.getElementById('dorm-hover-meta');
            const hoverScoresEl  = document.getElementById('dorm-hover-scores');
            const hoverFooterEl  = document.getElementById('dorm-hover-footer');

            // ── Resize handling ────────────────────────────────────────────
            function resize() {
                const r = wrap.getBoundingClientRect();
                renderer.setSize(r.width, r.height, false);
                camera.aspect = r.width / Math.max(r.height, 1);
                camera.updateProjectionMatrix();
                computeOverviewPose();
                if (!selectedName) {
                    setOverviewPose();
                } else {
                    cameraDistance = Math.max(180, overviewDistance * 0.55);
                    applyCameraPose();
                }
                positionConnector();
            }
            window.addEventListener('resize', resize);
            resize();
            setOverviewPose();

            // ── Picking (hover + click) ────────────────────────────────────
            const raycaster = new THREE.Raycaster();
            const mouse = new THREE.Vector2();
            let hovered = null;

            function setDormColor(name, color) {
                const group = dormByName[name];
                if (!group || !group.length) return;
                group[0].material.color.copy(color);
            }

            // ── Dorm hover scale animation ──────────────────────────────────
            // Each dorm tracks a target scale (1.0 = normal, HOVER_SCALE = hovered).
            // The render loop lerps toward the target each frame for a smooth feel.
            const HOVER_SCALE = 1.035; // subtle — just enough for visual feedback
            const SCALE_LERP  = 0.12;  // speed (higher = snappier)
            const dormScaleTarget = {}; // name → target scale
            const dormScaleCurrent = {}; // name → current scale
            DORMS.forEach(d => {
                dormScaleTarget[d.name]  = 1.0;
                dormScaleCurrent[d.name] = 1.0;
            });

            function setDormScale(name, target) {
                dormScaleTarget[name] = target;
            }

            function tickDormScales() {
                DORMS.forEach(d => {
                    const cur = dormScaleCurrent[d.name];
                    const tgt = dormScaleTarget[d.name];
                    if (Math.abs(cur - tgt) < 0.0001) {
                        dormScaleCurrent[d.name] = tgt;
                    } else {
                        dormScaleCurrent[d.name] = cur + (tgt - cur) * SCALE_LERP;
                    }
                    const s = dormScaleCurrent[d.name];
                    const group = dormByName[d.name];
                    if (group) group.forEach(m => m.scale.set(s, s, s));
                });
            }

            function setHover(mesh) {
                if (hovered && (!mesh || hovered.userData.name !== mesh.userData.name)) {
                    const prevName = hovered.userData.name;
                    setDormColor(prevName, prevName === selectedName ? DORM_SELECT_COLOR : DORM_BASE_COLOR);
                    if (prevName !== selectedName) setDormScale(prevName, 1.0);
                }
                hovered = mesh;
                if (mesh && mesh.userData.name !== selectedName) {
                    setDormColor(mesh.userData.name, DORM_HOVER_COLOR);
                    setDormScale(mesh.userData.name, HOVER_SCALE);
                }
            }

            function pickAt(clientX, clientY) {
                const r = canvas.getBoundingClientRect();
                mouse.x = ((clientX - r.left) / r.width) * 2 - 1;
                mouse.y = -((clientY - r.top) / r.height) * 2 + 1;
                raycaster.setFromCamera(mouse, camera);
                const hits = raycaster.intersectObjects(dormMeshes, false);
                return hits.length ? hits[0].object : null;
            }

            // ── Hover guide card ────────────────────────────────────────────
            // Single focused card that follows the hovered building, with a
            // dot+line connector showing exactly which structure it describes.
            // (DOM refs declared earlier, before resize(), to avoid TDZ errors.)

            // Category metadata mirrored client-side so the hover card can
            // render verbal labels next to each dimension.
            const HOVER_CATEGORIES = [
              { key: 'culture',     icon: '🏆', label: 'Culture' },
              { key: 'roomSize',    icon: '📦', label: 'Size' },
              { key: 'quietness',   icon: '🔇', label: 'Noise' },
              { key: 'tempControl', icon: '🌡️', label: 'Temp' },
              { key: 'sunlight',    icon: '☀️', label: 'Light' }
            ];
            function ratingColorJS(val) {
                const colors = { 5: '#34877A', 4: '#92B89D', 3: '#D69772', 2: '#C27654', 1: '#AE5436' };
                return colors[Math.round(val)] || '#cfcfcf';
            }
            function rankTier(rank, total) {
                if (!rank || !total) return { color: '#6b6b6b', tier: 'No data' };
                const pct = (rank - 1) / Math.max(total - 1, 1);
                if (pct <= 0.20) return { color: '#1f7a4d', tier: 'Top tier' };
                if (pct <= 0.45) return { color: '#2f7a3a', tier: 'Strong' };
                if (pct <= 0.65) return { color: '#7a6a1f', tier: 'Mid' };
                if (pct <= 0.85) return { color: '#a3621f', tier: 'Below avg' };
                return { color: '#a83434', tier: 'Bottom' };
            }

            function populateHoverCard(name) {
                const data = DORM_SCORE_BY_NAME[name];
                const rank = DORM_RANKS.rankByName[name];
                const total = DORM_RANKS.total || 0;
                const overall = DORM_RANKS.overallByName[name];
                const tier = rankTier(rank, total);

                hoverTitleEl.textContent = (name || '').replace(/_/g, '-');

                // Rank chip
                if (rank) {
                    hoverRankEl.textContent = '#' + rank;
                    hoverRankEl.style.background = tier.color;
                    hoverRankSubEl.textContent = tier.tier + (total ? ' · of ' + total : '');
                } else {
                    hoverRankEl.textContent = '—';
                    hoverRankEl.style.background = '#6b6b6b';
                    hoverRankSubEl.textContent = 'Not yet ranked';
                }

                // Meta line: house count + overall score + review count
                const houseCount = data ? data.houseCount : 0;
                const reviewCount = data ? (data.reviewCount || 0) : 0;
                const houseStr = houseCount + ' house' + (houseCount === 1 ? '' : 's');
                const overallStr = '';
                const reviewStr = reviewCount > 0 ? ' · ' + reviewCount + ' review' + (reviewCount === 1 ? '' : 's') : '';
                hoverMetaEl.textContent = houseStr + overallStr + reviewStr;

                // Score grid: 5 dimensions
                let html = '';
                HOVER_CATEGORIES.forEach(cat => {
                    const score = data && data.scores ? data.scores[cat.key] : null;
                    const has = score != null;
                    const color = has ? ratingColorJS(score) : '#e5e7eb';
                    const pct = has ? Math.max(6, Math.min(100, ((score - 1) / 4) * 100)) : 0;
                    html += '<div class="dorm-hover-score">' +
                              '<span class="dorm-hover-score__icon">' + cat.icon + '</span>' +
                              '<span class="dorm-hover-score__label">' + cat.label + '</span>' +
                              '<div class="dorm-hover-score__bar"><div class="dorm-hover-score__fill" style="width:' + pct + '%; background:' + color + ';"></div></div>' +
                              '<span class="dorm-hover-score__val">' + (has ? score.toFixed(1) : '—') + '</span>' +
                            '</div>';
                });
                hoverScoresEl.innerHTML = html;

                // Footer: top vibes (if any)
                if (data && data.topVibes && data.topVibes.length) {
                    let f = '<div class="dorm-hover-card__footer-label">Top descriptors</div><div class="dorm-hover-card__chips">';
                    data.topVibes.forEach(v => {
                        f += '<span class="dorm-hover-card__chip">' + escapeHtml(v) + '</span>';
                    });
                    f += '</div>';
                    hoverFooterEl.innerHTML = f;
                    hoverFooterEl.hidden = false;
                } else {
                    hoverFooterEl.innerHTML = '';
                    hoverFooterEl.hidden = true;
                }
            }

            function escapeHtml(s) {
                return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
            }

            // Project the hovered dorm's anchor world position to screen px,
            // then place the card off to one side (avoiding viewport edges)
            // and draw the SVG connector from the dot at the building to a
            // point on the card's edge facing the building.
            function projectAnchor(name) {
                const v = dormAnchor[name];
                if (!v) return null;
                const r = wrap.getBoundingClientRect();
                const proj = v.clone().project(camera);
                return {
                    x: (proj.x * 0.5 + 0.5) * r.width,
                    y: (-proj.y * 0.5 + 0.5) * r.height
                };
            }

            function showHoverCard(name) {
                populateHoverCard(name);
                hoverCard.dataset.dorm = name;
                hoverCard.setAttribute('aria-hidden', 'false');
                hoverCard.classList.add('dorm-hover-card--visible');
                // Scale up the card when a dorm is selected (zoomed in)
                if (selectedName) {
                    hoverCard.classList.add('dorm-hover-card--zoomed');
                } else {
                    hoverCard.classList.remove('dorm-hover-card--zoomed');
                }
                connectorDotSprite.visible = true;
                connectorLine3D.visible = false; // circuit canvas handles the line
                circuitVisible = true;
                positionConnector();
            }
            function hideHoverCard() {
                hoverCard.classList.remove('dorm-hover-card--visible');
                hoverCard.classList.remove('dorm-hover-card--zoomed');
                hoverCard.setAttribute('aria-hidden', 'true');
                hoverCard.removeAttribute('data-dorm');
                connectorDotSprite.visible = false;
                connectorLine3D.visible = false;
                circuitVisible = false;
                circuitAnchorScreen = null;
                circuitCardEdge = null;
            }

            function positionConnector() {
                const name = hoverCard.dataset.dorm;
                if (!name) return;
                const anchor = projectAnchor(name);
                if (!anchor) return;
                const r = wrap.getBoundingClientRect();

                // Decide which side of the building to place the card. Pick
                // the side with more room so the card doesn't clip.
                const cardWidth = hoverCard.offsetWidth || 320;
                const cardHeight = hoverCard.offsetHeight || 260;
                const margin = 24;

                // When zoomed into a selected dorm, push the card further
                // away so the connector line is clearly visible.
                const cardOffset = selectedName ? 340 : 160;

                const placeRight = anchor.x < r.width / 2;
                let cardX = placeRight
                    ? Math.min(r.width - cardWidth - margin, anchor.x + cardOffset)
                    : Math.max(margin, anchor.x - cardWidth - cardOffset);
                let cardY = Math.max(margin, Math.min(r.height - cardHeight - margin, anchor.y - cardHeight / 2));

                hoverCard.style.left = cardX + 'px';
                hoverCard.style.top  = cardY + 'px';

                // Connector: line from anchor to the card's near edge.
                const cardEdgeX = placeRight ? cardX : (cardX + cardWidth);
                const cardEdgeY = cardY + cardHeight / 2;

                // Update circuit trace endpoints (screen-space pixels)
                circuitAnchorScreen = { x: anchor.x, y: anchor.y };
                circuitCardEdge     = { x: cardEdgeX, y: cardEdgeY };
                circuitVisible      = true;

                // Position the 3D connector dot sprite at the dorm's anchor
                const anchorWorld = dormAnchor[name];
                if (anchorWorld) {
                    connectorDotSprite.position.copy(anchorWorld);
                    connectorDotSprite.visible = true;
                }
            }

            canvas.addEventListener('pointermove', (ev) => {
                const hit = pickAt(ev.clientX, ev.clientY);
                if (hit) {
                    setHover(hit);
                    canvas.style.cursor = 'pointer';
                    // When zoomed into a selected dorm, keep that card pinned
                    if (selectedName) {
                        // Don't change the card — it stays on the selected dorm
                    } else {
                        if (hoverCard.dataset.dorm !== hit.userData.name) {
                            showHoverCard(hit.userData.name);
                        }
                    }
                } else {
                    if (hovered) setHover(null);
                    canvas.style.cursor = 'default';
                    // Only hide hover card if NOT zoomed into a selected dorm
                    if (!selectedName) {
                        hideHoverCard();
                    }
                }
            });
            canvas.addEventListener('pointerleave', () => {
                if (hovered) setHover(null);
                // Only hide hover card if NOT zoomed into a selected dorm
                if (!selectedName) {
                    hideHoverCard();
                }
            });

            // Click: zoom in on the dorm. No orbit. A second click on the
            // already-selected dorm opens its full dorm page so the click
            // remains useful even when zoomed.
            canvas.addEventListener('click', (ev) => {
                const hit = pickAt(ev.clientX, ev.clientY);
                if (!hit) {
                    // Clicked empty space — exit zoomed view
                    if (selectedName) {
                        clearSelection();
                        hideHoverCard();
                    }
                    return;
                }
                const name = hit.userData.name;
                if (selectedName === name) {
                    window.location.href = '/dorm/' + encodeURIComponent(name);
                    return;
                }
                selectDorm(name);
            });
            // Keyboard accessibility — arrow keys cycle dorms when canvas focused
            canvas.tabIndex = 0;
            canvas.setAttribute('role', 'application');
            canvas.addEventListener('keydown', (e) => {
                if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft' && e.key !== 'Enter' && e.key !== 'Escape') return;
                e.preventDefault();
                if (e.key === 'Escape') { clearSelection(); hideHoverCard(); return; }
                const names = DORMS.map(d => d.name);
                let idx = names.indexOf(selectedName);
                if (e.key === 'ArrowRight') idx = (idx + 1 + names.length) % names.length;
                if (e.key === 'ArrowLeft')  idx = (idx - 1 + names.length) % names.length;
                if (e.key === 'Enter' && idx === -1) idx = 0;
                if (idx >= 0) selectDorm(names[idx]);
            });

            // Global Escape key listener — exits zoomed view from anywhere
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && selectedName) {
                    e.preventDefault();
                    clearSelection();
                    hideHoverCard();
                }
            });

            // Click anywhere off-canvas (or on empty ground) to deselect.
            // Clicks on the hover card itself should NOT deselect.
            wrap.addEventListener('click', (ev) => {
                if (ev.target === canvas) return; // canvas handler runs
                if (hoverCard.contains(ev.target)) return; // clicking the card itself
            });

            // ── Dorm selection: zoom only, no orbit ─────────────────────────
            function dormCenter(name) {
                const d = DORMS.find(x => x.name === name);
                if (!d) return null;
                // If the dorm was rendered from a precise polygon footprint,
                // its true centroid may differ from the (label-only) lat/lng.
                // Use the anchor computed during rendering when available.
                const a = dormAnchor[name];
                if (a) return { x: a.x, z: a.z };
                return latLngToXZ(d.lat, d.lng);
            }

            function selectDorm(name) {
                if (selectedName && dormByName[selectedName]) {
                    setDormColor(selectedName, DORM_BASE_COLOR);
                }
                selectedName = name;
                if (dormByName[name]) setDormColor(name, DORM_SELECT_COLOR);

                // Show and pin the hover card for the selected dorm
                showHoverCard(name);

                const c = dormCenter(name);
                if (c) {
                    focusTargetVec.set(c.x, 0, c.z);
                    focusDistance = Math.max(180, overviewDistance * 0.55);
                    focusing = true;
                }
            }
            function clearSelection() {
                if (selectedName && dormByName[selectedName]) {
                    setDormColor(selectedName, DORM_BASE_COLOR);
                }
                selectedName = null;

                focusTargetVec.copy(overviewTarget);
                focusDistance = overviewDistance;
                focusing = true;

                // Reset hover state so the camera eases back to overview
                hoverTargetVec.copy(overviewTarget);
                hoverTargetActive = false;
                hoverLookAtActive = false;
                hoverLookAtCurrent.copy(overviewTarget);
            }

            // ── Update 2D overlay label positions each frame ──────────────
            // Projects each dorm's anchor from world space to screen pixels
            // and positions the HTML overlay element accordingly.
            function updateDormLabels2D() {
                const r = wrap.getBoundingClientRect();
                const halfW = r.width / 2;
                const halfH = r.height / 2;
                DORMS.forEach(d => {
                    const el = dormOverlayEls[d.name];
                    const anchor = dormAnchor[d.name];
                    if (!el || !anchor) return;

                    const proj = anchor.clone().project(camera);
                    if (proj.z > 1) { el.style.opacity = '0'; return; }

                    const sx = (proj.x * halfW) + halfW;
                    const sy = (-proj.y * halfH) + halfH;

                    el.style.opacity = '1';
                    el.style.left = sx + 'px';
                    el.style.top  = (sy - LABEL_PX_ABOVE_ANCHOR) + 'px';
                });
            }

            // Projects each landmark's anchor to screen space and positions
            // its 2D HTML label element, same approach as dorm labels.
            function updateLandmarkLabels2D() {
                const r = wrap.getBoundingClientRect();
                const halfW = r.width / 2;
                const halfH = r.height / 2;
                Object.keys(landmarkOverlayEls).forEach(name => {
                    const el = landmarkOverlayEls[name];
                    const anchor = landmarkAnchor[name];
                    if (!el || !anchor) return;

                    const proj = anchor.clone().project(camera);
                    if (proj.z > 1) { el.style.opacity = '0'; return; }

                    const sx = (proj.x * halfW) + halfW;
                    const sy = (-proj.y * halfH) + halfH;

                    el.style.opacity = '1';
                    el.style.left = sx + 'px';
                    el.style.top  = sy + 'px';
                });
            }

            // ── Animation loop ──────────────────────────────────────────────
            const FOCUS_LERP  = 0.08;
            const compassEl = document.getElementById('compass-2d');
            let lastFrameTime = performance.now();

            // ── Hover zoom ──────────────────────────────────────────────────
            // On hover, smoothly shift the camera target toward the hovered
            // dorm's position and pull the distance in slightly, so the zoom
            // moves in the direction of the dorm rather than toward the center.
            // On hover exit the camera eases back to the overview pose.
            // This is entirely independent of the click-to-focus system.
            const HOVER_ZOOM_AMOUNT  = 28;   // world-units to pull in on distance
            const HOVER_ZOOM_LERP    = 0.10;
            let hoverZoomTarget      = 0;    // target distance offset

            function animate() {
                requestAnimationFrame(animate);

                const now = performance.now();
                const dt = Math.min((now - lastFrameTime) / 1000, 0.1); // seconds, capped
                lastFrameTime = now;

                if (focusing) {
                    cameraTarget.lerp(focusTargetVec, FOCUS_LERP);
                    cameraDistance += (focusDistance - cameraDistance) * FOCUS_LERP;
                    if (cameraTarget.distanceToSquared(focusTargetVec) < 0.5 &&
                        Math.abs(cameraDistance - focusDistance) < 0.5) {
                        focusing = false;
                        cameraTarget.copy(focusTargetVec);
                        cameraDistance = focusDistance;
                    }
                }

                // Hover: keep camera position fixed, nudge the look-at point
                // a tiny amount toward the dorm — barely perceptible tilt.
                const LOOK_LERP   = 0.03;  // very slow ease
                const LOOK_BLEND  = 0.02;
                if (hovered && !selectedName && !focusing) {
                    const c = dormCenter(hovered.userData.name);
                    if (c) {
                        const lookTarget = new THREE.Vector3(
                            cameraTarget.x + (c.x - cameraTarget.x) * LOOK_BLEND,
                            cameraTarget.y,
                            cameraTarget.z + (c.z - cameraTarget.z) * LOOK_BLEND
                        );
                        if (!hoverLookAtActive) {
                            hoverLookAtCurrent.copy(cameraTarget);
                            hoverLookAtActive = true;
                        }
                        hoverLookAtCurrent.lerp(lookTarget, LOOK_LERP);
                    }
                    hoverZoomTarget = -HOVER_ZOOM_AMOUNT;
                } else {
                    hoverZoomTarget = 0;
                    if (hoverLookAtActive) {
                        hoverLookAtCurrent.lerp(cameraTarget, LOOK_LERP);
                        if (hoverLookAtCurrent.distanceToSquared(cameraTarget) < 0.1) {
                            hoverLookAtActive = false;
                            hoverLookAtCurrent.copy(cameraTarget);
                        }
                    }
                }

                hoverZoomOffset += (hoverZoomTarget - hoverZoomOffset) * HOVER_ZOOM_LERP;

                // Show compass when zoomed out (near overview distance), hide when zoomed in
                if (compassEl) {
                    var zoomRatio = cameraDistance / overviewDistance;
                    compassEl.style.opacity = zoomRatio > 0.75 ? '1' : '0';
                }

                tickDormScales();
                applyCameraPose();
                renderer.render(scene, camera);

                // Update 2D overlay labels to track projected positions
                updateDormLabels2D();
                updateLandmarkLabels2D();

                // Connector tracks the camera so the line stays glued to
                // the building as we zoom in.
                if (hoverCard.dataset.dorm) positionConnector();

                // Tick and draw the circuit trace overlay
                tickCircuitPulse(dt);
                drawCircuitTrace();
            }
            animate();

            // ── Helper: cheap canvas-based text sprite ──────────────────────
            function makeTextSprite(text, opts) {
                opts = opts || {};
                const fontSize = opts.fontSize || 32;
                const padding = 12;
                const c = document.createElement('canvas');
                const ctx = c.getContext('2d');
                ctx.font = `${opts.weight || 600} ${fontSize}px Inter, sans-serif`;
                const tw = ctx.measureText(text).width;
                c.width = Math.ceil(tw + padding * 2);
                c.height = Math.ceil(fontSize + padding * 2);
                ctx.font = `${opts.weight || 600} ${fontSize}px Inter, sans-serif`;
                if (opts.bg) {
                    ctx.fillStyle = opts.bg;
                    roundRect(ctx, 0, 0, c.width, c.height, 8);
                    ctx.fill();
                }
                ctx.fillStyle = opts.color || '#222';
                ctx.textBaseline = 'middle';
                ctx.fillText(text, padding, c.height / 2);
                const tex = new THREE.CanvasTexture(c);
                tex.minFilter = THREE.LinearFilter;
                const mat = new THREE.SpriteMaterial({ map: tex, transparent: true, depthTest: false });
                const sprite = new THREE.Sprite(mat);
                // Store canvas dimensions so callers can compute proportional scale
                sprite.userData.canvasWidth = c.width;
                sprite.userData.canvasHeight = c.height;
                return sprite;
            }
            function rankColor(rank, total) {
                if (!rank || !total) return '#6b6b6b';
                const pct = (rank - 1) / Math.max(total - 1, 1);
                if (pct <= 0.20) return '#1f7a4d';
                if (pct <= 0.45) return '#2f7a3a';
                if (pct <= 0.65) return '#7a6a1f';
                if (pct <= 0.85) return '#a3621f';
                return '#a83434';
            }

            function roundRect(ctx, x, y, w, h, r) {
                ctx.beginPath();
                ctx.moveTo(x + r, y);
                ctx.arcTo(x + w, y,     x + w, y + h, r);
                ctx.arcTo(x + w, y + h, x,     y + h, r);
                ctx.arcTo(x,     y + h, x,     y,     r);
                ctx.arcTo(x,     y,     x + w, y,     r);
                ctx.closePath();
            }
        </script>
    </body>

