<%- include('partials/head', { title: houseName + ' | Room for Improvement' }) %>

    <body>
        <%- include('partials/nav') %>

        <!-- Word cloud hover tooltip -->
        <div class="wc-tooltip" id="wc-tooltip"></div>
        <!-- Word cloud hover highlight overlay -->
        <span class="wc-hover-highlight" id="wc-hover-highlight"></span>
        <style>
            /* Preview pill shared styles */
            .preview-pill {
                position: absolute;
                z-index: 10;
                display: flex;
                align-items: center;
                gap: 0.55rem;
                padding: 0.5rem 0.8rem 0.5rem 0.65rem;
                background: rgba(255,255,255,0.12);
                backdrop-filter: blur(14px) saturate(1.8);
                -webkit-backdrop-filter: blur(14px) saturate(1.8);
                border: 1px solid rgba(255,255,255,0.2);
                border-radius: 2rem;
                text-decoration: none;
                color: rgba(255,255,255,0.95);
                text-align: left;
                max-width: 230px;
                box-shadow: 0 4px 18px rgba(0,0,0,0.25);
                transition: background 0.2s ease, box-shadow 0.2s ease, transform 0.18s ease;
                cursor: pointer;
                overflow: hidden;
            }
            .preview-pill:hover {
                background: rgba(255,255,255,0.22);
                box-shadow: 0 6px 28px rgba(0,0,0,0.35);
                transform: translateY(-2px);
            }
            .preview-pill-icon {
                flex-shrink: 0;
                width: 15px;
                height: 15px;
                opacity: 0.82;
            }
            .preview-pill-text {
                font-size: 0.7rem;
                font-weight: 500;
                letter-spacing: 0.01em;
                line-height: 1.4;
                flex: 1;
                min-width: 0;
                overflow: hidden;
                display: -webkit-box;
                -webkit-line-clamp: 2;
                -webkit-box-orient: vertical;
                position: relative;
            }
            /* Swipe transition for rotating text */
            .preview-pill-text.swiping-up {
                transform: translateY(-120%);
                opacity: 0;
                transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.8s ease;
            }
            .preview-pill-text.preparing {
                transform: translateY(120%);
                opacity: 0;
                transition: none; /* Instant reset to bottom */
            }
            .preview-pill-text.visible {
                transform: translateY(0);
                opacity: 1;
                transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.8s ease;
            }
            .preview-pill-arrow {
                flex-shrink: 0;
                opacity: 0.8;
            }

            /* ── Expanded top-right preview pill (now occupies space vacated by house board button) ── */
            .preview-pill-large {
                padding: 0.7rem 1rem;
                max-width: 290px;
                min-width: 220px;
                border-radius: 1.1rem;
                background: rgba(255,255,255,0.14);
                border: 1px solid rgba(255,255,255,0.24);
            }
            .preview-pill-large .preview-pill-icon {
                width: 18px;
                height: 18px;
            }
            .preview-pill-large .preview-pill-text {
                font-size: 0.82rem;
                line-height: 1.45;
                -webkit-line-clamp: 3;
                font-weight: 500;
            }
            .preview-pill-large .preview-pill-arrow {
                width: 14px;
                height: 14px;
            }

            /* ── Back pill sizing — slightly larger to match the reduced content pills ── */
            #pill-back {
                padding: 0.6rem 1rem;
                max-width: 200px;
                border-radius: 1.1rem;
                gap: 0.6rem;
            }
            #pill-back .preview-pill-icon {
                width: 17px;
                height: 17px;
            }
            #pill-back .preview-pill-text {
                font-size: 0.8rem;
                font-weight: 600;
            }

            /* Maroon "Back" pill (top-left, replaces trivia pill position) */
            .back-pill {
                background: rgba(128, 0, 0, 0.85);
                border: 1px solid rgba(255, 255, 255, 0.25);
                color: #fff;
            }
            .back-pill:hover {
                background: rgba(128, 0, 0, 1);
            }

            /* Maroon "house board" button under the house name header */
            .house-board-btn {
                display: inline-flex;
                align-items: center;
                gap: 0.5rem;
                background-color: #800000;
                color: #fff;
                padding: 0.65rem 1.2rem;
                border-radius: 0.5rem;
                font-weight: 700;
                text-decoration: none;
                box-shadow: 0 3px 10px rgba(0,0,0,0.28);
                transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
            }
            .house-board-btn:hover {
                background-color: #660000;
                transform: translateY(-1px);
                box-shadow: 0 6px 18px rgba(0,0,0,0.36);
            }

            /* ── Room table filters ── */
            .room-filters {
                display: flex;
                flex-wrap: wrap;
                gap: 1rem;
                align-items: center;
                margin: 1rem 0 0.75rem;
                padding: 0.75rem 1rem;
                background: #f9fafb;
                border: 1px solid var(--border-color);
                border-radius: 0.5rem;
            }
            .room-filters label {
                font-size: 0.85rem;
                font-weight: 600;
                color: var(--text-secondary);
                margin: 0;
                display: flex;
                align-items: center;
                gap: 0.4rem;
            }
            .room-filters select, .room-filters input[type="checkbox"] {
                font-size: 0.85rem;
            }
            .room-filters select {
                padding: 0.3rem 0.5rem;
                border: 1px solid var(--border-color);
                border-radius: 0.35rem;
                background: #fff;
            }
            .room-filters .filter-clear-btn {
                background: none;
                border: 1px solid var(--border-color);
                padding: 0.3rem 0.7rem;
                border-radius: 0.35rem;
                cursor: pointer;
                font-size: 0.8rem;
                color: var(--text-secondary);
            }
            .room-filters .filter-clear-btn:hover { background: #fff; }


            /* ── Room type tag buttons ── */
            .roomtype-tag-filters {
                display: flex;
                flex-wrap: wrap;
                gap: 0.4rem;
                align-items: center;
            }
            .roomtype-tag-btn {
                display: inline-flex;
                align-items: center;
                padding: 0.25rem 0.7rem;
                border: 1.5px solid #800000;
                border-radius: 2rem;
                background: #fff;
                color: #800000;
                font-size: 0.8rem;
                font-weight: 600;
                cursor: pointer;
                transition: background 0.15s, color 0.15s;
                user-select: none;
            }
            .roomtype-tag-btn:hover {
                background: rgba(128,0,0,0.08);
            }
            .roomtype-tag-btn.active {
                background: #800000;
                color: #fff;
            }

            /* ── Active tag filter chips (shown inside filter bar) ── */
            .active-tag-chips-wrap {
                /* Fixed-size scrollable strip — clip early to keep toggle in place */
                display: flex;
                align-items: center;
                max-width: 210px;
                min-width: 0;
                overflow: hidden;
                flex-shrink: 1;
                position: relative;
            }
            .active-tag-chips {
                display: flex;
                flex-wrap: nowrap;    /* NEVER wrap — chips scroll horizontally */
                gap: 0.35rem;
                align-items: center;
                overflow-x: auto;
                overflow-y: hidden;
                scroll-behavior: smooth;
                /* Hide scrollbar visually but keep functional */
                scrollbar-width: none;
                -ms-overflow-style: none;
                padding-bottom: 2px;  /* prevent clipping bottom of chips */
            }
            .active-tag-chips::-webkit-scrollbar { display: none; }
            /* Fade edge to hint at scroll — wider fade = clips sooner */
            .active-tag-chips-wrap::after {
                content: '';
                position: absolute;
                right: 0;
                top: 0;
                bottom: 0;
                width: 40px;
                background: linear-gradient(to right, transparent, #f9fafb);
                pointer-events: none;
                opacity: 0;           /* shown only when chips overflow */
                transition: opacity 0.2s;
            }
            .active-tag-chips-wrap.has-overflow::after { opacity: 1; }
            .active-tag-chip {
                display: inline-flex;
                align-items: center;
                gap: 0.25rem;
                padding: 0.2rem 0.55rem;
                background: #800000;
                color: #fff;
                border-radius: 2rem;
                font-size: 0.78rem;
                font-weight: 600;
                cursor: default;
                white-space: nowrap;  /* never let chip text wrap */
                flex-shrink: 0;       /* never let chips shrink/squish */
            }
            .active-tag-chip .chip-remove {
                cursor: pointer;
                font-size: 0.9rem;
                line-height: 1;
                opacity: 0.8;
                margin-left: 0.15rem;
            }
            .active-tag-chip .chip-remove:hover { opacity: 1; }

            /* Profanity toggle + Clear filters — locked together at right end of filter row */
            .filter-row-right {
                display: flex;
                align-items: center;
                gap: 0.6rem;
                margin-left: auto;
                flex-shrink: 0;   /* never shrink — always stays rightmost */
            }
            /* ── Room filters bar extra elements ── */
            .filter-tags-dropdown-wrapper {
                position: relative;
                display: inline-flex;
                align-items: center;
            }
            .filter-tags-btn {
                display: inline-flex;
                align-items: center;
                gap: 0.35rem;
                padding: 0.3rem 0.75rem;
                border: 1.5px solid #800000;
                border-radius: 0.35rem;
                background: #fff;
                color: #800000;
                font-size: 0.82rem;
                font-weight: 600;
                cursor: pointer;
                transition: background 0.15s, color 0.15s;
                user-select: none;
            }
            .filter-tags-btn:hover { background: rgba(128,0,0,0.07); }
            .filter-tags-btn.open { background: #800000; color: #fff; }
            .filter-tags-dropdown {
                display: none;
                position: absolute;
                top: calc(100% + 6px);
                left: 0;
                min-width: 280px;
                max-width: 360px;
                max-height: 320px;
                overflow-y: auto;
                background: #fff;
                border: 1px solid var(--border-color);
                border-radius: 0.5rem;
                box-shadow: 0 6px 20px rgba(0,0,0,0.12);
                z-index: 200;
                padding: 0.5rem 0;
            }
            .filter-tags-dropdown.open { display: block; }
            .filter-tags-dropdown-group { padding: 0.25rem 0.75rem 0.15rem; font-size: 0.73rem; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; margin-top: 0.3rem; }
            .filter-tags-dropdown-item {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                padding: 0.35rem 0.9rem;
                font-size: 0.83rem;
                cursor: pointer;
                transition: background 0.12s;
            }
            .filter-tags-dropdown-item:hover { background: #f3f4f6; }
            .filter-tags-dropdown-item.selected { font-weight: 600; color: #800000; }
            .filter-tags-dropdown-item .ftd-check { width: 14px; height: 14px; opacity: 0; flex-shrink: 0; }
            .filter-tags-dropdown-item.selected .ftd-check { opacity: 1; }

            /* Room type tag color coding */
            .roomtype-tag-btn[data-roomtype*="single" i], .roomtype-tag-btn[data-roomtype="Single" i] {
                border-color: #059669; color: #059669;
            }
            .roomtype-tag-btn[data-roomtype*="single" i].active, .roomtype-tag-btn[data-roomtype="Single" i].active {
                background: #059669; color: #fff;
            }
            .roomtype-tag-btn[data-roomtype*="double" i] {
                border-color: #2563eb; color: #2563eb;
            }
            .roomtype-tag-btn[data-roomtype*="double" i].active {
                background: #2563eb; color: #fff;
            }
            .roomtype-tag-btn[data-roomtype*="suite" i] {
                border-color: #7c3aed; color: #7c3aed;
            }
            .roomtype-tag-btn[data-roomtype*="suite" i].active {
                background: #7c3aed; color: #fff;
            }
            .roomtype-tag-btn[data-roomtype*="apartment" i] {
                border-color: #d97706; color: #d97706;
            }
            .roomtype-tag-btn[data-roomtype*="apartment" i].active {
                background: #d97706; color: #fff;
            }

            /* Profanity toggle (matches rooms.ejs) */
            .hp-profanity-toggle {
                display: flex;
                align-items: center;
                gap: 0.5rem;
            }

            /* ── Tags in table rows are now clickable ── */
            #room-table .tag {
                cursor: pointer;
                transition: opacity 0.15s;
            }
            #room-table .tag:hover {
                opacity: 0.75;
            }

            /* ── Sortable table headers ── */
            th.sortable {
                cursor: pointer;
                user-select: none;
                position: relative;
            }
            th.sortable:hover { background: rgba(0,0,0,0.03); }
            th.sortable .sort-indicator {
                display: inline-block;
                margin-left: 0.3rem;
                font-size: 0.75rem;
                opacity: 0.45;
            }
            th.sortable.sort-asc .sort-indicator,
            th.sortable.sort-desc .sort-indicator {
                opacity: 1;
                color: var(--primary-color, #800000);
            }

            /* ── Word cloud sections ── */
            .word-cloud-section {
                margin-top: 2.5rem;
                padding: 1.25rem 1.5rem;
                background: #fdfdfd;
                border: 1px solid var(--border-color);
                border-radius: 0.6rem;
            }
            .word-cloud-section h3 {
                margin-top: 0;
                margin-bottom: 0.5rem;
                font-size: 1.15rem;
            }
            .word-cloud-section .word-cloud-sub {
                color: var(--text-secondary);
                font-size: 0.85rem;
                margin-bottom: 0.9rem;
            }
            .word-cloud-canvas {
                width: 100%;
                height: 260px;
                background: #fff;
                border: 1px dashed var(--border-color);
                border-radius: 0.4rem;
            }
            /* CSS fallback word cloud (used if wordcloud2 fails) */
            .word-cloud-fallback {
                display: flex;
                flex-wrap: wrap;
                gap: 0.4rem 0.8rem;
                align-items: baseline;
                padding: 1rem;
                background: #fff;
                border-radius: 0.4rem;
                min-height: 120px;
            }
            .word-cloud-fallback .wc-word {
                display: inline-block;
                padding: 0.15em 0.45em;
                line-height: 1.1;
                color: var(--primary-dark, #800000);
            }
            .word-cloud-empty {
                color: var(--text-secondary);
                font-style: italic;
                padding: 1rem;
            }

            /* ── Fix #1: Rating column headers — narrow width + wrappable text ── */
            #room-table th.sortable {
                white-space: normal;
                word-break: break-word;
                line-height: 1.3;
            }
            #room-table th[data-sort-key="naturalLight"],
            #room-table th[data-sort-key="roomSize"],
            #room-table th[data-sort-key="noise"],
            #room-table th[data-sort-key="tempControl"] {
                width: 108px;
                min-width: 96px;
                max-width: 116px;
            }
            #room-table th[data-sort-key="tags"] {
                width: 160px;
                min-width: 140px;
                max-width: 180px;
            }

            /* ── Fix #2: Word cloud two-column layout ── */
            .word-cloud-row {
                display: flex;
                gap: 0.75rem;
                margin-bottom: 1rem;
            }
            .word-cloud-row .word-cloud-section {
                flex: 1;
                margin-top: 0;
                padding: 0.75rem 1rem;
            }
            .word-cloud-row .word-cloud-canvas {
                height: 180px;
            }
            .word-cloud-row .word-cloud-section h3 {
                font-size: 1.15rem;
                margin-bottom: 0.25rem;
            }
            .word-cloud-row .word-cloud-sub {
                font-size: 0.82rem;
                margin-bottom: 0.5rem;
            }

            /* ── Word cloud hover tooltip ── */
            .wc-tooltip {
                position: fixed;
                z-index: 9999;
                pointer-events: none;
                background: rgba(30, 30, 30, 0.92);
                color: #fff;
                padding: 0.45rem 0.75rem;
                border-radius: 0.4rem;
                font-size: 0.82rem;
                font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
                white-space: nowrap;
                box-shadow: 0 3px 12px rgba(0,0,0,0.25);
                opacity: 0;
                transition: opacity 0.15s ease;
            }
            .wc-tooltip.visible {
                opacity: 1;
            }
            .wc-tooltip .wc-tooltip-word {
                font-weight: 700;
            }
            .wc-tooltip .wc-tooltip-count {
                font-weight: 400;
                opacity: 0.85;
            }

            /* ── Word cloud hover highlight overlay ── */
            .wc-hover-highlight {
                position: fixed;
                z-index: 9998;
                pointer-events: none;
                display: flex;
                align-items: center;
                justify-content: center;
                font-family: Georgia, serif;
                transition: opacity 0.12s ease;
            }

            /* ── Word cloud legend: centered + hover dim effect ── */
            #culture-wc-legend,
            #descriptor-wc-legend {
                justify-content: center;
            }
            #culture-wc-legend .wc-legend-item,
            #descriptor-wc-legend .wc-legend-item {
                transition: opacity 0.2s ease;
            }
            #culture-wc-legend.has-hover .wc-legend-item:not(.hovered),
            #descriptor-wc-legend.has-hover .wc-legend-item:not(.hovered) {
                opacity: 0.25;
            }

            /* ── Legend item tooltip (breakdown on hover) ── */
            .wc-legend-tooltip {
                display: none;
                position: absolute;
                top: calc(100% + 8px);
                left: 50%;
                transform: translateX(-50%);
                min-width: 180px;
                max-width: 260px;
                padding: 0.5rem 0.75rem;
                background: rgba(30, 30, 30, 0.95);
                color: #fff;
                font-size: 0.75rem;
                font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
                border-radius: 0.4rem;
                box-shadow: 0 3px 12px rgba(0,0,0,0.3);
                z-index: 10000;
                pointer-events: none;
                white-space: nowrap;
            }
            .wc-legend-tooltip::before {
                content: '';
                position: absolute;
                bottom: 100%;
                left: 50%;
                transform: translateX(-50%);
                border: 5px solid transparent;
                border-bottom-color: rgba(30, 30, 30, 0.95);
            }
            .wc-legend-item:hover .wc-legend-tooltip {
                display: block;
            }

            /* ── Tag color coding by sentiment (same scale as rating columns) ── */
            .tag[data-tag-sentiment="positive"] {
                background-color: rgba(52, 135, 122, 0.15);
                color: #1e6b61;
                border-color: rgba(52, 135, 122, 0.35);
            }
            .tag[data-tag-sentiment="negative"] {
                background-color: rgba(174, 84, 54, 0.12);
                color: #8b3a22;
                border-color: rgba(174, 84, 54, 0.3);
            }
            .tag[data-tag-sentiment="mild-negative"] {
                background-color: rgba(214, 151, 114, 0.15);
                color: #8a4e28;
                border-color: rgba(214, 151, 114, 0.35);
            }
            /* neutral = "Unusually shaped room" — softened black outline + font */
            .tag[data-tag-sentiment="neutral"] {
                color: #444;
                border-color: #444;
            }

            /* ── Floor Summary Section ── */
            .floor-summary-section {
                margin-top: 1.5rem;
                margin-bottom: 0.5rem;
                padding: 1rem 1.25rem;
                background: #fdfdfd;
                border: 1px solid var(--border-color);
                border-radius: 0.6rem;
            }
            .floor-summary-title {
                font-size: 1rem;
                font-weight: 700;
                color: var(--text-primary);
                margin-bottom: 0.2rem;
            }
            .floor-summary-subtitle {
                font-size: 0.78rem;
                color: var(--text-secondary);
                margin-bottom: 0.75rem;
            }
            .floor-summary-table-wrap {
                overflow-x: auto;
            }
            .floor-summary-table {
                width: 100%;
                border-collapse: collapse;
                font-size: 0.85rem;
            }
            .floor-summary-table th {
                text-align: left;
                padding: 0.35rem 0.6rem;
                font-size: 0.72rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.04em;
                color: var(--text-secondary);
                border-bottom: 1px solid var(--border-color);
                white-space: nowrap;
            }
            .floor-summary-row {
                cursor: pointer;
                transition: background 0.12s;
            }
            .floor-summary-row:hover {
                background: rgba(128,0,0,0.04);
            }
            .floor-summary-row.active-floor-filter {
                background: rgba(128,0,0,0.08);
            }
            .floor-summary-row td {
                padding: 0.4rem 0.6rem;
                border-bottom: 1px solid var(--border-color);
                vertical-align: middle;
            }
            .floor-summary-floor-cell {
                font-weight: 700;
            }
            .fs-val {
                display: inline-block;
                font-size: 0.95rem;
                font-weight: 700;
            }
            .fs-na {
                color: #ccc;
                font-size: 0.85rem;
            }
            .floor-summary-tags-cell {
                display: flex;
                flex-wrap: wrap;
                gap: 0.2rem;
                align-items: center;
                padding: 0.4rem 0.6rem;
            }
            .fs-tag {
                font-size: 0.72rem;
                padding: 0.1em 0.45em;
                cursor: default;
            }
            .fs-vibe-tag {
                display: inline-block;
                padding: 0.18em 0.55em;
                border-radius: var(--radius-full);
                font-size: 0.72rem;
                font-weight: 600;
                border: 1px solid currentColor;
                cursor: default;
                white-space: nowrap;
                /* background, border, and font color set by JS via assignTheme */
            }
            /* Prevent the generic .tag hover from overriding theme colors */
            .fs-vibe-tag:hover {
                opacity: 0.85;
            }
        </style>

            <main style="max-width:1300px; margin:0 auto; padding:2rem 1.5rem;">

                <!-- Header Banner -->
                <div class="house-banner" style="background-color: var(--primary-dark); <% if (typeof dormBackground !== 'undefined' && dormBackground) { %>background-image: linear-gradient(rgba(0,0,0,0.48), rgba(0,0,0,0.72)), url('<%= dormBackground %>'); background-size: cover; background-position: center;<% } %> position: relative; overflow: visible;">

                    <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; position:relative; z-index:2;">
                        <!-- House emblem -->
                        <% if (typeof houseEmblem !== 'undefined' && houseEmblem) { %>
                        <img src="<%= houseEmblem %>" alt="<%= houseName %> emblem" style="width:72px; height:72px; border-radius:50%; box-shadow: 0 4px 16px rgba(0,0,0,0.4); border: 3px solid rgba(255,255,255,0.2); margin-bottom:1rem; object-fit: cover; background-color: #fff;">
                        <% } else { %>
                        <div style="width:72px; height:72px; border-radius:50%; background:<%= houseColor %>;
                                display:flex; align-items:center; justify-content:center;
                                box-shadow: 0 4px 16px rgba(0,0,0,0.4); border: 3px solid rgba(255,255,255,0.2); margin-bottom:1rem;">
                            <span style="color:white; font-weight:800; font-size:1.5rem; letter-spacing:0.02em;">
                                <%= houseInitials %>
                            </span>
                        </div>
                        <% } %>
                        <h1 style="margin:0; font-size:2.5rem; font-weight:800; text-shadow:0 2px 4px rgba(0,0,0,0.5); color:white; text-align:center; display:flex; flex-direction:column; align-items:center;">
                            <span style="border-bottom:none; text-decoration:none;"><%= houseName %></span>
                            <div style="font-size: 1.35rem; font-weight:600; margin-top:0.25rem; white-space:nowrap; text-shadow:0 1px 3px rgba(0,0,0,0.4);">
                                (<a href="/dorm/<%= encodeURIComponent(dormName) %>" style="color:rgba(255,255,255,0.85); text-decoration:none;"><%= dormName.replace(/_/g,'-') %></a>)
                            </div>
                        </h1>

                        <!-- House board button — now positioned directly below the house name header -->
                        <a class="house-board-btn"
                           href="/house/<%= encodeURIComponent(dormName) %>/<%= encodeURIComponent(houseName) %>/board"
                           style="margin-top: 1.1rem;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zm-7-2h2v-2h-2v2zm0-4h2V7h-2v6z"/>
                            </svg>
                            Click here to access house board
                        </a>
                    </div>

                    <!-- ── BACK BUTTON PILL (top-left, navigates to rankings) ── -->
                    <a class="preview-pill back-pill" id="pill-back"
                       href="/dorm/<%= encodeURIComponent(dormName) %>"
                       style="top: 1rem; left: 1.25rem;"
                       title="Back to Rankings">
                        <svg class="preview-pill-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="rgba(255,255,255,0.95)">
                            <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
                        </svg>
                        <span class="preview-pill-text visible">Back to Rankings</span>
                    </a>

                    <!-- ── PREVIEW PILL: TRIVIA (moved to bottom-right) ── -->
                    <a class="preview-pill preview-pill-large" id="pill-trivia"
                       href="/house/<%= encodeURIComponent(dormName) %>/<%= encodeURIComponent(houseName) %>/board#trivia"
                       style="bottom: 2.6rem; right: 1.25rem;"
                       title="House Trivia">
                        <!-- Lightbulb icon -->
                        <svg class="preview-pill-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="rgba(255,255,255,0.85)">
                            <path d="M9 21c0 .55.45 1 1 1h4c.55 0 1-.45 1-1v-1H9v1zm3-19C8.14 2 5 5.14 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.86-3.14-7-7-7z"/>
                        </svg>
                        <span class="preview-pill-text visible" id="pill-trivia-text">Loading…</span>
                        <!-- Arrow -->
                        <svg class="preview-pill-arrow" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.8)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14M13 6l6 6-6 6"/>
                        </svg>
                    </a>

                    <!-- ── EXPANDED PREVIEW PILL: QUOTES (now occupies top-right area previously used by board button) ── -->
                    <a class="preview-pill preview-pill-large" id="pill-quotes"
                       href="/house/<%= encodeURIComponent(dormName) %>/<%= encodeURIComponent(houseName) %>/board#quotes"
                       style="top: 1rem; right: 1.25rem;"
                       title="Anonymous Quotes">
                        <!-- Double-quote / speech icon -->
                        <svg class="preview-pill-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="rgba(255,255,255,0.9)">
                            <path d="M9.983 3v7.391c0 5.704-3.731 9.57-8.983 10.609l-.995-2.151c2.432-.917 3.995-3.638 3.995-5.849h-4v-10h9.983zm14.017 0v7.391c0 5.704-3.748 9.571-9 10.609l-.996-2.151c2.433-.917 3.996-3.638 3.996-5.849h-3.983v-10h9.983z"/>
                        </svg>
                        <span class="preview-pill-text visible" id="pill-quotes-text">Loading…</span>
                        <svg class="preview-pill-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.9)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14M13 6l6 6-6 6"/>
                        </svg>
                    </a>

                    <!-- ── PREVIEW PILL: INSIDER TIPS (bottom-left) ── -->
                    <a class="preview-pill preview-pill-large" id="pill-tips"
                       href="/house/<%= encodeURIComponent(dormName) %>/<%= encodeURIComponent(houseName) %>/board#tips"
                       style="bottom: 2.6rem; left: 1.25rem;"
                       title="Insider Tips">
                        <!-- Map-pin / location icon -->
                        <svg class="preview-pill-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="rgba(255,255,255,0.85)">
                            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                        </svg>
                        <span class="preview-pill-text visible" id="pill-tips-text">Loading…</span>
                        <svg class="preview-pill-arrow" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.8)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14M13 6l6 6-6 6"/>
                        </svg>
                    </a>

                </div><!-- end house-banner -->

                <!-- Inline Stats Row -->
                <div class="house-stats-row" style="display:flex; align-items:stretch; justify-content:space-between; flex-wrap:nowrap; overflow-x:auto; gap:0; padding:0.75rem 1.5rem;">
                    <% const ratedRooms=rooms.filter(r=> r.houseCultureVal || r.outsideNoiseVal);
                        const cultureRated = rooms.filter(r => r.houseCultureVal);
                        const avgCulture = cultureRated.length ? (cultureRated.reduce((s,r) => s +
                        parseFloat(r.houseCultureVal), 0) / cultureRated.length).toFixed(1) : null;
                        const noiseRated = rooms.filter(r => r.outsideNoiseVal);
                        const avgNoise = noiseRated.length ? (noiseRated.reduce((s,r) => s +
                        parseFloat(r.outsideNoiseVal), 0) / noiseRated.length).toFixed(1) : null;
                        %>
                        <div style="display:flex; gap:0; flex-wrap:nowrap; align-items:center;">
                            <div class="house-stat-mini" style="padding:0.25rem 1.5rem 0.25rem 0; flex-direction:column; align-items:flex-start;">
                                <span class="house-stat-val" style="color:#0f172a; font-size:2.4rem; line-height:1;">
                                    <%= rooms.length %>
                                </span>
                                <span class="house-stat-lbl" style="font-size:0.72rem; margin-top:0.2rem;">Total Rooms</span>
                            </div>
                            <div class="house-stat-mini"
                                style="border-left:1px solid var(--border-color); padding:0.25rem 1.5rem; flex-direction:column; align-items:flex-start;">
                                <span class="house-stat-val" style="color:var(--accent-color); font-size:2.4rem; line-height:1;">
                                    <%= ratedRooms.length> 0 ? ratedRooms.length : '—' %>
                                </span>
                                <span class="house-stat-lbl" style="font-size:0.72rem; margin-top:0.2rem;">Reviews</span>
                            </div>
                            <% if (avgCulture !==null) { %>
                                <div class="house-stat-mini"
                                    style="border-left:1px solid var(--border-color); padding:0.25rem 1.5rem; flex-direction:column; align-items:flex-start;">
                                    <%
                                        var avgCultureRounded = Math.round(parseFloat(avgCulture));
                                        var avgCultureColors = { 5: '#34877A', 4: '#92B89D', 3: '#D69772', 2: '#C27654', 1: '#AE5436' };
                                        var avgCultureBg = avgCultureColors[avgCultureRounded] || '#92B89D';
                                        var avgCultureTxt = '#fff';
                                    %>
                                    <span class="house-stat-val" style="color:<%= avgCultureBg %>; font-size:2.4rem; line-height:1;">
                                        <%= avgCulture %>/5
                                    </span>
                                    <span class="house-stat-lbl" style="font-size:0.72rem; margin-top:0.2rem;">House Culture</span>
                                </div>
                                <% } %>
                                    <% if (avgNoise !==null) { %>
                                        <div class="house-stat-mini"
                                            style="border-left:1px solid var(--border-color); padding:0.25rem 1.5rem; flex-direction:column; align-items:flex-start;">
                                            <%
                                                var avgNoiseRounded = Math.round(parseFloat(avgNoise));
                                                var avgNoiseColors = { 1: '#34877A', 2: '#92B89D', 3: '#D69772', 4: '#C27654', 5: '#AE5436' };
                                                var avgNoiseBg = avgNoiseColors[avgNoiseRounded] || '#D69772';
                                                var avgNoiseTxt = '#fff';
                                            %>
                                            <span class="house-stat-val" style="color:<%= avgNoiseBg %>; font-size:2.4rem; line-height:1;">
                                                <%= avgNoise %>/5
                                            </span>
                                            <span class="house-stat-lbl" style="font-size:0.72rem; margin-top:0.2rem;">Noise Level</span>
                                        </div>
                                        <% } %>
                        </div>

                        <!-- House Rankings Display -->
                        <% if (typeof houseRanks !== 'undefined' && houseRanks) {
                            const categoryIcons = {
                                culture: { icon: '🏆', label: 'House<br>Culture' },
                                quietness: { icon: '🔇', label: 'Noise<br>Level' },
                                sunlight: { icon: '☀️', label: 'Nat.<br>Light' },
                                roomSize: { icon: '📦', label: 'Room<br>Size' },
                                tempControl: { icon: '🌡️', label: 'Temp<br>Control' }
                            };
                            // Display order: culture, roomSize, quietness, tempControl, sunlight
                            const displayOrder = ['culture', 'roomSize', 'quietness', 'tempControl', 'sunlight'];
                            const activeRanks = displayOrder
                                .filter(k => houseRanks[k] !== null && houseRanks[k] !== undefined)
                                .map(k => [k, houseRanks[k]]);
                            const totalHouses = typeof totalHousesInDorm !== 'undefined' ? totalHousesInDorm : 14;
                            if (activeRanks.length > 0) {
                        %>
                            <div style="display:flex; gap:0; flex-wrap:nowrap; align-items:center; border-left:1px solid var(--border-color); margin-left:auto;">
                                <% activeRanks.forEach(([cat, rank], idx) => {
                                    // Color scale: rank 1 = most green (#34877A), rank totalHouses = most red (#AE5436)
                                    const rankColors = ['#34877A','#92B89D','#D69772','#C27654','#AE5436'];
                                    const t = totalHouses <= 1 ? 0 : (rank - 1) / (totalHouses - 1);
                                    const colorIdx = Math.round(t * (rankColors.length - 1));
                                    const rankColor = rankColors[colorIdx];
                                %>
                                    <div class="house-stat-mini" style="flex-direction:column; align-items:flex-start; padding:0.25rem 1.25rem; <%= idx > 0 ? 'border-left:1px solid var(--border-color);' : '' %>">
                                        <span class="house-stat-val" style="font-size:2rem; line-height:1; color:var(--text-primary);">
                                            <span style="font-size:1.6rem; margin-right:3px; vertical-align:middle;"><%= categoryIcons[cat].icon %></span><span style="vertical-align:middle; color:<%= rankColor %>">#<%= rank %></span>
                                        </span>
                                        <span class="house-stat-lbl" style="font-size:0.72rem; margin-top:0.2rem; line-height:1.3;"><%- categoryIcons[cat].label %></span>
                                    </div>
                                <% }); %>
                            </div>
                        <%
                            }
                        } %>
                    </div>
                </div>

                <!-- ── Fix #2: Word Clouds side-by-side, below stats bar, above filter row ── -->
                <div class="word-cloud-row">
                    <% const cw = (typeof cultureWords !== 'undefined' ? cultureWords : []); %>
                    <div class="word-cloud-section">
                        <h3>Culture Vibes</h3>
                        <div class="word-cloud-sub">Selected from a checklist by residents; shows the most commonly chosen descriptors.</div>
                        <% if (cw.length > 0) { %>
                            <div id="culture-wordcloud" class="word-cloud-canvas"></div>
                            <div id="culture-wordcloud-fallback" class="word-cloud-fallback" style="display:none;"></div>
                            <div id="culture-wc-legend" style="display:flex; flex-wrap:wrap; margin-top:0.4rem; justify-content:center;"></div>
                        <% } else { %>
                            <div class="word-cloud-empty">No culture notes yet — be the first to submit.</div>
                        <% } %>
                    </div>
                    <% const hdw = (typeof houseDescriptorWords !== 'undefined' ? houseDescriptorWords : []); %>
                    <% if (hdw.length > 0) { %>
                    <div class="word-cloud-section">
                        <h3>House Descriptors</h3>
                        <div class="word-cloud-sub">Written freely by residents; shows the most frequently used words and phrases.</div>
                        <div id="descriptor-wordcloud" class="word-cloud-canvas"></div>
                        <div id="descriptor-wordcloud-fallback" class="word-cloud-fallback" style="display:none;"></div>
                        <div id="descriptor-wc-legend" style="display:flex; flex-wrap:wrap; margin-top:0.4rem; justify-content:center;"></div>
                    </div>
                    <% } %>
                </div>

                <!-- ── Floor Summary Section ── -->
                <%
                    // Compute per-floor averages and culture/descriptor vibes
                    var floorSummaryMap = {};
                    (typeof floors !== 'undefined' ? floors : []).forEach(function(f) {
                        floorSummaryMap[f] = { noise: [], roomSize: [], naturalLight: [], tempControl: [], culture: [], tags: {}, vibes: {} };
                    });
                    (typeof rooms !== 'undefined' ? rooms : []).forEach(function(r) {
                        if (!r.floor || !floorSummaryMap[r.floor]) return;
                        var fs = floorSummaryMap[r.floor];
                        if (r.outsideNoiseVal) fs.noise.push(parseFloat(r.outsideNoiseVal));
                        if (r.roomSizeVal) fs.roomSize.push(parseFloat(r.roomSizeVal));
                        if (r.naturalLightVal) fs.naturalLight.push(parseFloat(r.naturalLightVal));
                        if (r.tempControlVal) fs.tempControl.push(parseFloat(r.tempControlVal));
                        if (r.houseCultureVal) fs.culture.push(parseFloat(r.houseCultureVal));
                        if (r.tags) {
                            r.tags.split(', ').forEach(function(t) {
                                if (t) fs.tags[t] = (fs.tags[t] || 0) + 1;
                            });
                        }
                        // Culture vibes (cultureTags + culture notes) and house descriptors
                        if (Array.isArray(r.cultureTags)) {
                            r.cultureTags.forEach(function(v) {
                                if (v) fs.vibes[v] = (fs.vibes[v] || 0) + 1;
                            });
                        }
                        if (Array.isArray(r.houseDescriptors)) {
                            r.houseDescriptors.forEach(function(v) {
                                if (v) fs.vibes[v] = (fs.vibes[v] || 0) + 1;
                            });
                        }
                    });
                    function fsAvg(arr) { return arr.length ? (arr.reduce(function(a,b){return a+b;},0)/arr.length).toFixed(1) : null; }
                    function fsColorMap(val, inverted) {
                        if (!val) return 'transparent';
                        var r = Math.round(parseFloat(val));
                        var colors = inverted
                            ? { 1: '#34877A', 2: '#92B89D', 3: '#D69772', 4: '#C27654', 5: '#AE5436' }
                            : { 5: '#34877A', 4: '#92B89D', 3: '#D69772', 2: '#C27654', 1: '#AE5436' };
                        return colors[r] || '#92B89D';
                    }
                    var floorSummaryFloors = (typeof floors !== 'undefined' ? floors : []).filter(function(f) {
                        var fs = floorSummaryMap[f];
                        return fs && (fs.noise.length || fs.roomSize.length || fs.naturalLight.length || fs.tempControl.length || fs.culture.length);
                    });
                %>
                <% if (floorSummaryFloors.length > 0) { %>
                <div class="floor-summary-section" id="floor-summary-section">
                    <div class="floor-summary-title">Floor Summary</div>
                    <div class="floor-summary-subtitle">Click a floor row to filter the table below to that floor's rooms</div>
                    <div class="floor-summary-table-wrap">
                        <table class="floor-summary-table">
                            <thead>
                                <tr>
                                    <th>Floor</th>
                                    <th>Size</th>
                                    <th>Noise</th>
                                    <th>Temp</th>
                                    <th>Nat. Light</th>
                                    <th>Culture</th>
                                    <th>Top Culture Vibes &amp; Descriptors</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% floorSummaryFloors.forEach(function(f) {
                                    var fs = floorSummaryMap[f];
                                    var avgNoise = fsAvg(fs.noise);
                                    var avgSize = fsAvg(fs.roomSize);
                                    var avgLight = fsAvg(fs.naturalLight);
                                    var avgTemp = fsAvg(fs.tempControl);
                                    var avgCulture = fsAvg(fs.culture);
                                    // Top 5 culture vibes / descriptors for this floor
                                    var allVibesSorted = Object.keys(fs.vibes).sort(function(a,b){return fs.vibes[b]-fs.vibes[a];});
                                    // Only show >=2 mentions unless all are 1
                                    var hasMultiMention = allVibesSorted.some(function(v){ return fs.vibes[v] >= 2; });
                                    var filteredVibes = hasMultiMention
                                        ? allVibesSorted.filter(function(v){ return fs.vibes[v] >= 2; })
                                        : allVibesSorted;
                                    var topVibes = filteredVibes.slice(0,5);
                                %>
                                <tr class="floor-summary-row" data-floor="<%= f %>" title="Click to filter table to floor <%= f %>">
                                    <td class="floor-summary-floor-cell">
                                        <span style="font-weight:700; color:var(--text-primary);"><%= f %></span>
                                    </td>
                                    <td><% if (avgSize) { %><span class="fs-val" style="color:<%= fsColorMap(avgSize, false) %>"><%= avgSize %></span><% } else { %><span class="fs-na">—</span><% } %></td>
                                    <td><% if (avgNoise) { %><span class="fs-val" style="color:<%= fsColorMap(avgNoise, true) %>"><%= avgNoise %></span><% } else { %><span class="fs-na">—</span><% } %></td>
                                    <td><% if (avgTemp) { %><span class="fs-val" style="color:<%= fsColorMap(avgTemp, false) %>"><%= avgTemp %></span><% } else { %><span class="fs-na">—</span><% } %></td>
                                    <td><% if (avgLight) { %><span class="fs-val" style="color:<%= fsColorMap(avgLight, false) %>"><%= avgLight %></span><% } else { %><span class="fs-na">—</span><% } %></td>
                                    <td><% if (avgCulture) { %><span class="fs-val" style="color:<%= fsColorMap(avgCulture, false) %>"><%= avgCulture %></span><% } else { %><span class="fs-na">—</span><% } %></td>
                                    <td class="floor-summary-tags-cell">
                                        <% if (topVibes.length > 0) { %>
                                            <% topVibes.forEach(function(vibe) { %>
                                                <span class="fs-vibe-tag" data-vibe-count="<%= fs.vibes[vibe] %>" data-vibe-text="<%= vibe.replace(/"/g, '&quot;') %>"><%= vibe %></span>
                                            <% }); %>
                                        <% } else { %>
                                            <span class="fs-na">—</span>
                                        <% } %>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
                <% } %>

                <!-- ── Filters ── -->
                <div class="room-filters" id="room-filters">
                    <label>
                        Floor:
                        <select id="filter-floor">
                            <option value="">All</option>
                            <% (typeof floors !== 'undefined' ? floors : []).forEach(f => { %>
                                <option value="<%= f %>"><%= f %></option>
                            <% }) %>
                        </select>
                    </label>

                    <!-- Room Type: clickable tag buttons with X when active -->
                    <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
                        <span style="font-size:0.85rem; font-weight:600; color:var(--text-secondary);">Room Type:</span>
                        <div class="roomtype-tag-filters" id="roomtype-tag-filters">
                            <% (typeof roomTypes !== 'undefined' ? roomTypes : []).forEach(t => { %>
                                <button type="button" class="roomtype-tag-btn" data-roomtype="<%= t %>"><%= t %></button>
                            <% }) %>
                        </div>
                    </div>

                    <label>
                        <input type="checkbox" id="filter-hasreview">
                        Has Review
                    </label>

                    <!-- Filter by Tags dropdown -->
                    <div class="filter-tags-dropdown-wrapper" id="filter-tags-wrapper">
                        <button type="button" class="filter-tags-btn" id="filter-tags-toggle-btn">
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M10 18h4v-2h-4v2zm-7-10v2h18V8H3zm3 7h12v-2H6v2z"/></svg>
                            Filter by Tags
                        </button>
                        <div class="filter-tags-dropdown" id="filter-tags-dropdown">
                            <div class="filter-tags-dropdown-group">Space &amp; Layout</div>
                            <div class="filter-tags-dropdown-item" data-tag="Particularly high ceiling"><span class="ftd-check">✓</span> Particularly high ceiling</div>
                            <div class="filter-tags-dropdown-item" data-tag="Particularly low ceiling"><span class="ftd-check">✓</span> Particularly low ceiling</div>
                            <div class="filter-tags-dropdown-item" data-tag="Extra storage / closet space"><span class="ftd-check">✓</span> Extra storage / closet space</div>
                            <div class="filter-tags-dropdown-item" data-tag="Limited storage / closet space"><span class="ftd-check">✓</span> Limited storage / closet space</div>
                            <div class="filter-tags-dropdown-item" data-tag="Unusually shaped room"><span class="ftd-check">✓</span> Unusually shaped room</div>
                            <div class="filter-tags-dropdown-item" data-tag="Good furniture layout flexibility"><span class="ftd-check">✓</span> Good furniture layout flexibility</div>
                            <div class="filter-tags-dropdown-group">Light &amp; Windows</div>
                            <div class="filter-tags-dropdown-item" data-tag="Particularly big windows"><span class="ftd-check">✓</span> Particularly big windows</div>
                            <div class="filter-tags-dropdown-item" data-tag="Particularly small windows"><span class="ftd-check">✓</span> Particularly small windows</div>
                            <div class="filter-tags-dropdown-item" data-tag="Gets good sunlight"><span class="ftd-check">✓</span> Gets good sunlight</div>
                            <div class="filter-tags-dropdown-item" data-tag="Gets poor sunlight"><span class="ftd-check">✓</span> Gets poor sunlight</div>
                            <div class="filter-tags-dropdown-item" data-tag="Drafty windows"><span class="ftd-check">✓</span> Drafty windows</div>
                            <div class="filter-tags-dropdown-group">Noise</div>
                            <div class="filter-tags-dropdown-item" data-tag="Notable hallway noise"><span class="ftd-check">✓</span> Notable hallway noise</div>
                            <div class="filter-tags-dropdown-item" data-tag="Noise from adjacent rooms"><span class="ftd-check">✓</span> Noise from adjacent rooms</div>
                            <div class="filter-tags-dropdown-item" data-tag="Noise from above or below"><span class="ftd-check">✓</span> Noise from above or below</div>
                            <div class="filter-tags-dropdown-item" data-tag="Notably quiet"><span class="ftd-check">✓</span> Notably quiet</div>
                            <div class="filter-tags-dropdown-group">Temperature &amp; Air</div>
                            <div class="filter-tags-dropdown-item" data-tag="AC/heating issues"><span class="ftd-check">✓</span> AC/heating issues</div>
                            <div class="filter-tags-dropdown-item" data-tag="Gets very hot"><span class="ftd-check">✓</span> Gets very hot</div>
                            <div class="filter-tags-dropdown-item" data-tag="Gets very cold"><span class="ftd-check">✓</span> Gets very cold</div>
                            <div class="filter-tags-dropdown-item" data-tag="Good ventilation"><span class="ftd-check">✓</span> Good ventilation</div>
                            <div class="filter-tags-dropdown-item" data-tag="Poor ventilation"><span class="ftd-check">✓</span> Poor ventilation</div>
                            <div class="filter-tags-dropdown-item" data-tag="Significant radiator noise"><span class="ftd-check">✓</span> Significant radiator noise</div>
                        </div>
                    </div>

                    <!-- Chips + toggle locked together so toggle never wraps down (Fix #4) -->
                    <div style="display:flex; align-items:center; flex:1; min-width:0; gap:0.5rem;">
                        <!-- Active tag filter chips (populated by JS when user clicks a tag) -->
                        <div class="active-tag-chips-wrap" id="active-tag-chips-wrap" style="display:none;">
                            <div class="active-tag-chips" id="active-tag-chips"></div>
                        </div>

                        <!-- Profanity toggle + Clear filters — always locked to right end of row -->
                        <div class="filter-row-right">
                            <!-- Profanity toggle -->
                            <div class="profanity-toggle-group">
                                <span class="profanity-label">Profanity:</span>
                                <span class="profanity-info-icon" tabindex="0" aria-label="Info about profanity toggle">
                                    ⓘ
                                    <span class="profanity-tooltip">Toggles visibility of profane language in custom room names and notes. Some submissions contain adult language — this filter hides that content by default.</span>
                                </span>
                                <label class="toggle-switch">
                                    <input type="checkbox" id="censor-toggle" onchange="toggleCensorship()">
                                    <span class="toggle-slider"></span>
                                </label>
                            </div>

                            <button type="button" class="filter-clear-btn" id="filter-clear-btn">Clear filters</button>
                        </div>
                    </div>
                </div>

                <!-- Room Table -->
                <div class="table-container">
                    <table id="room-table">
                        <thead>
                            <tr>
                                <th class="sortable" data-sort-key="name" style="width:200px;">Room <span class="sort-indicator"></span></th>
                                <th class="sortable" data-sort-key="floor" style="width:52px; min-width:52px; max-width:60px; white-space:nowrap;">Floor <span class="sort-indicator"></span></th>
                                <th class="sortable" data-sort-key="roomType" style="width:28px; min-width:22px; max-width:34px;">Type <span class="sort-indicator"></span></th>
                                <th class="sortable" data-sort-key="tags" style="width:185px; min-width:165px; max-width:205px;">Tags <span class="sort-indicator"></span></th>
                                <th class="sortable" data-sort-key="roomSize">ROOM<br>SIZE <span class="sort-indicator"></span></th>
                                <th class="sortable" data-sort-key="noise">NOISE<br>LEVEL <span class="sort-indicator"></span></th>
                                <th class="sortable" data-sort-key="tempControl">TEMP<br>CONTROL <span class="sort-indicator"></span></th>
                                <th class="sortable" data-sort-key="naturalLight">NATURAL<br>LIGHT <span class="sort-indicator"></span></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% rooms.sort((a,b)=> {
                                const hasReviewA = (a.houseCultureVal || a.customName || a.tags) ? 1 : 0;
                                const hasReviewB = (b.houseCultureVal || b.customName || b.tags) ? 1 : 0;
                                if (hasReviewA !== hasReviewB) return hasReviewB - hasReviewA;

                                if (hasReviewA && hasReviewB) {
                                    const nameA = a.customName ? a.customName.toLowerCase() : "";
                                    const nameB = b.customName ? b.customName.toLowerCase() : "";

                                    if (nameA === 'shitbox suite' && nameB !== 'shitbox suite') return -1;
                                    if (nameB === 'shitbox suite' && nameA !== 'shitbox suite') return 1;

                                    if (nameA && nameB && nameA !== nameB) {
                                        return nameA.localeCompare(nameB);
                                    }
                                    if (nameA && !nameB) return -1;
                                    if (!nameA && nameB) return 1;
                                }

                                const n = (x) => parseInt(x.roomNumber) || 0;
                                return n(a)-n(b);
                            }).forEach(room => {
                                const hasReview = !!(room.houseCultureVal || room.customName || room.tags);
                                const displayName = room.customName ? room.customName : (room.roomType + ' ' + room.roomNumber);
                            %>
                                <tr style="cursor:pointer;"
                                    onclick="window.location='/rooms/<%= room.id %>'"
                                    data-floor="<%= room.floor || '' %>"
                                    data-roomtype="<%= room.roomType || '' %>"
                                    data-hasreview="<%= hasReview ? '1' : '0' %>"
                                    data-name="<%= displayName %>"
                                    data-tags="<%= room.tags || '' %>"
                                    data-culture="<%= room.houseCultureVal || '' %>"
                                    data-noise="<%= room.outsideNoiseVal || '' %>"
                                    data-roomsize="<%= room.roomSizeVal || '' %>"
                                    data-naturallight="<%= room.naturalLightVal || '' %>"
                                    data-tempcontrol="<%= room.tempControlVal || '' %>"
                                    data-roomnumber="<%= parseInt(room.roomNumber) || 0 %>">
                                    <td data-label="Room" style="font-weight:600; font-size:1.05em;">
                                        <% if (room.customName) { %>
                                            <div>
                                                <span class="room-name" data-original="<%= room.customName %>" style="color:#800000;">
                                                    <%= room.customName %>
                                                </span>
                                                <div
                                                    style="font-size:0.75em; font-style:italic; font-weight:400; color:var(--text-secondary); margin-top:0.15rem;">
                                                    (<%= room.roomType %> <%= room.roomNumber %>)</div>
                                            </div>
                                            <% } else { %>
                                                <span>
                                                    <%= room.roomType %> <%= room.roomNumber %>
                                                </span>
                                                <% } %>
                                    </td>
                                    <td data-label="Floor">
                                        <strong style="color:#000;"><%= room.floor || '—' %></strong>
                                    </td>
                                    <td data-label="Type">
                                        <span
                                            style="display:inline-block; padding:0.2em 0.6em; border-radius:0.4rem; font-size:0.78rem; font-weight:600;
                             background: <%= room.roomType && room.roomType.toLowerCase().includes('double') ? '#dbeafe' : room.roomType && room.roomType.toLowerCase().includes('suite') ? '#f3e8ff' : '#f3f4f6' %>;
                             color: <%= room.roomType && room.roomType.toLowerCase().includes('double') ? '#1d4ed8' : room.roomType && room.roomType.toLowerCase().includes('suite') ? '#7c3aed' : '#374151' %>;">
                                            <%= room.roomType || 'Single' %>
                                        </span>
                                    </td>
                                    <td data-label="Tags">
                                        <% if (room.tags) { %>
                                            <div style="display:flex; flex-wrap:wrap; gap:0.25rem; max-width:280px;">
                                                <% room.tags.split(', ').forEach(t => {
                                                    var tagSentiment = 'neutral';
                                                    var tl = t.toLowerCase();
                                                    // Positive tags (green scale)
                                                    if (tl === 'particularly high ceiling' || tl === 'extra storage / closet space' || tl === 'good furniture layout flexibility' || tl === 'particularly big windows' || tl === 'gets good sunlight' || tl === 'notably quiet' || tl === 'good ventilation') tagSentiment = 'positive';
                                                    // Strong negative tags (red)
                                                    else if (tl === 'limited storage / closet space' || tl === 'gets poor sunlight' || tl === 'notable hallway noise' || tl === 'noise from adjacent rooms' || tl === 'noise from above or below' || tl === 'ac/heating issues' || tl === 'poor ventilation') tagSentiment = 'negative';
                                                    // Mild negative tags (orange)
                                                    else if (tl === 'particularly small windows' || tl === 'particularly low ceiling' || tl === 'drafty windows' || tl === 'gets very hot' || tl === 'gets very cold' || tl === 'significant radiator noise') tagSentiment = 'mild-negative';
                                                    // Neutral/ambiguous
                                                    // else: 'neutral' (unusually shaped room)
                                                %>
                      <span class="tag" data-tag-sentiment="<%= tagSentiment %>" onclick="event.stopPropagation(); addTagFilter('<%= t.replace(/'/g, "&#39;") %>')" title="Filter by this tag"><%= t %></span>
                    <% }) %>
                  </div>
                <% } else { %>
                  <span style="color:#ccc; font-size:0.85rem;">—</span>
                <% } %>
              </td>
              <td data-label="Room Size">
                <% if (room.roomSizeVal) { %>
                  <%
                    var sizeRounded = Math.round(parseFloat(room.roomSizeVal));
                    var sizeColors = { 5: '#34877A', 4: '#92B89D', 3: '#D69772', 2: '#C27654', 1: '#AE5436' };
                    var sizeBg = sizeColors[sizeRounded] || 'transparent';
                  %>
                  <div style="display:flex; align-items:center; gap:0.4rem;">
                    <span style="display:inline-block; width:1.8em; text-align:center; padding:0.15em 0.15em; border-radius:0.3rem; font-size:1.15rem; font-weight:600; background-color:<%= sizeBg %>; color:#fff;"><%= room.roomSizeVal %></span>
                  </div>
                <% } else { %>
                  <span style="color:#ccc; font-size:0.8rem;">N/A</span>
                <% } %>
              </td>
              <td data-label="Noise Level">
                <% if (room.outsideNoiseVal) { %>
                  <%
                    var noiseRounded = Math.round(parseFloat(room.outsideNoiseVal));
                    var noiseColors = { 1: '#34877A', 2: '#92B89D', 3: '#D69772', 4: '#C27654', 5: '#AE5436' };
                    var noiseBg = noiseColors[noiseRounded] || 'transparent';
                  %>
                  <div style="display:flex; align-items:center; gap:0.4rem;">
                    <span style="display:inline-block; width:1.8em; text-align:center; padding:0.15em 0.15em; border-radius:0.3rem; font-size:1.15rem; font-weight:600; background-color:<%= noiseBg %>; color:#fff;"><%= room.outsideNoiseVal %></span>
                  </div>
                <% } else { %>
                  <span style="color:#ccc;">—</span>
                <% } %>
              </td>
              <td data-label="Temp Control">
                <% if (room.tempControlVal) { %>
                  <%
                    var tempRounded = Math.round(parseFloat(room.tempControlVal));
                    var tempColors = { 5: '#34877A', 4: '#92B89D', 3: '#D69772', 2: '#C27654', 1: '#AE5436' };
                    var tempBg = tempColors[tempRounded] || 'transparent';
                  %>
                  <div style="display:flex; align-items:center; gap:0.4rem;">
                    <span style="display:inline-block; width:1.8em; text-align:center; padding:0.15em 0.15em; border-radius:0.3rem; font-size:1.15rem; font-weight:600; background-color:<%= tempBg %>; color:#fff;"><%= room.tempControlVal %></span>
                  </div>
                <% } else { %>
                  <span style="color:#ccc; font-size:0.8rem;">N/A</span>
                <% } %>
              </td>
              <td data-label="Natural Light">
                <% if (room.naturalLightVal) { %>
                  <%
                    var lightRounded = Math.round(parseFloat(room.naturalLightVal));
                    var lightColors = { 5: '#34877A', 4: '#92B89D', 3: '#D69772', 2: '#C27654', 1: '#AE5436' };
                    var lightBg = lightColors[lightRounded] || 'transparent';
                  %>
                  <div style="display:flex; align-items:center; gap:0.4rem;">
                    <span style="display:inline-block; width:1.8em; text-align:center; padding:0.15em 0.15em; border-radius:0.3rem; font-size:1.15rem; font-weight:600; background-color:<%= lightBg %>; color:#fff;"><%= room.naturalLightVal %></span>
                  </div>
                <% } else { %>
                  <span style="color:#ccc; font-size:0.8rem;">N/A</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>


  </main>

  <footer><p>&copy; 2025 Room for Improvement</p></footer>

  <%- include('partials/ratingColors') %>

  <!-- D3 + d3-cloud from CDN for both word clouds -->
  <script src="https://d3js.org/d3.v7.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/d3-cloud@1/build/d3.layout.cloud.min.js"></script>

  <script>
    // Data injected from the server — for word clouds
    var CULTURE_WORDS    = <%- JSON.stringify(typeof cultureWords !== 'undefined' ? cultureWords : []) %>;
    var DESCRIPTOR_WORDS = <%- JSON.stringify(typeof houseDescriptorWords !== 'undefined' ? houseDescriptorWords : []) %>;

    // Basic stopword list for splitting free-text descriptors into useful tokens.
    var STOP = new Set(['the','a','an','and','or','but','of','in','on','to','for','with','is','it','its','this','that','these','those','be','are','was','were','at','by','my','your','our','their','very','really','just','not','no','yes','so','too','also']);

    // ── Deterministic theme classification ──────────────────────────────────
    // Themes are assigned deterministically based on keyword matching.
    // Given the same input, the same theme is always assigned.
    var THEMES = {
      'community':  { label: 'Community',   color: '#2563eb' },
      'social':     { label: 'Social',       color: '#7c3aed' },
      'academic':   { label: 'Academic',     color: '#0891b2' },
      'positive':   { label: 'Positive',     color: '#16a34a' },
      'negative':   { label: 'Negative',     color: '#dc2626' },
      'neutral':    { label: 'Neutral',      color: '#78716c' },
      'physical':   { label: 'Physical',     color: '#d97706' },
    };

    var THEME_KEYWORDS = [
      { theme: 'community',  words: ['welcoming','inclusive','tight-knit','tight','knit','community','friendly','warm','supportive','diverse','belonging','together','family','close','bond','connected','unity','cohesive','collaborative','welcom'] },
      { theme: 'social',     words: ['social','fun','lively','party','events','active','spirited','outgoing','vibrant','energetic','loud','noisy','busy','happening','nightlife','gatherings','hangout','chill','laid-back','relaxed','casual'] },
      { theme: 'academic',   words: ['studious','quiet','independent','focused','academic','study','intellectual','competitive','pressure','serious','hardworking','driven','ambitious','scholarly','research','library','work'] },
      { theme: 'positive',   words: ['great','good','nice','beautiful','clean','spacious','bright','cozy','comfortable','modern','amazing','love','best','awesome','excellent','wonderful','fantastic','perfect','ideal','pleasant','enjoyable','happy','positive'] },
      { theme: 'negative',   words: ['bad','dirty','small','dark','cramped','old','broken','worst','terrible','ugly','smelly','gross','cliquey','exclusive','disconnected','toxic','unwelcoming','hostile','isolated','lonely','negative','poor','awful'] },
      { theme: 'physical',   words: ['big','large','spacious','small','tiny','room','floor','window','light','sunlight','sunny','temperature','hot','cold','drafty','heating','ac','storage','ceiling','view','bathroom','kitchen','furniture','layout'] },
    ];

    function assignTheme(word) {
      var lower = word.toLowerCase().replace(/[^a-z0-9\-]/g, '');
      for (var i = 0; i < THEME_KEYWORDS.length; i++) {
        var entry = THEME_KEYWORDS[i];
        for (var j = 0; j < entry.words.length; j++) {
          if (lower.indexOf(entry.words[j]) !== -1 || entry.words[j].indexOf(lower) !== -1) {
            return entry.theme;
          }
        }
      }
      return 'neutral';
    }

    function themeColor(word, count, maxCount) {
      var theme = assignTheme(word);
      var baseColor = THEMES[theme].color;
      var mag = maxCount > 0 ? (count / maxCount) : 1;
      return { color: baseColor, opacity: 0.45 + 0.55 * mag, theme: theme };
    }

    // Turn raw phrase strings into [word, weight] pairs.
    // Used for house descriptors (free text) — tokenizes into words + phrases.
    // Words that already appear as part of a counted multi-word phrase are NOT
    // counted again individually to prevent double-counting.
    function tokenizePhrases(rawList) {
      var counts = {};
      // First pass: collect multi-word phrases (≤4 words, ≤40 chars)
      var phrasesAdded = new Set();
      rawList.forEach(function(raw) {
        if (!raw) return;
        var phrase = String(raw).trim();
        if (!phrase) return;
        var wordCount = phrase.split(/\s+/).length;
        if (wordCount > 1 && wordCount <= 4 && phrase.length <= 40) {
          var key = phrase.replace(/\s+/g,' ');
          counts[key] = (counts[key] || 0) + 2;
          phrasesAdded.add(key.toLowerCase());
        }
      });
      // Second pass: add individual word tokens, but skip words already covered
      // by a phrase that was counted above
      rawList.forEach(function(raw) {
        if (!raw) return;
        var phrase = String(raw).trim();
        if (!phrase) return;
        var wordCount = phrase.split(/\s+/).length;
        // If this whole phrase was already counted as a multi-word phrase, skip tokenizing it
        if (wordCount > 1 && phrasesAdded.has(phrase.toLowerCase().replace(/\s+/g,' '))) return;
        phrase.toLowerCase().split(/[^a-z0-9'-]+/).forEach(function(w) {
          if (!w || w.length < 3) return;
          if (STOP.has(w)) return;
          counts[w] = (counts[w] || 0) + 1;
        });
      });
      return Object.keys(counts).map(function(k) { return [k, counts[k]]; })
                                .sort(function(a,b) { return b[1] - a[1]; })
                                .slice(0, 80);
    }

    // Count exact phrases — used for culture vibes (fixed checklist items).
    function countExactPhrases(rawList) {
      var counts = {};
      rawList.forEach(function(raw) {
        if (!raw) return;
        var phrase = String(raw).trim();
        if (!phrase) return;
        var key = phrase.replace(/\s+/g,' ');
        counts[key] = (counts[key] || 0) + 1;
      });
      return Object.keys(counts).map(function(k) { return [k, counts[k]]; })
                                .sort(function(a,b) { return b[1] - a[1]; })
                                .slice(0, 80);
    }

    // ── Word cloud tooltip helpers ──
    function showWordCloudTooltip(word, count, event, dimension, container) {
      var tooltip = document.getElementById('wc-tooltip');
      var highlight = document.getElementById('wc-hover-highlight');
      if (!tooltip || !highlight) return;

      // Update tooltip content
      tooltip.querySelector('.wc-tooltip-word').textContent = word;
      tooltip.querySelector('.wc-tooltip-count').textContent = (count || 0) + ' responses';

      // Position tooltip near cursor
      var tx = event.clientX + 14;
      var ty = event.clientY - 10;
      // Keep tooltip on screen
      var tw = tooltip.offsetWidth || 160;
      if (tx + tw > window.innerWidth - 8) tx = event.clientX - tw - 10;
      if (ty < 8) ty = 8;
      tooltip.style.left = tx + 'px';
      tooltip.style.top = ty + 'px';
      tooltip.classList.add('visible');

      // Show highlight overlay at the word's bounding box with 15% size increase
      if (dimension) {
        var canvasRect = container.getBoundingClientRect();
        // dimension: { x, y, w, h } relative to canvas
        var wordX = canvasRect.left + dimension.x;
        var wordY = canvasRect.top + dimension.y;
        var wordW = dimension.w;
        var wordH = dimension.h;

        highlight.textContent = word;
        highlight.style.left = wordX + 'px';
        highlight.style.top = wordY + 'px';
        highlight.style.width = wordW + 'px';
        highlight.style.height = wordH + 'px';
        // Increase font size by ~15% from the rendered height
        highlight.style.fontSize = Math.round(wordH * 1.15) + 'px';
        highlight.style.color = '#800000';
        highlight.style.fontWeight = '700';
        highlight.style.opacity = '1';
      }
    }

    function hideWordCloudTooltip() {
      var tooltip = document.getElementById('wc-tooltip');
      var highlight = document.getElementById('wc-hover-highlight');
      if (tooltip) tooltip.classList.remove('visible');
      if (highlight) highlight.style.opacity = '0';
    }

    // ── Render a legend for the word cloud ──────────────────────────────────
    function renderLegend(legendEl, usedThemes, svgContainer, themeCounts, wordData) {
      if (!legendEl) return;
      legendEl.innerHTML = '';
      // Find max count for scaling
      var maxCount = 0;
      if (themeCounts) {
        Object.values(themeCounts).forEach(function(c) { if (c > maxCount) maxCount = c; });
      }
      var themesInOrder = ['community','social','academic','positive','negative','physical','neutral'];

      // Build sorted list: only used themes, sorted by count descending (largest dot first)
      var sortedThemes = themesInOrder.filter(function(key) { return usedThemes.has(key); });
      sortedThemes.sort(function(a, b) {
        var ca = (themeCounts && themeCounts[a]) ? themeCounts[a] : 0;
        var cb = (themeCounts && themeCounts[b]) ? themeCounts[b] : 0;
        return cb - ca;
      });

      // Build per-theme word breakdown for tooltip
      var themeWordBreakdown = {};
      if (wordData) {
        wordData.forEach(function(d) {
          if (!themeWordBreakdown[d.theme]) themeWordBreakdown[d.theme] = [];
          themeWordBreakdown[d.theme].push({ text: d.text, count: d.count });
        });
        // Sort each theme's words by count desc
        Object.keys(themeWordBreakdown).forEach(function(theme) {
          themeWordBreakdown[theme].sort(function(a, b) { return b.count - a.count; });
        });
      }

      sortedThemes.forEach(function(key) {
        var item = document.createElement('div');
        item.className = 'wc-legend-item';
        item.dataset.theme = key;
        item.style.cssText = 'display:inline-flex; align-items:center; gap:0.3rem; margin-right:0.75rem; margin-bottom:0.25rem; cursor:default; position:relative;';
        var dot = document.createElement('span');
        // Size dot based on count relative to max (min 6px, max 16px)
        var count = (themeCounts && themeCounts[key]) ? themeCounts[key] : 0;
        var dotSize = maxCount > 0 ? Math.round(6 + (count / maxCount) * 10) : 9;
        dot.style.cssText = 'display:inline-block; width:' + dotSize + 'px; height:' + dotSize + 'px; border-radius:50%; background:' + THEMES[key].color + '; flex-shrink:0;';
        var label = document.createElement('span');
        label.style.cssText = 'font-size:0.7rem; color:var(--text-secondary); font-weight:500;';
        label.textContent = THEMES[key].label;

        // Legend tooltip element (different from word hover tooltip)
        var legendTooltip = document.createElement('div');
        legendTooltip.className = 'wc-legend-tooltip';
        var words = themeWordBreakdown[key] || [];
        var breakdownHtml = '<div style="font-weight:700; margin-bottom:0.3rem; font-size:0.8rem;"><span style="color:#fff;">' + count + ' total mentions</span><span style="color:rgba(255,255,255,0.6);">: </span><span style="color:' + THEMES[key].color + ';">' + THEMES[key].label + '</span></div>';
        breakdownHtml += '<div style="border-top:1px solid rgba(255,255,255,0.2); margin-bottom:0.3rem;"></div>';
        words.forEach(function(w) {
          breakdownHtml += '<div style="display:flex; justify-content:space-between; gap:1rem; font-size:0.75rem;"><span style="color:rgba(255,255,255,0.9);">' + w.text + '</span><span style="color:rgba(255,255,255,0.6); font-weight:600;">' + w.count + '</span></div>';
        });
        legendTooltip.innerHTML = breakdownHtml;
        item.appendChild(legendTooltip);

        item.appendChild(dot);
        item.appendChild(label);
        // Hover: dim all other legend items AND dim non-matching words in the cloud
        item.addEventListener('mouseenter', function() {
          legendEl.classList.add('has-hover');
          item.classList.add('hovered');
          if (svgContainer) {
            d3.select(svgContainer).select('svg').selectAll('text')
              .transition().duration(150)
              .style('opacity', function(w) { return w.theme === key ? w.opacity : 0.08; });
          }
        });
        item.addEventListener('mouseleave', function() {
          legendEl.classList.remove('has-hover');
          item.classList.remove('hovered');
          if (svgContainer) {
            d3.select(svgContainer).select('svg').selectAll('text')
              .transition().duration(200)
              .style('opacity', function(w) { return w.opacity; });
          }
        });
        legendEl.appendChild(item);
      });
    }

    // ── Core D3-cloud renderer (used for both clouds) ────────────────────────
    function renderD3Cloud(container, legendEl, rawList, useExactPhrases) {
      if (!container || !rawList || rawList.length === 0) return;

      var pairs = useExactPhrases ? countExactPhrases(rawList) : tokenizePhrases(rawList);
      if (pairs.length === 0) return;

      var maxW = pairs[0][1];
      var width = container.clientWidth || 400;
      var height = 180;

      var usedThemes = new Set();
      var wordData = pairs.map(function(p) {
        var tc = themeColor(p[0], p[1], maxW);
        usedThemes.add(tc.theme);
        var sz = Math.max(11, (p[1] / maxW) * 46);
        return { text: p[0], size: sz, count: p[1], color: tc.color, opacity: tc.opacity, theme: tc.theme };
      });

      // Compute per-theme total response counts for legend sizing
      var themeCounts = {};
      wordData.forEach(function(d) {
        themeCounts[d.theme] = (themeCounts[d.theme] || 0) + d.count;
      });

      renderLegend(legendEl, usedThemes, container, themeCounts, wordData);

      var layout = d3.layout.cloud()
        .size([width, height])
        .words(wordData.map(function(d) {
          return { text: d.text, size: d.size, count: d.count, color: d.color, opacity: d.opacity, theme: d.theme };
        }))
        .padding(4)
        .rotate(function() { return 0; })
        .font('Georgia, serif')
        .fontSize(function(d) { return d.size; })
        .on('end', draw);

      layout.start();

      function draw(words) {
        if (!words || words.length === 0) return;

        var svg = d3.select(container).append('svg')
          .attr('width', width)
          .attr('height', height);

        var g = svg.append('g')
          .attr('transform', 'translate(' + (width / 2) + ',' + (height / 2) + ')');

        g.selectAll('text')
          .data(words)
          .enter().append('text')
          .style('font-size', function(d) { return d.size + 'px'; })
          .style('font-family', 'Georgia, serif')
          .style('fill', function(d) { return d.color; })
          .style('opacity', function(d) { return d.opacity; })
          .style('cursor', 'pointer')
          .attr('text-anchor', 'middle')
          .attr('transform', function(d) { return 'translate(' + d.x + ',' + d.y + ')'; })
          .text(function(d) { return d.text; })
          .on('mouseover', function(event, d) {
            // Dim all words of other themes in this cloud
            d3.select(this.closest('svg')).selectAll('text')
              .transition().duration(150)
              .style('opacity', function(w) {
                return w.theme === d.theme ? 1 : 0.12;
              })
              .style('font-size', function(w) {
                return w.theme === d.theme ? w.size + 'px' : w.size + 'px';
              });
            // Scale up the hovered word
            d3.select(this)
              .transition().duration(200)
              .style('font-size', (d.size * 1.4) + 'px')
              .style('opacity', 1);
            var tooltip = document.getElementById('wc-tooltip');
            if (tooltip) {
              // Build: "N mentions: Theme" with theme colored
              tooltip.innerHTML = '<span style="font-weight:600; color:#fff;">' + d.count + ' mentions</span><span style="color:rgba(255,255,255,0.6);">: </span><span style="font-weight:700; color:' + THEMES[d.theme].color + ';">' + THEMES[d.theme].label + '</span>';
              var tx = event.clientX + 14;
              var ty = event.clientY + 18;
              var tw = tooltip.offsetWidth || 160;
              var th = tooltip.offsetHeight || 36;
              if (tx + tw > window.innerWidth - 8) tx = event.clientX - tw - 10;
              if (ty + th > window.innerHeight - 8) ty = event.clientY - th - 10;
              if (ty < 8) ty = 8;
              tooltip.style.left = tx + 'px';
              tooltip.style.top = ty + 'px';
              tooltip.classList.add('visible');
            }
            // Dim legend items that don't match this theme
            var legendEl = this.closest('.word-cloud-section') ? this.closest('.word-cloud-section').querySelector('[id$="-wc-legend"]') : null;
            if (legendEl) {
              legendEl.classList.add('has-hover');
              legendEl.querySelectorAll('.wc-legend-item').forEach(function(item) {
                if (item.dataset.theme === d.theme) {
                  item.classList.add('hovered');
                } else {
                  item.classList.remove('hovered');
                }
              });
            }
          })
          .on('mouseout', function(event, d) {
            // Restore all words in this cloud
            d3.select(this.closest('svg')).selectAll('text')
              .transition().duration(200)
              .style('font-size', function(w) { return w.size + 'px'; })
              .style('opacity', function(w) { return w.opacity; });
            var tooltip = document.getElementById('wc-tooltip');
            if (tooltip) tooltip.classList.remove('visible');
            // Restore legend
            var legendEl = this.closest('.word-cloud-section') ? this.closest('.word-cloud-section').querySelector('[id$="-wc-legend"]') : null;
            if (legendEl) {
              legendEl.classList.remove('has-hover');
              legendEl.querySelectorAll('.wc-legend-item').forEach(function(item) {
                item.classList.remove('hovered');
              });
            }
          });
      }
    }

    // Render both clouds once DOM is ready
    document.addEventListener('DOMContentLoaded', function() {
      var cultureContainer = document.getElementById('culture-wordcloud');
      var cultureLegend = document.getElementById('culture-wc-legend');
      if (cultureContainer && CULTURE_WORDS.length > 0) {
        renderD3Cloud(cultureContainer, cultureLegend, CULTURE_WORDS, true); // exact phrases for fixed checklist
      }

      var descriptorContainer = document.getElementById('descriptor-wordcloud');
      var descriptorLegend = document.getElementById('descriptor-wc-legend');
      if (descriptorContainer && DESCRIPTOR_WORDS.length > 0) {
        renderD3Cloud(descriptorContainer, descriptorLegend, DESCRIPTOR_WORDS, false); // tokenize free text
      }

      // ── Apply theme colors to floor summary vibe tags ──
      document.querySelectorAll('.fs-vibe-tag').forEach(function(tagEl) {
        var text = tagEl.dataset.vibeText || tagEl.textContent.trim();
        var theme = (typeof assignTheme === 'function') ? assignTheme(text) : 'neutral';
        var color = (typeof THEMES !== 'undefined' && THEMES[theme]) ? THEMES[theme].color : '#78716c';
        // Parse hex color to apply as semi-transparent background
        var r = parseInt(color.slice(1,3),16);
        var g = parseInt(color.slice(3,5),16);
        var b = parseInt(color.slice(5,7),16);
        // Darken the color by ~40% for the font
        var dr = Math.round(r * 0.55);
        var dg = Math.round(g * 0.55);
        var db = Math.round(b * 0.55);
        tagEl.style.color = 'rgb(' + dr + ',' + dg + ',' + db + ')';
        tagEl.style.backgroundColor = 'rgba(' + r + ',' + g + ',' + b + ',0.1)';
        tagEl.style.borderColor = 'rgba(' + r + ',' + g + ',' + b + ',0.35)';
      });

      // ── Floor summary tag tooltips — identical to word cloud word hover ──
      var tooltip = document.getElementById('wc-tooltip');
      document.querySelectorAll('.fs-tag, .fs-vibe-tag').forEach(function(tagEl) {
        tagEl.addEventListener('mouseenter', function(e) {
          if (!tooltip) return;
          var count = parseInt(tagEl.dataset.tagCount || tagEl.dataset.vibeCount || '0');
          var tagText = tagEl.textContent.trim();
          // Determine theme using the same assignTheme function as the word cloud
          var theme = (typeof assignTheme === 'function') ? assignTheme(tagText) : 'neutral';
          var themeColor = (typeof THEMES !== 'undefined' && THEMES[theme]) ? THEMES[theme].color : '#78716c';
          var themeLabel = (typeof THEMES !== 'undefined' && THEMES[theme]) ? THEMES[theme].label : 'Neutral';
          tooltip.innerHTML = '<span style="font-weight:600; color:#fff;">' + count + ' mention' + (count !== 1 ? 's' : '') + '</span><span style="color:rgba(255,255,255,0.6);">: </span><span style="font-weight:700; color:' + themeColor + ';">' + themeLabel + '</span>';
          var tx = e.clientX + 14;
          var ty = e.clientY + 18;
          var tw = tooltip.offsetWidth || 160;
          var th = tooltip.offsetHeight || 36;
          if (tx + tw > window.innerWidth - 8) tx = e.clientX - tw - 10;
          if (ty + th > window.innerHeight - 8) ty = e.clientY - th - 10;
          if (ty < 8) ty = 8;
          tooltip.style.left = tx + 'px';
          tooltip.style.top = ty + 'px';
          tooltip.classList.add('visible');
        });
        tagEl.addEventListener('mousemove', function(e) {
          if (!tooltip) return;
          var tx = e.clientX + 14;
          var ty = e.clientY + 18;
          var tw = tooltip.offsetWidth || 160;
          var th = tooltip.offsetHeight || 36;
          if (tx + tw > window.innerWidth - 8) tx = e.clientX - tw - 10;
          if (ty + th > window.innerHeight - 8) ty = e.clientY - th - 10;
          if (ty < 8) ty = 8;
          tooltip.style.left = tx + 'px';
          tooltip.style.top = ty + 'px';
        });
        tagEl.addEventListener('mouseleave', function() {
          if (tooltip) tooltip.classList.remove('visible');
        });
      });
    });
  </script>

