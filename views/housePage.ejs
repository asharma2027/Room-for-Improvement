  <!-- wordcloud2.js from CDN for both word clouds -->
  <script src="https://cdn.jsdelivr.net/npm/wordcloud@1.2.2/src/wordcloud2.min.js"></script>

  <script>
    // Data injected from the server — for word clouds
    var CULTURE_WORDS    = <%- JSON.stringify(typeof cultureWords !== 'undefined' ? cultureWords : []) %>;
    var DESCRIPTOR_WORDS = <%- JSON.stringify(typeof houseDescriptorWords !== 'undefined' ? houseDescriptorWords : []) %>;

    // Basic stopword list for splitting free-text descriptors into useful tokens.
    var STOP = new Set(['the','a','an','and','or','but','of','in','on','to','for','with','is','it','its','this','that','these','those','be','are','was','were','at','by','my','your','our','their','very','really','just','not','no','yes','so','too','also']);

    // Turn raw phrase strings into [word, weight] pairs.
    // Keeps multi-word descriptor chips ("Tight-knit community") intact by treating whole phrases
    // as one token, then also contributes individual words from free-form notes.
    function tokenizePhrases(rawList) {
      var counts = {};
      rawList.forEach(function(raw) {
        if (!raw) return;
        var phrase = String(raw).trim();
        if (!phrase) return;
        // If it looks like a short tag/chip (<= 4 words), keep the whole phrase.
        var wordCount = phrase.split(/\s+/).length;
        if (wordCount <= 4 && phrase.length <= 40) {
          var key = phrase.replace(/\s+/g,' ');
          counts[key] = (counts[key] || 0) + 2;
        }
        // Also break into individual meaningful words.
        phrase.toLowerCase().split(/[^a-z0-9'-]+/).forEach(function(w) {
          if (!w || w.length < 3) return;
          if (STOP.has(w)) return;
          counts[w] = (counts[w] || 0) + 1;
        });
      });
      return Object.keys(counts).map(function(k) { return [k, counts[k]]; })
                                .sort(function(a,b) { return b[1] - a[1]; })
                                .slice(0, 80);
    }

    function renderWordCloud(containerId, fallbackId, list) {
      var container = document.getElementById(containerId);
      var fallback = document.getElementById(fallbackId);
      if (!container || !list || list.length === 0) return;

      var pairs = tokenizePhrases(list);
      if (pairs.length === 0) return;

      var maxW = pairs[0][1];
      var useCanvas = (typeof WordCloud === 'function');
      if (useCanvas) {
        try {
          WordCloud(container, {
            list: pairs,
            gridSize: 10,
            weightFactor: function(size) {
              // scale so top word ~48px, smallest ~12px
              return Math.max(12, (size / maxW) * 48);
            },
            fontFamily: 'Georgia, serif',
            color: function() {
              var palette = ['#800000','#b45309','#065f46','#0f766e','#4338ca','#7c3aed','#be185d','#1f2937'];
              return palette[Math.floor(Math.random() * palette.length)];
            },
            backgroundColor: '#fff',
            rotateRatio: 0.2,
            minRotation: -Math.PI / 12,
            maxRotation: Math.PI / 12,
            shrinkToFit: true
          });
          return;
        } catch(err) {
          // Fall through to CSS fallback
          console.warn('wordcloud2 failed, using CSS fallback', err);
        }
      }

      // CSS fallback: render weighted chips
      container.style.display = 'none';
      fallback.style.display = 'flex';
      fallback.innerHTML = '';
      pairs.forEach(function(p) {
        var span = document.createElement('span');
        span.className = 'wc-word';
        var sizePx = Math.max(12, (p[1] / maxW) * 40);
        span.style.fontSize = sizePx + 'px';
        span.style.opacity = String(0.55 + 0.45 * (p[1] / maxW));
        span.textContent = p[0];
        fallback.appendChild(span);
      });
    }

    // Render both clouds once DOM is ready
    document.addEventListener('DOMContentLoaded', function() {
      renderWordCloud('culture-wordcloud', 'culture-wordcloud-fallback', CULTURE_WORDS);
      renderWordCloud('descriptor-wordcloud', 'descriptor-wordcloud-fallback', DESCRIPTOR_WORDS);
    });
  </script>

