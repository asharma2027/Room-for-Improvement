<%- include('partials/head', { title: houseName + ' | Room for Improvement' }) %>

    <body>
        <%- include('partials/nav') %>

        <style>
            /* Preview pill shared styles */
            .preview-pill {
                position: absolute;
                z-index: 10;
                display: flex;
                align-items: center;
                gap: 0.55rem;
                padding: 0.5rem 0.8rem 0.5rem 0.65rem;
                background: rgba(255,255,255,0.12);
                backdrop-filter: blur(14px) saturate(1.8);
                -webkit-backdrop-filter: blur(14px) saturate(1.8);
                border: 1px solid rgba(255,255,255,0.2);
                border-radius: 2rem;
                text-decoration: none;
                color: rgba(255,255,255,0.95);
                text-align: left;
                max-width: 230px;
                box-shadow: 0 4px 18px rgba(0,0,0,0.25);
                transition: background 0.2s ease, box-shadow 0.2s ease, transform 0.18s ease;
                cursor: pointer;
                overflow: hidden;
            }
            .preview-pill:hover {
                background: rgba(255,255,255,0.22);
                box-shadow: 0 6px 28px rgba(0,0,0,0.35);
                transform: translateY(-2px);
            }
            .preview-pill-icon {
                flex-shrink: 0;
                width: 15px;
                height: 15px;
                opacity: 0.82;
            }
            .preview-pill-text {
                font-size: 0.7rem;
                font-weight: 500;
                letter-spacing: 0.01em;
                line-height: 1.4;
                flex: 1;
                min-width: 0;
                overflow: hidden;
                display: -webkit-box;
                -webkit-line-clamp: 2;
                -webkit-box-orient: vertical;
                position: relative;
            }
            /* Swipe transition for rotating text */
            .preview-pill-text.swiping-up {
                transform: translateY(-120%);
                opacity: 0;
                transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease;
            }
            .preview-pill-text.preparing {
                transform: translateY(120%);
                opacity: 0;
                transition: none; /* Instant reset to bottom */
            }
            .preview-pill-text.visible {
                transform: translateY(0);
                opacity: 1;
                transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease;
            }
            .preview-pill-arrow {
                flex-shrink: 0;
                opacity: 0.8;
            }

            /* ── Expanded top-right preview pill (now occupies space vacated by house board button) ── */
            .preview-pill-large {
                padding: 0.7rem 1rem;
                max-width: 290px;
                min-width: 220px;
                border-radius: 1.1rem;
                background: rgba(255,255,255,0.14);
                border: 1px solid rgba(255,255,255,0.24);
            }
            .preview-pill-large .preview-pill-icon {
                width: 18px;
                height: 18px;
            }
            .preview-pill-large .preview-pill-text {
                font-size: 0.82rem;
                line-height: 1.45;
                -webkit-line-clamp: 3;
                font-weight: 500;
            }
            .preview-pill-large .preview-pill-arrow {
                width: 14px;
                height: 14px;
            }

            /* ── Back pill sizing — slightly larger to match the reduced content pills ── */
            #pill-back {
                padding: 0.6rem 1rem;
                max-width: 200px;
                border-radius: 1.1rem;
                gap: 0.6rem;
            }
            #pill-back .preview-pill-icon {
                width: 17px;
                height: 17px;
            }
            #pill-back .preview-pill-text {
                font-size: 0.8rem;
                font-weight: 600;
            }

            /* Maroon "Back" pill (top-left, replaces trivia pill position) */
            .back-pill {
                background: rgba(128, 0, 0, 0.85);
                border: 1px solid rgba(255, 255, 255, 0.25);
                color: #fff;
            }
            .back-pill:hover {
                background: rgba(128, 0, 0, 1);
            }

            /* Maroon "house board" button under the house name header */
            .house-board-btn {
                display: inline-flex;
                align-items: center;
                gap: 0.5rem;
                background-color: #800000;
                color: #fff;
                padding: 0.65rem 1.2rem;
                border-radius: 0.5rem;
                font-weight: 700;
                text-decoration: none;
                box-shadow: 0 3px 10px rgba(0,0,0,0.28);
                transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
            }
            .house-board-btn:hover {
                background-color: #660000;
                transform: translateY(-1px);
                box-shadow: 0 6px 18px rgba(0,0,0,0.36);
            }

            /* ── Room table filters ── */
            .room-filters {
                display: flex;
                flex-wrap: wrap;
                gap: 1rem;
                align-items: center;
                margin: 1rem 0 0.75rem;
                padding: 0.75rem 1rem;
                background: #f9fafb;
                border: 1px solid var(--border-color);
                border-radius: 0.5rem;
            }
            .room-filters label {
                font-size: 0.85rem;
                font-weight: 600;
                color: var(--text-secondary);
                margin: 0;
                display: flex;
                align-items: center;
                gap: 0.4rem;
            }
            .room-filters select, .room-filters input[type="checkbox"] {
                font-size: 0.85rem;
            }
            .room-filters select {
                padding: 0.3rem 0.5rem;
                border: 1px solid var(--border-color);
                border-radius: 0.35rem;
                background: #fff;
            }
            .room-filters .filter-clear-btn {
                margin-left: auto;
                background: none;
                border: 1px solid var(--border-color);
                padding: 0.3rem 0.7rem;
                border-radius: 0.35rem;
                cursor: pointer;
                font-size: 0.8rem;
                color: var(--text-secondary);
            }
            .room-filters .filter-clear-btn:hover { background: #fff; }

            /* ── Room type tag buttons ── */
            .roomtype-tag-filters {
                display: flex;
                flex-wrap: wrap;
                gap: 0.4rem;
                align-items: center;
            }
            .roomtype-tag-btn {
                display: inline-flex;
                align-items: center;
                padding: 0.25rem 0.7rem;
                border: 1.5px solid #800000;
                border-radius: 2rem;
                background: #fff;
                color: #800000;
                font-size: 0.8rem;
                font-weight: 600;
                cursor: pointer;
                transition: background 0.15s, color 0.15s;
                user-select: none;
            }
            .roomtype-tag-btn:hover {
                background: rgba(128,0,0,0.08);
            }
            .roomtype-tag-btn.active {
                background: #800000;
                color: #fff;
            }

            /* ── Active tag filter chips (shown inside filter bar) ── */
            .active-tag-chips {
                display: flex;
                flex-wrap: wrap;
                gap: 0.35rem;
                align-items: center;
            }
            .active-tag-chip {
                display: inline-flex;
                align-items: center;
                gap: 0.25rem;
                padding: 0.2rem 0.55rem;
                background: #800000;
                color: #fff;
                border-radius: 2rem;
                font-size: 0.78rem;
                font-weight: 600;
                cursor: default;
            }
            .active-tag-chip .chip-remove {
                cursor: pointer;
                font-size: 0.9rem;
                line-height: 1;
                opacity: 0.8;
                margin-left: 0.15rem;
            }
            .active-tag-chip .chip-remove:hover { opacity: 1; }

            /* ── Tags in table rows are now clickable ── */
            #room-table .tag {
                cursor: pointer;
                transition: opacity 0.15s;
            }
            #room-table .tag:hover {
                opacity: 0.75;
            }

            /* ── Sortable table headers ── */
            th.sortable {
                cursor: pointer;
                user-select: none;
                position: relative;
            }
            th.sortable:hover { background: rgba(0,0,0,0.03); }
            th.sortable .sort-indicator {
                display: inline-block;
                margin-left: 0.3rem;
                font-size: 0.75rem;
                opacity: 0.45;
            }
            th.sortable.sort-asc .sort-indicator,
            th.sortable.sort-desc .sort-indicator {
                opacity: 1;
                color: var(--primary-color, #800000);
            }

            /* ── Word cloud sections ── */
            .word-cloud-section {
                margin-top: 2.5rem;
                padding: 1.25rem 1.5rem;
                background: #fdfdfd;
                border: 1px solid var(--border-color);
                border-radius: 0.6rem;
            }
            .word-cloud-section h3 {
                margin-top: 0;
                margin-bottom: 0.5rem;
                font-size: 1.15rem;
            }
            .word-cloud-section .word-cloud-sub {
                color: var(--text-secondary);
                font-size: 0.85rem;
                margin-bottom: 0.9rem;
            }
            .word-cloud-canvas {
                width: 100%;
                height: 260px;
                background: #fff;
                border: 1px dashed var(--border-color);
                border-radius: 0.4rem;
            }
            /* CSS fallback word cloud (used if wordcloud2 fails) */
            .word-cloud-fallback {
                display: flex;
                flex-wrap: wrap;
                gap: 0.4rem 0.8rem;
                align-items: baseline;
                padding: 1rem;
                background: #fff;
                border-radius: 0.4rem;
                min-height: 120px;
            }
            .word-cloud-fallback .wc-word {
                display: inline-block;
                padding: 0.15em 0.45em;
                line-height: 1.1;
                color: var(--primary-dark, #800000);
            }
            .word-cloud-empty {
                color: var(--text-secondary);
                font-style: italic;
                padding: 1rem;
            }
        </style>

            <main style="max-width:1200px; margin:0 auto; padding:2rem 1.5rem;">

                <!-- Header Banner -->
                <div class="house-banner" style="background-color: var(--primary-dark); <% if (typeof dormBackground !== 'undefined' && dormBackground) { %>background-image: linear-gradient(rgba(0,0,0,0.48), rgba(0,0,0,0.72)), url('<%= dormBackground %>'); background-size: cover; background-position: center;<% } %> position: relative; overflow: visible;">

                    <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; position:relative; z-index:2;">
                        <!-- House emblem -->
                        <% if (typeof houseEmblem !== 'undefined' && houseEmblem) { %>
                        <img src="<%= houseEmblem %>" alt="<%= houseName %> emblem" style="width:72px; height:72px; border-radius:50%; box-shadow: 0 4px 16px rgba(0,0,0,0.4); border: 3px solid rgba(255,255,255,0.2); margin-bottom:1rem; object-fit: cover; background-color: #fff;">
                        <% } else { %>
                        <div style="width:72px; height:72px; border-radius:50%; background:<%= houseColor %>;
                                display:flex; align-items:center; justify-content:center;
                                box-shadow: 0 4px 16px rgba(0,0,0,0.4); border: 3px solid rgba(255,255,255,0.2); margin-bottom:1rem;">
                            <span style="color:white; font-weight:800; font-size:1.5rem; letter-spacing:0.02em;">
                                <%= houseInitials %>
                            </span>
                        </div>
                        <% } %>
                        <h1 style="margin:0; font-size:2.5rem; font-weight:800; text-shadow:0 2px 4px rgba(0,0,0,0.5); color:white; text-align:center; display:flex; flex-direction:column; align-items:center;">
                            <span style="border-bottom:none; text-decoration:none;"><%= houseName %></span>
                            <div style="font-size: 1.35rem; font-weight:600; margin-top:0.25rem; white-space:nowrap; text-shadow:0 1px 3px rgba(0,0,0,0.4);">
                                (<a href="/dorm/<%= encodeURIComponent(dormName) %>" style="color:rgba(255,255,255,0.85); text-decoration:none;"><%= dormName.replace(/_/g,'-') %></a>)
                            </div>
                        </h1>

                        <!-- House board button — now positioned directly below the house name header -->
                        <a class="house-board-btn"
                           href="/house/<%= encodeURIComponent(dormName) %>/<%= encodeURIComponent(houseName) %>/board"
                           style="margin-top: 1.1rem;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zm-7-2h2v-2h-2v2zm0-4h2V7h-2v6z"/>
                            </svg>
                            Click here to access house board
                        </a>
                    </div>

                    <!-- ── BACK BUTTON PILL (top-left, navigates to rankings) ── -->
                    <a class="preview-pill back-pill" id="pill-back"
                       href="/dorm/<%= encodeURIComponent(dormName) %>"
                       style="top: 1rem; left: 1.25rem;"
                       title="Back to Rankings">
                        <svg class="preview-pill-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="rgba(255,255,255,0.95)">
                            <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
                        </svg>
                        <span class="preview-pill-text visible">Back to Rankings</span>
                    </a>

                    <!-- ── PREVIEW PILL: TRIVIA (moved to bottom-right) ── -->
                    <a class="preview-pill preview-pill-large" id="pill-trivia"
                       href="/house/<%= encodeURIComponent(dormName) %>/<%= encodeURIComponent(houseName) %>/board#trivia"
                       style="bottom: 2.6rem; right: 1.25rem;"
                       title="House Trivia">
                        <!-- Lightbulb icon -->
                        <svg class="preview-pill-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="rgba(255,255,255,0.85)">
                            <path d="M9 21c0 .55.45 1 1 1h4c.55 0 1-.45 1-1v-1H9v1zm3-19C8.14 2 5 5.14 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.86-3.14-7-7-7z"/>
                        </svg>
                        <span class="preview-pill-text visible" id="pill-trivia-text">Loading…</span>
                        <!-- Arrow -->
                        <svg class="preview-pill-arrow" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.8)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14M13 6l6 6-6 6"/>
                        </svg>
                    </a>

                    <!-- ── EXPANDED PREVIEW PILL: QUOTES (now occupies top-right area previously used by board button) ── -->
                    <a class="preview-pill preview-pill-large" id="pill-quotes"
                       href="/house/<%= encodeURIComponent(dormName) %>/<%= encodeURIComponent(houseName) %>/board#quotes"
                       style="top: 1rem; right: 1.25rem;"
                       title="Anonymous Quotes">
                        <!-- Double-quote / speech icon -->
                        <svg class="preview-pill-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="rgba(255,255,255,0.9)">
                            <path d="M9.983 3v7.391c0 5.704-3.731 9.57-8.983 10.609l-.995-2.151c2.432-.917 3.995-3.638 3.995-5.849h-4v-10h9.983zm14.017 0v7.391c0 5.704-3.748 9.571-9 10.609l-.996-2.151c2.433-.917 3.996-3.638 3.996-5.849h-3.983v-10h9.983z"/>
                        </svg>
                        <span class="preview-pill-text visible" id="pill-quotes-text">Loading…</span>
                        <svg class="preview-pill-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.9)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14M13 6l6 6-6 6"/>
                        </svg>
                    </a>

                    <!-- ── PREVIEW PILL: INSIDER TIPS (bottom-left) ── -->
                    <a class="preview-pill preview-pill-large" id="pill-tips"
                       href="/house/<%= encodeURIComponent(dormName) %>/<%= encodeURIComponent(houseName) %>/board#tips"
                       style="bottom: 2.6rem; left: 1.25rem;"
                       title="Insider Tips">
                        <!-- Map-pin / location icon -->
                        <svg class="preview-pill-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="rgba(255,255,255,0.85)">
                            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                        </svg>
                        <span class="preview-pill-text visible" id="pill-tips-text">Loading…</span>
                        <svg class="preview-pill-arrow" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.8)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14M13 6l6 6-6 6"/>
                        </svg>
                    </a>

                </div><!-- end house-banner -->

                <!-- Inline Stats Row -->
                <div class="house-stats-row" style="display:flex; align-items:center; justify-content:space-between; flex-wrap:nowrap; overflow-x:auto;">
                    <% const ratedRooms=rooms.filter(r=> r.houseCultureVal || r.outsideNoiseVal);
                        const cultureRated = rooms.filter(r => r.houseCultureVal);
                        const avgCulture = cultureRated.length ? (cultureRated.reduce((s,r) => s +
                        parseFloat(r.houseCultureVal), 0) / cultureRated.length).toFixed(1) : null;
                        const noiseRated = rooms.filter(r => r.outsideNoiseVal);
                        const avgNoise = noiseRated.length ? (noiseRated.reduce((s,r) => s +
                        parseFloat(r.outsideNoiseVal), 0) / noiseRated.length).toFixed(1) : null;
                        %>
                        <div style="display:flex; gap:1rem; flex-wrap:nowrap; align-items:center;">
                            <div class="house-stat-mini">
                                <span class="house-stat-val" style="color:<%= houseColor %>;">
                                    <%= rooms.length %>
                                </span>
                                <span class="house-stat-lbl">Total Rooms</span>
                            </div>
                            <div class="house-stat-mini"
                                style="border-left:1px solid var(--border-color); padding-left:1rem;">
                                <span class="house-stat-val" style="color:var(--accent-color);">
                                    <%= ratedRooms.length> 0 ? ratedRooms.length : '—' %>
                                </span>
                                <span class="house-stat-lbl">Reviews</span>
                            </div>
                            <% if (avgCulture !==null) { %>
                                <div class="house-stat-mini"
                                    style="border-left:1px solid var(--border-color); padding-left:1rem;">
                                    <span class="house-stat-val" style="color:var(--success-color);">
                                        <%= avgCulture %>/5
                                    </span>
                                    <span class="house-stat-lbl">Culture</span>
                                </div>
                                <% } %>
                                    <% if (avgNoise !==null) { %>
                                        <div class="house-stat-mini"
                                            style="border-left:1px solid var(--border-color); padding-left:1rem;">
                                            <span class="house-stat-val" style="color:var(--error-color);">
                                                <%= avgNoise %>/5
                                            </span>
                                            <span class="house-stat-lbl">Noise</span>
                                        </div>
                                        <% } %>
                        </div>

                        <!-- House Rankings Display -->
                        <% if (typeof houseRanks !== 'undefined' && houseRanks) {
                            const categoryIcons = {
                                culture: { icon: '🏆', label: 'Culture' },
                                quietness: { icon: '🔇', label: 'Quietness' },
                                sunlight: { icon: '☀️', label: 'Sunlight' },
                                roomSize: { icon: '📦', label: 'Room Size' },
                                tempControl: { icon: '❄️', label: 'Temp Control' }
                            };
                            const activeRanks = Object.entries(houseRanks).filter(([k,v]) => v !== null);
                            if (activeRanks.length > 0) {
                        %>
                            <div style="display:flex; gap:0.75rem; flex-wrap:nowrap; align-items:center; padding-left:1rem; border-left:1px solid var(--border-color); margin-left:auto;">
                                <% activeRanks.sort((a,b) => a[1] - b[1]).forEach(([cat, rank]) => {
                                    const isTop3 = rank <= 3;
                                %>
                                    <div class="house-stat-mini" style="align-items:center;">
                                        <span class="house-stat-val" style="font-size:1.1rem; color:<%= isTop3 ? 'var(--primary-color)' : 'var(--text-primary)' %>;">
                                            <span style="font-size:0.8rem; margin-right:2px;"><%= categoryIcons[cat].icon %></span>#<%= rank %>
                                        </span>
                                        <span class="house-stat-lbl"><%= categoryIcons[cat].label %></span>
                                    </div>
                                <% }); %>
                            </div>
                        <%
                            }
                        } %>
                    </div>
                </div>

                <!-- ── Filters ── -->
                <div class="room-filters" id="room-filters">
                    <label>
                        Floor:
                        <select id="filter-floor">
                            <option value="">All</option>
                            <% (typeof floors !== 'undefined' ? floors : []).forEach(f => { %>
                                <option value="<%= f %>"><%= f %></option>
                            <% }) %>
                        </select>
                    </label>

                    <!-- Room Type: clickable tag buttons instead of a dropdown -->
                    <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
                        <span style="font-size:0.85rem; font-weight:600; color:var(--text-secondary);">Room Type:</span>
                        <div class="roomtype-tag-filters" id="roomtype-tag-filters">
                            <% (typeof roomTypes !== 'undefined' ? roomTypes : []).forEach(t => { %>
                                <button type="button" class="roomtype-tag-btn" data-roomtype="<%= t %>"><%= t %></button>
                            <% }) %>
                        </div>
                    </div>

                    <label>
                        <input type="checkbox" id="filter-hasreview">
                        Has Review
                    </label>

                    <!-- Active tag filter chips (populated by JS when user clicks a tag) -->
                    <div class="active-tag-chips" id="active-tag-chips" style="display:none;"></div>

                    <button type="button" class="filter-clear-btn" id="filter-clear-btn">Clear filters</button>
                </div>

                <!-- Room Table -->
                <div class="table-container">
                    <table id="room-table">
                        <thead>
                            <tr>
                                <th class="sortable" data-sort-key="name" style="width:200px;">Room <span class="sort-indicator"></span></th>
                                <th class="sortable" data-sort-key="floor">Floor <span class="sort-indicator"></span></th>
                                <th class="sortable" data-sort-key="roomType">Type <span class="sort-indicator"></span></th>
                                <th class="sortable" data-sort-key="tags">Tags <span class="sort-indicator"></span></th>
                                <th class="sortable" data-sort-key="culture">Culture <span class="sort-indicator"></span></th>
                                <th class="sortable" data-sort-key="noise">Noise <span class="sort-indicator"></span></th>
                                <th class="sortable" data-sort-key="roomSize">Room Size <span class="sort-indicator"></span></th>
                                <th class="sortable" data-sort-key="naturalLight">Natural Light <span class="sort-indicator"></span></th>
                                <th class="sortable" data-sort-key="tempControl">Temp Control <span class="sort-indicator"></span></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% rooms.sort((a,b)=> {
                                const hasReviewA = (a.houseCultureVal || a.customName || a.tags) ? 1 : 0;
                                const hasReviewB = (b.houseCultureVal || b.customName || b.tags) ? 1 : 0;
                                if (hasReviewA !== hasReviewB) return hasReviewB - hasReviewA;

                                if (hasReviewA && hasReviewB) {
                                    const nameA = a.customName ? a.customName.toLowerCase() : "";
                                    const nameB = b.customName ? b.customName.toLowerCase() : "";

                                    if (nameA === 'shitbox suite' && nameB !== 'shitbox suite') return -1;
                                    if (nameB === 'shitbox suite' && nameA !== 'shitbox suite') return 1;

                                    if (nameA && nameB && nameA !== nameB) {
                                        return nameA.localeCompare(nameB);
                                    }
                                    if (nameA && !nameB) return -1;
                                    if (!nameA && nameB) return 1;
                                }

                                const n = (x) => parseInt(x.roomNumber) || 0;
                                return n(a)-n(b);
                            }).forEach(room => {
                                const hasReview = !!(room.houseCultureVal || room.customName || room.tags);
                                const displayName = room.customName ? room.customName : (room.roomType + ' ' + room.roomNumber);
                            %>
                                <tr style="cursor:pointer;"
                                    onclick="window.location='/rooms/<%= room.id %>'"
                                    data-floor="<%= room.floor || '' %>"
                                    data-roomtype="<%= room.roomType || '' %>"
                                    data-hasreview="<%= hasReview ? '1' : '0' %>"
                                    data-name="<%= displayName %>"
                                    data-tags="<%= room.tags || '' %>"
                                    data-culture="<%= room.houseCultureVal || '' %>"
                                    data-noise="<%= room.outsideNoiseVal || '' %>"
                                    data-roomsize="<%= room.roomSizeVal || '' %>"
                                    data-naturallight="<%= room.naturalLightVal || '' %>"
                                    data-tempcontrol="<%= room.tempControlVal || '' %>"
                                    data-roomnumber="<%= parseInt(room.roomNumber) || 0 %>">
                                    <td style="font-weight:600; font-size:1.05em;">
