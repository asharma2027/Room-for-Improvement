      'Snell_Hitchcock': [
        'Tower rooms look amazing but get cold in winter — pack an extra blanket.',
        'The grand common room is best for studying between 9am and noon on weekdays.',
        'Room selection: floors 3–5 strike the best balance of light and quiet.',
        'The building has surprisingly good cell reception for a historic structure.'
      ],
      'I-House': [
        'Cultural event invites come through the house email list — subscribe early.',
        'The garden courtyard is almost always quieter than indoor common spaces.',
        'Rooms on the north side face the street; rooms on the south side face the quad.',
        'The dining program often features international cuisine — check weekly menus.'
      ],
      'Max Palevsky': [
        'Pro tip: Regenstein Library has lockers you can rent by the quarter.',
        'The main courtyard is the best spot for an outdoor study session in spring.',
        'Rooms on the top floors of the east wing get the longest afternoon light.',
        'The house lounge kitchen gets restocked with event food late on Friday nights.'
      ],
      'Renee_Granville-Grossman': [
        'The 24-hour study lounge is genuinely underused — golden for late-night cramming.',
        'South-facing rooms get the most direct light throughout the day.',
        'The Metra stop is 5 minutes on foot — fastest route downtown on campus.',
        'Keep an eye on the house bulletin board for unofficial subletting during breaks.'
      ]
    };

    // Fallback generic data if dorm isn't matched
    var genericTrivia = [
      'UChicago residential houses each have their own unique culture and traditions.',
      'House lounges are the unofficial headquarters of first-year social life.',
      'Many dorm buildings have architectural features worth looking up — literally.'
    ];
    var genericQuotes = [
      '"The best part of living here was everything I didn\'t expect."',
      '"You find your people faster than you think you will."',
      '"House culture is what you make it — but it usually makes itself."'
    ];
    var genericTips = [
      'Introduce yourself to your RA in week one — they know everything.',
      'Upper floors tend to be quieter and get more natural light.',
      'Always check the house group chat before buying something for the common room.'
    ];

    var triviaList  = TRIVIA[dorm]  || genericTrivia;
    var quotesList  = QUOTES[dorm]  || genericQuotes;
    var tipsList    = TIPS[dorm]    || genericTips;

    function rotator(elId, items, delayMs) {
      if (!items || items.length === 0) return;
      var el = document.getElementById(elId);
      if (!el) return;
      var idx = Math.floor(Math.random() * items.length);
      el.textContent = items[idx];
      if (items.length <= 1) return; // no need to rotate

      var DISPLAY_MS = 5000; // 5 seconds per item
      
      setTimeout(function() {
        setInterval(function() {
          // Swipe out up
          el.classList.remove('visible');
          el.classList.add('swiping-up');
          
          setTimeout(function() {
            // Instantly move to bottom
            idx = (idx + 1) % items.length;
            el.textContent = items[idx];
            el.classList.remove('swiping-up');
            el.classList.add('preparing');
            
            // Allow browser to render the instant move, then swipe in
            requestAnimationFrame(function() {
              requestAnimationFrame(function() {
                el.classList.remove('preparing');
                el.classList.add('visible');
              });
            });
          }, 400); // Wait for swipe out to finish
        }, DISPLAY_MS);
      }, delayMs);
    }

    // Stagger starts to avoid sensory overload
    rotator('pill-trivia-text', triviaList, 0);
    rotator('pill-quotes-text', quotesList, 1500);
    rotator('pill-tips-text',   tipsList, 3000);
  })();
  </script>

  <script>
    // Profanity filter - common inappropriate words
    const badWords = ['damn', 'hell', 'fuck', 'shit', 'ass', 'bitch', 'bastard', 'crap', 'piss', 'cock', 'dick', 'pussy', 'slut', 'whore', 'fag', 'nigger', 'nigga', 'cunt', 'twat'];

    function censorText(text) {
      let censored = text;
      const lowerText = text.toLowerCase();

      badWords.forEach(word => {
        const regex = new RegExp(word, 'gi');
        censored = censored.replace(regex, (match) => {
          return '*'.repeat(match.length);
        });
      });

      return censored;
    }

    function toggleCensorship() {
      const isChecked = document.getElementById('censor-toggle').checked;
      const roomNames = document.querySelectorAll('.room-name');

      roomNames.forEach(name => {
        const original = name.getAttribute('data-original');
        if (original) {
          if (isChecked) {
            // Show original
            name.textContent = original;
          } else {
            // Apply censorship
            name.textContent = censorText(original);
          }
        }
      });
    }

    // Apply censorship on page load (default state is censored)
    document.addEventListener('DOMContentLoaded', function () {
      toggleCensorship();
    });
  </script>

