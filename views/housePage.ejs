  <!-- ── Client-side filters + column sorting ── -->
  <script>
  (function() {
    var table = document.getElementById('room-table');
    if (!table) return;
    var tbody = table.tBodies[0];
    var allRows = Array.prototype.slice.call(tbody.rows);

    // Keys that should default to DESCENDING on first click
    var descFirstKeys = new Set(['culture','roomsize','naturallight','tempcontrol']);

    // Helpers
    function getKey(row, key) {
      var v = row.dataset[key.toLowerCase()] || '';
      // numeric fields
      if (['culture','noise','roomsize','naturallight','tempcontrol','roomnumber'].indexOf(key.toLowerCase()) !== -1) {
        var n = parseFloat(v);
        return isNaN(n) ? null : n;
      }
      if (key === 'floor') {
        var fn = parseFloat(v);
        return isNaN(fn) ? v.toLowerCase() : fn;
      }
      return v.toLowerCase();
    }

    // ── Room Type Tag Buttons ────────────────────────────────
    var activeRoomType = '';
    var roomTypeBtns = document.querySelectorAll('.roomtype-tag-btn');
    roomTypeBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var val = btn.dataset.roomtype;
        if (activeRoomType === val) {
          // deselect
          activeRoomType = '';
          btn.classList.remove('active');
        } else {
          roomTypeBtns.forEach(function(b) { b.classList.remove('active'); });
          activeRoomType = val;
          btn.classList.add('active');
        }
        applyFilters();
      });
    });

    // ── Active Tag Chips (Change 5) ────────────────────────────
    var activeTagFilters = [];
    var chipsContainer = document.getElementById('active-tag-chips');

    window.addTagFilter = function(tag) {
      if (activeTagFilters.indexOf(tag) !== -1) return; // already active
      activeTagFilters.push(tag);
      renderTagChips();
      applyFilters();
    };

    function removeTagFilter(tag) {
      var idx = activeTagFilters.indexOf(tag);
      if (idx !== -1) activeTagFilters.splice(idx, 1);
      renderTagChips();
      applyFilters();
    }

    var chipsWrap = document.getElementById('active-tag-chips-wrap');

    function updateChipsOverflow() {
      if (!chipsWrap || !chipsContainer) return;
      var hasOverflow = chipsContainer.scrollWidth > chipsContainer.clientWidth;
      chipsWrap.classList.toggle('has-overflow', hasOverflow);
    }

    function renderTagChips() {
      if (!chipsContainer) return;
      if (activeTagFilters.length === 0) {
        if (chipsWrap) chipsWrap.style.display = 'none';
        chipsContainer.innerHTML = '';
        return;
      }
      if (chipsWrap) chipsWrap.style.display = 'flex';
      chipsContainer.innerHTML = activeTagFilters.map(function(tag) {
        var safeTag = tag.replace(/\\/g,'\\\\').replace(/'/g,"\\'");
        return '<span class="active-tag-chip">'
          + tag
          + '<span class="chip-remove" title="Remove filter" onclick="window.hpRemoveTagFilter(\'' + safeTag + '\')">&times;</span></span>';
      }).join('');
      // Check for horizontal overflow (to show scroll fade hint)
      requestAnimationFrame(updateChipsOverflow);
    }

    // Expose removeTagFilter globally so onclick handlers in chips work
    window.hpRemoveTagFilter = function(tag) {
      var idx = activeTagFilters.indexOf(tag);
      if (idx !== -1) activeTagFilters.splice(idx, 1);
      renderTagChips();
      // Sync dropdown item selected state
      document.querySelectorAll('.filter-tags-dropdown-item').forEach(function(item) {
        if (item.dataset.tag === tag) item.classList.remove('selected');
      });
      applyFilters();
    };

    // ── Filters ─────────────────────────────────────────────
    var floorSel = document.getElementById('filter-floor');
    var reviewChk = document.getElementById('filter-hasreview');
    var clearBtn = document.getElementById('filter-clear-btn');

    function applyFilters() {
      var f = floorSel ? floorSel.value : '';
      var t = activeRoomType;
      var r = reviewChk ? reviewChk.checked : false;
      allRows.forEach(function(row) {
        var show = true;
        if (f && row.dataset.floor !== f) show = false;
        if (t && row.dataset.roomtype !== t) show = false;
        if (r && row.dataset.hasreview !== '1') show = false;
        // Tag chip filters: row must contain ALL active tag filters
        if (activeTagFilters.length > 0) {
          var rowTagsRaw = (row.dataset.tags || '').split(', ');
          var rowTags = rowTagsRaw.map(function(s) { return s.trim().toLowerCase(); });
          var allMatch = activeTagFilters.every(function(tag) {
            return rowTags.indexOf(tag.trim().toLowerCase()) !== -1;
          });
          if (!allMatch) show = false;
        }
        row.style.display = show ? '' : 'none';
      });
      // Sync floor summary active state
      document.querySelectorAll('.floor-summary-row').forEach(function(summaryRow) {
        summaryRow.classList.toggle('active-floor-filter', summaryRow.dataset.floor === f && f !== '');
      });
    }
    if (floorSel)  floorSel.addEventListener('change', applyFilters);
    if (reviewChk) reviewChk.addEventListener('change', applyFilters);
    if (clearBtn) {
      clearBtn.addEventListener('click', function() {
        if (floorSel) floorSel.value = '';
        activeRoomType = '';
        roomTypeBtns.forEach(function(b) { b.classList.remove('active'); });
        if (reviewChk) reviewChk.checked = false;
        activeTagFilters = [];
        renderTagChips();
        // Reset dropdown items
        document.querySelectorAll('.filter-tags-dropdown-item').forEach(function(item) {
          item.classList.remove('selected');
        });
        // Reset floor summary active state
        document.querySelectorAll('.floor-summary-row').forEach(function(r) { r.classList.remove('active-floor-filter'); });
        applyFilters();
      });
    }

    // ── Floor Summary Row Click-to-Filter ──────────────────────────────────
    document.querySelectorAll('.floor-summary-row').forEach(function(row) {
      row.addEventListener('click', function() {
        var floor = row.dataset.floor;
        if (!floor || !floorSel) return;
        // Toggle: if already filtering this floor, clear it
        if (floorSel.value === floor) {
          floorSel.value = '';
          row.classList.remove('active-floor-filter');
        } else {
          floorSel.value = floor;
          document.querySelectorAll('.floor-summary-row').forEach(function(r) { r.classList.remove('active-floor-filter'); });
          row.classList.add('active-floor-filter');
        }
        applyFilters();
      });
    });

    // ── Filter-by-Tags Dropdown ──────────────────────────────
    var tagsToggleBtn = document.getElementById('filter-tags-toggle-btn');
    var tagsDropdown = document.getElementById('filter-tags-dropdown');
    if (tagsToggleBtn && tagsDropdown) {
      tagsToggleBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        var isOpen = tagsDropdown.classList.contains('open');
        tagsDropdown.classList.toggle('open', !isOpen);
        tagsToggleBtn.classList.toggle('open', !isOpen);
      });
      document.addEventListener('click', function(e) {
        if (!tagsToggleBtn.contains(e.target) && !tagsDropdown.contains(e.target)) {
          tagsDropdown.classList.remove('open');
          tagsToggleBtn.classList.remove('open');
        }
      });
      tagsDropdown.querySelectorAll('.filter-tags-dropdown-item').forEach(function(item) {
        item.addEventListener('click', function(e) {
          e.stopPropagation();
          var tag = item.dataset.tag;
          if (!tag) return;
          if (activeTagFilters.indexOf(tag) !== -1) {
            // Remove
            window.hpRemoveTagFilter(tag);
            item.classList.remove('selected');
          } else {
            // Add
            activeTagFilters.push(tag);
            item.classList.add('selected');
            renderTagChips();
            applyFilters();
          }
        });
      });
    }

    // ── Sorting ─────────────────────────────────────────────
    var currentSort = { key: null, dir: 1 };
    var headers = table.querySelectorAll('th.sortable');

    function clearIndicators() {
      headers.forEach(function(h) {
        h.classList.remove('sort-asc','sort-desc');
        var ind = h.querySelector('.sort-indicator');
        if (ind) ind.textContent = '';
      });
    }

    function sortBy(key) {
      var dir;
      if (currentSort.key === key) {
        // Toggle direction
        dir = -currentSort.dir;
      } else {
        // First click: use descending (-1) for rating columns, ascending (1) for others
        dir = descFirstKeys.has(key) ? -1 : 1;
      }
      currentSort = { key: key, dir: dir };

      var sorted = allRows.slice().sort(function(a, b) {
        var va = getKey(a, key);
        var vb = getKey(b, key);
        // Nulls/empty strings always sort to the bottom regardless of direction
        var aEmpty = (va === null || va === undefined || va === '');
        var bEmpty = (vb === null || vb === undefined || vb === '');
        if (aEmpty && !bEmpty) return 1;
        if (!aEmpty && bEmpty) return -1;
        if (aEmpty && bEmpty) return 0;

        if (typeof va === 'number' && typeof vb === 'number') {
          return (va - vb) * dir;
        }
        return String(va).localeCompare(String(vb)) * dir;
      });

      // Re-append in new order
      sorted.forEach(function(row) { tbody.appendChild(row); });

      clearIndicators();
      var th = table.querySelector('th.sortable[data-sort-key="' + key + '"]');
      if (th) {
        th.classList.add(dir === 1 ? 'sort-asc' : 'sort-desc');
        var ind = th.querySelector('.sort-indicator');
        if (ind) ind.textContent = dir === 1 ? '▲' : '▼';
      }
    }

    headers.forEach(function(h) {
      h.addEventListener('click', function() {
        sortBy(h.dataset.sortKey);
      });
    });
  })();
  </script>

  <script>
    // Profanity filter - common inappropriate words
    const badWords = ['damn', 'hell', 'fuck', 'shit', 'ass', 'bitch', 'bastard', 'crap', 'piss', 'cock', 'dick', 'pussy', 'slut', 'whore', 'fag', 'nigger', 'nigga', 'cunt', 'twat'];

    function censorText(text) {
      let censored = text;
      const lowerText = text.toLowerCase();

      badWords.forEach(word => {
        const regex = new RegExp(word, 'gi');
        censored = censored.replace(regex, (match) => {
          return '*'.repeat(match.length);
        });
      });

      return censored;
    }

    function toggleCensorship() {
      const toggleEl = document.getElementById('censor-toggle');
      const isChecked = toggleEl ? toggleEl.checked : false;
      const roomNames = document.querySelectorAll('.room-name');

      roomNames.forEach(name => {
        const original = name.getAttribute('data-original');
        if (original) {
          if (isChecked) {
            // Show original
            name.textContent = original;
          } else {
            // Apply censorship
            name.textContent = censorText(original);
          }
        }
      });
    }

    // Apply censorship on page load (default state is censored)
    document.addEventListener('DOMContentLoaded', function () {
      toggleCensorship();
    });
  </script>

</body>
