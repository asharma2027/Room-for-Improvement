    ];

    var triviaList  = TRIVIA[dorm]  || genericTrivia;
    var quotesList  = QUOTES[dorm]  || genericQuotes;
    var tipsList    = TIPS[dorm]    || genericTips;

    function rotator(elId, items, delayMs) {
      if (!items || items.length === 0) return;
      var el = document.getElementById(elId);
      if (!el) return;
      var idx = Math.floor(Math.random() * items.length);
      el.textContent = items[idx];
      if (items.length <= 1) return; // no need to rotate

      var DISPLAY_MS = 12000; // 12 seconds per item

      setTimeout(function() {
        setInterval(function() {
          // Swipe out up
          el.classList.remove('visible');
          el.classList.add('swiping-up');

          setTimeout(function() {
            // Instantly move to bottom
            idx = (idx + 1) % items.length;
            el.textContent = items[idx];
            el.classList.remove('swiping-up');
            el.classList.add('preparing');

            // Allow browser to render the instant move, then swipe in
            requestAnimationFrame(function() {
              requestAnimationFrame(function() {
                el.classList.remove('preparing');
                el.classList.add('visible');
              });
            });
          }, 800); // Wait for swipe out to finish
        }, DISPLAY_MS);
      }, delayMs);
    }

    // Stagger starts to avoid sensory overload
    rotator('pill-trivia-text', triviaList, 0);
    rotator('pill-quotes-text', quotesList, 1500);
    rotator('pill-tips-text',   tipsList, 3000);
  })();
