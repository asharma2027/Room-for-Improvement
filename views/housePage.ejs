                                                    (<%= room.roomType %> <%= room.roomNumber %>)</div>
                                            </div>
                                            <% } else { %>
                                                <span>
                                                    <%= room.roomType %> <%= room.roomNumber %>
                                                </span>
                                                <% } %>
                                    </td>
                                    <td>
                                        <%= room.floor || '—' %>
                                    </td>
                                    <td>
                                        <span
                                            style="display:inline-block; padding:0.2em 0.6em; border-radius:0.4rem; font-size:0.78rem; font-weight:600;
                             background: <%= room.roomType && room.roomType.toLowerCase().includes('double') ? '#dbeafe' : room.roomType && room.roomType.toLowerCase().includes('suite') ? '#f3e8ff' : '#f3f4f6' %>;
                             color: <%= room.roomType && room.roomType.toLowerCase().includes('double') ? '#1d4ed8' : room.roomType && room.roomType.toLowerCase().includes('suite') ? '#7c3aed' : '#374151' %>;">
