<%- include('partials/head', { title: 'Submit a Review | Room for Improvement' }) %>

  <body>
    <%- include('partials/nav') %>
    <style>
      .sr-container {
        max-width: 640px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }
      .sr-header {
        margin-bottom: 2rem;
      }
      .sr-header h1 {
        margin-bottom: 0.25rem;
        font-size: 1.9rem;
      }
      .sr-header p {
        color: var(--text-secondary);
        margin: 0;
        font-size: 0.95rem;
      }
      .sr-field {
        margin-bottom: 1.25rem;
      }
      .sr-field label {
        display: block;
        font-weight: 600;
        font-size: 0.88rem;
        color: var(--text-secondary);
        margin-bottom: 0.4rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }
      .sr-field select,
      .sr-field input[type="text"] {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 2px solid var(--border-color);
        border-radius: var(--radius-md);
        font-size: 0.95rem;
        background: #fff;
        color: var(--text-primary);
        transition: border-color 0.2s;
      }
      .sr-field select:focus,
      .sr-field input[type="text"]:focus {
        outline: none;
        border-color: var(--primary-color);
        box-shadow: 0 0 0 3px rgba(123,0,26,0.1);
      }
      .sr-field select:disabled {
        background: #f9fafb;
        color: #aaa;
        cursor: not-allowed;
      }

      /* Room number typeahead */
      .sr-room-wrapper {
        position: relative;
      }
      .sr-room-dropdown {
        display: none;
        position: absolute;
        top: calc(100% + 4px);
        left: 0;
        right: 0;
        z-index: 200;
        background: #fff;
        border: 1.5px solid var(--border-color);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-lg);
        max-height: 280px;
        overflow-y: auto;
      }
      .sr-room-dropdown.open { display: block; }
      .sr-room-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.6rem 1rem;
        cursor: pointer;
        border-bottom: 1px solid #f3f4f6;
        transition: background 0.12s;
        font-size: 0.9rem;
      }
      .sr-room-item:last-child { border-bottom: none; }
      .sr-room-item:hover { background: #fdf2f2; }
      .sr-room-item .sr-room-num {
        font-weight: 700;
        color: var(--text-primary);
      }
      .sr-room-item .sr-room-meta {
        font-size: 0.78rem;
        color: var(--text-secondary);
      }
      .sr-room-item.sr-add-new {
        color: var(--primary-color);
        font-weight: 600;
        font-style: italic;
      }
      .sr-room-item.sr-add-new:hover { background: rgba(123,0,26,0.05); }

      .sr-go-btn {
        width: 100%;
        padding: 0.85rem;
        font-size: 1rem;
        margin-top: 0.5rem;
        border-radius: var(--radius-full);
      }
      .sr-go-btn:disabled {
        opacity: 0.45;
        cursor: not-allowed;
        transform: none !important;
        box-shadow: none !important;
      }

      .sr-back {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        color: var(--text-secondary);
        font-size: 0.88rem;
        font-weight: 500;
        text-decoration: none;
        margin-bottom: 1.5rem;
      }
      .sr-back:hover { color: var(--primary-color); }
    </style>

    <main>
      <div class="sr-container">
        <a href="/" class="sr-back">← Back to Home</a>

        <div class="sr-header">
          <h1>Submit a Review</h1>
          <p>Select your dorm, house, and room number to get started.</p>
        </div>

        <!-- Dorm -->
        <div class="sr-field">
          <label for="sr-dorm-select">Dorm</label>
          <select id="sr-dorm-select">
            <option value="">Select a dorm…</option>
          </select>
        </div>

        <!-- House -->
        <div class="sr-field">
          <label for="sr-house-select">House</label>
          <select id="sr-house-select" disabled>
            <option value="">Select a house…</option>
          </select>
        </div>

        <!-- Room Number (typeahead) -->
        <div class="sr-field">
          <label for="sr-room-input">Room Number</label>
          <div class="sr-room-wrapper">
            <input type="text" id="sr-room-input" placeholder="Type a room number…" autocomplete="off" disabled />
            <div class="sr-room-dropdown" id="sr-room-dropdown"></div>
          </div>
        </div>

        <button class="sr-go-btn" id="sr-go-btn" disabled>Go to Review Form</button>
      </div>
    </main>

    <footer>
      <p>&copy; 2026 Room for Improvement</p>
    </footer>

    <script>
    (function() {
      var allHouses = [];
      var allRooms = [];
      var selectedRoomId = null;
      var selectedRoomNumber = null;
      var selectedDorm = null;
      var selectedHouse = null;
      var isNewRoom = false;

      var dormSel = document.getElementById('sr-dorm-select');
      var houseSel = document.getElementById('sr-house-select');
      var roomInput = document.getElementById('sr-room-input');
      var roomDropdown = document.getElementById('sr-room-dropdown');
      var goBtn = document.getElementById('sr-go-btn');

      // Load house data
      fetch('/api/houses')
        .then(function(r) { return r.json(); })
        .then(function(houses) {
          allHouses = houses;
          var dorms = [];
          var seen = {};
          houses.forEach(function(h) {
            if (!seen[h.dorm]) { seen[h.dorm] = true; dorms.push(h.dorm); }
          });
          dorms.sort();
          dorms.forEach(function(d) {
            var opt = document.createElement('option');
            opt.value = d; opt.textContent = d.replace(/_/g, '-');
            dormSel.appendChild(opt);
          });
        })
        .catch(function() {
          dormSel.innerHTML = '<option value="">Could not load data</option>';
        });

      dormSel.addEventListener('change', function() {
        selectedDorm = dormSel.value;
        selectedHouse = null;
        selectedRoomId = null;
        selectedRoomNumber = null;
        isNewRoom = false;
        houseSel.innerHTML = '<option value="">Select a house…</option>';
        houseSel.disabled = !selectedDorm;
        roomInput.value = '';
        roomInput.disabled = true;
        roomDropdown.classList.remove('open');
        goBtn.disabled = true;
        if (!selectedDorm) return;
        var houses = allHouses.filter(function(h) { return h.dorm === selectedDorm; });
        houses.sort(function(a, b) { return a.house.localeCompare(b.house); });
        houses.forEach(function(h) {
          var opt = document.createElement('option');
          opt.value = h.house; opt.textContent = h.house;
          houseSel.appendChild(opt);
        });
      });

      houseSel.addEventListener('change', function() {
        selectedHouse = houseSel.value;
        selectedRoomId = null;
        selectedRoomNumber = null;
        isNewRoom = false;
        roomInput.value = '';
        roomInput.disabled = !selectedHouse;
        roomDropdown.classList.remove('open');
        goBtn.disabled = true;
        allRooms = [];
        if (!selectedHouse) return;
        // Fetch rooms for this dorm/house
        fetch('/api/rooms-by-house?dorm=' + encodeURIComponent(selectedDorm) + '&house=' + encodeURIComponent(selectedHouse))
          .then(function(r) { return r.json(); })
          .then(function(rooms) { allRooms = rooms; })
          .catch(function() { allRooms = []; });
      });

      roomInput.addEventListener('input', function() {
        var q = roomInput.value.trim();
        selectedRoomId = null;
        selectedRoomNumber = null;
        isNewRoom = false;
        goBtn.disabled = true;
        if (!q) { roomDropdown.classList.remove('open'); return; }
        showRoomDropdown(q);
      });

      roomInput.addEventListener('focus', function() {
        var q = roomInput.value.trim();
        if (q) showRoomDropdown(q);
      });

      document.addEventListener('click', function(e) {
        if (!roomInput.contains(e.target) && !roomDropdown.contains(e.target)) {
          roomDropdown.classList.remove('open');
        }
      });

      function showRoomDropdown(q) {
        var matches = allRooms.filter(function(r) {
          return r.roomNumber.toLowerCase().includes(q.toLowerCase());
        });
        matches.sort(function(a, b) { return a.roomNumber.localeCompare(b.roomNumber, undefined, { numeric: true }); });

        roomDropdown.innerHTML = '';

        matches.slice(0, 12).forEach(function(r) {
          var item = document.createElement('div');
          item.className = 'sr-room-item';
          item.innerHTML = '<span class="sr-room-num">' + escHtml(r.roomNumber) + '</span>'
            + '<span class="sr-room-meta">' + escHtml(r.roomType || '') + (r.floor ? ' · Floor ' + escHtml(r.floor) : '') + '</span>';
          item.addEventListener('mousedown', function(e) {
            e.preventDefault();
            selectRoom(r);
          });
          roomDropdown.appendChild(item);
        });

        // "Add new room" option if no exact match
        var exactMatch = allRooms.find(function(r) { return r.roomNumber.toLowerCase() === q.toLowerCase(); });
        if (!exactMatch) {
          var addItem = document.createElement('div');
          addItem.className = 'sr-room-item sr-add-new';
          addItem.innerHTML = '+ Add "' + escHtml(q) + '" as a new room';
          addItem.addEventListener('mousedown', function(e) {
            e.preventDefault();
            selectNewRoom(q);
          });
          roomDropdown.appendChild(addItem);
        }

        roomDropdown.classList.toggle('open', roomDropdown.children.length > 0);
      }

      function selectRoom(r) {
        selectedRoomId = r.id;
        selectedRoomNumber = r.roomNumber;
        isNewRoom = false;
        roomInput.value = r.roomNumber;
        roomDropdown.classList.remove('open');
        goBtn.disabled = false;
      }

      function selectNewRoom(roomNumber) {
        selectedRoomId = null;
        selectedRoomNumber = roomNumber;
        isNewRoom = true;
        roomInput.value = roomNumber;
        roomDropdown.classList.remove('open');
        goBtn.disabled = false;
      }

      goBtn.addEventListener('click', function() {
        if (!selectedDorm || !selectedHouse || !selectedRoomNumber) return;
        if (isNewRoom) {
          // POST to create the room, then redirect to review
          fetch('/api/add-room', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ dorm: selectedDorm, house: selectedHouse, roomNumber: selectedRoomNumber })
          })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.id) {
              window.location.href = '/rooms/' + encodeURIComponent(data.id) + '/review';
            } else {
              alert('Error creating room. Please try again.');
            }
          })
          .catch(function() { alert('Error creating room. Please try again.'); });
        } else {
          window.location.href = '/rooms/' + encodeURIComponent(selectedRoomId) + '/review';
        }
      });

      function escHtml(s) {
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
      }
    })();
    </script>
  </body>
</html>
